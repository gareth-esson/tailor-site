<script>
  function initTopicsCarousel() {
    const track = document.querySelector<HTMLElement>('.home-topics__track');
    const prevBtn = document.querySelector<HTMLButtonElement>('.home-topics__arrow--prev');
    const nextBtn = document.querySelector<HTMLButtonElement>('.home-topics__arrow--next');
    if (!track || !prevBtn || !nextBtn) return;

    function updateArrows() {
      const { scrollLeft, scrollWidth, clientWidth } = track!;
      prevBtn!.disabled = scrollLeft <= 4;
      nextBtn!.disabled = scrollLeft + clientWidth >= scrollWidth - 4;
    }

    function scroll(direction: number) {
      const card = track!.querySelector<HTMLElement>('.home-topics__card');
      if (!card) return;
      const gap = parseFloat(getComputedStyle(track!).gap) || 16;
      const distance = (card.offsetWidth + gap) * 2;
      track!.scrollBy({ left: direction * distance, behavior: 'smooth' });
    }

    prevBtn.addEventListener('click', () => scroll(-1));
    nextBtn.addEventListener('click', () => scroll(1));
    track.addEventListener('scroll', updateArrows, { passive: true });
    updateArrows();
  }

  document.addEventListener('astro:page-load', initTopicsCarousel);
  document.addEventListener('DOMContentLoaded', initTopicsCarousel);
</script>

---
/**
 * Landing page template [C3] — /topics/{slug}
 * 23 instances. Teacher-facing topic landing pages.
 * Aggregates questions, glossary terms, and blog posts from underlying granular topics.
 * Uses Tailor layer (default — Lexend, neutral surfaces, teal accent).
 */
import BaseLayout from '../../layouts/BaseLayout.astro';
import CtaExploreLessons from '../../components/CtaExploreLessons.astro';
import CtaBringToSchool from '../../components/CtaBringToSchool.astro';
import { getLandingPages, getQuestions, getGlossaryTerms, getBlogPosts, getGlossaryIndex, getCurriculumStatements } from '../../lib/content';
import { renderBlocks } from '../../lib/render-blocks';
import { injectGlossaryTooltips } from '../../lib/glossary-tooltips';
import { getPostItImagePath } from '../../lib/post-it-images';
import type { LandingPage, Question, GlossaryTerm, BlogPost, CurriculumStatement } from '../../lib/types';
import topicAliases from '../../../docs/topic-aliases.json';

export const prerender = true;

export async function getStaticPaths() {
  const landingPages = await getLandingPages();
  const allQuestions = await getQuestions();
  const allGlossary = await getGlossaryTerms();
  const allBlog = await getBlogPosts();
  const allCurriculum = await getCurriculumStatements();
  const glossaryIndex = await getGlossaryIndex();

  return landingPages.map((lp) => {
    // Collect granular topic IDs for this landing page
    const granularTopicIds = new Set(lp.granularTopicIds);

    // Aggregate questions: where primary topic matches any granular topic
    const questions = allQuestions
      .filter((q) => q.topicIds.some((tid) => granularTopicIds.has(tid)))
      .sort((a, b) => {
        // Answered questions first (have body content), then alphabetically
        const aHasAnswer = a.body.length > 0 ? 0 : 1;
        const bHasAnswer = b.body.length > 0 ? 0 : 1;
        if (aHasAnswer !== bHasAnswer) return aHasAnswer - bHasAnswer;
        return a.question.localeCompare(b.question);
      });

    // Aggregate glossary terms: where topic matches any granular topic
    const glossary = allGlossary
      .filter((g) => g.topicIds.some((tid) => granularTopicIds.has(tid)))
      .sort((a, b) => a.term.localeCompare(b.term));

    // Aggregate blog posts: where Topic or Secondary Topics match any granular topic
    // Blog posts use landing page IDs (not granular topic IDs) for Topic relations
    const blogPosts = allBlog
      .filter((bp) => {
        const bpTopicIds = [...bp.topicIds, ...bp.secondaryTopicIds];
        return bpTopicIds.includes(lp.id);
      })
      .sort((a, b) => b.title.localeCompare(a.title)); // placeholder sort — dates not yet in type

    // Aggregate curriculum statements: where any of the statement's topicIds
    // match any of the landing page's granularTopicIds. Deduplicate by id.
    const seen = new Set<string>();
    const curriculumStatements = allCurriculum
      .filter((cs) => {
        if (seen.has(cs.id)) return false;
        const matches = cs.topicIds.some((tid) => granularTopicIds.has(tid));
        if (matches) seen.add(cs.id);
        return matches;
      })
      .sort((a, b) => a.source.localeCompare(b.source) || a.statement.localeCompare(b.statement));

    // Related landing pages: same category, excluding self
    const relatedPages = landingPages
      .filter((other) => other.id !== lp.id && other.category === lp.category)
      .map((other) => ({ title: other.title, slug: other.slug, category: other.category }));

    return {
      params: { slug: lp.slug },
      props: {
        landingPage: lp,
        questions,
        glossary,
        blogPosts,
        relatedPages,
        glossaryIndex,
        curriculumStatements,
      },
    };
  });
}

interface Props {
  landingPage: LandingPage;
  questions: Question[];
  glossary: GlossaryTerm[];
  blogPosts: BlogPost[];
  relatedPages: { title: string; slug: string; category: string | null }[];
  glossaryIndex: Record<string, any>;
  curriculumStatements: CurriculumStatement[];
}

const { landingPage, questions, glossary, blogPosts, relatedPages, glossaryIndex, curriculumStatements } = Astro.props;

// Topic illustration
import { getTopicIllustrationPath } from '../../lib/topic-illustrations';
const illustrationSrc = getTopicIllustrationPath(landingPage.slug);

// Render body content (overview, curriculum mapping, learning objectives)
const bodyHtml = renderBlocks(landingPage.body, { headingOffset: 0 });
const bodyWithTooltips = injectGlossaryTooltips(bodyHtml, glossaryIndex, undefined);

// Curriculum mapping: group by source and build summary
const safeStatements = curriculumStatements ?? [];
const dfeStatements = safeStatements.filter(s => s.source.startsWith('DfE'));
const psheStatements = safeStatements.filter(s => s.source.startsWith('PSHE'));
const allKeyStages = [...new Set(safeStatements.flatMap(s => s.keyStages))].sort();

// Build granular topic slugs for the CTA URL
const topicSlugs = landingPage.granularTopics.map((t) => t.slug);

// Map category to --cat-* token name
const categoryTokenMap: Record<string, string> = {
  'Relationships': 'relationships',
  'Sex & Sexual Health': 'sexual-health',
  'Puberty & The Body': 'puberty',
  'Identity & Diversity': 'identity',
  'Online Safety & Media': 'online-safety',
  'Safety & Safeguarding': 'safety',
  'Health & Wellbeing': 'wellbeing',
};
const catToken = categoryTokenMap[landingPage.category || ''] || 'relationships';

// Search aliases for Pagefind indexing
const aliases = (topicAliases as Record<string, string[]>)[landingPage.slug] || [];

// SEO metadata
const metaTitle = landingPage.metaTitle || `${landingPage.title} | Tailor Education`;
const metaDescription = landingPage.metaDescription || `Explore ${landingPage.title} — questions, key terms, and teaching resources for RSE from Tailor Education.`;
const canonicalPath = `/topics/${landingPage.slug}/`;

// JSON-LD — WebPage with educationalLevel
const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'WebPage',
  name: landingPage.title,
  description: metaDescription,
  about: {
    '@type': 'Thing',
    name: landingPage.title,
  },
  educationalLevel: 'Secondary',
  provider: {
    '@type': 'Organization',
    name: 'Tailor Education',
    url: 'https://tailoreducation.org.uk',
  },
};

// Questions: limit to 6 with post-it + simpleAnswer for b11-sample-card display
const displayQuestions = questions
  .filter((q) => q.body.length > 0 && q.hasPostItScan && q.simpleAnswer?.length > 0)
  .slice(0, 6);

---

<BaseLayout
  title={metaTitle}
  description={metaDescription}
  canonicalPath={canonicalPath}
  jsonLd={jsonLd}
>
  <div class="landing-page" data-pagefind-body>
    <!-- §1 Hero -->
    <section class="landing-hero">
      <div class="mx-auto w-full max-w-[var(--container-max-shell)] px-[var(--space-global-gutter)] py-[var(--space-global-xl)]">
        {illustrationSrc && (
          <div class="landing-hero__illustration">
            <img src={illustrationSrc} alt="" class="landing-hero__illustration-img" />
          </div>
        )}
        <span class="landing-hero__category" style={`--cat-color: var(--cat-${catToken})`}>
          {landingPage.category}
        </span>
        <h1 class="landing-hero__title">{landingPage.title}</h1>

        {/* Topic search aliases — indexed by Pagefind but hidden from view */}
        {aliases.length > 0 && (
          <div data-pagefind-meta="aliases" style="display:none">
            {aliases.join(', ')}
          </div>
        )}
      </div>
    </section>

    <!-- §2 Topic overview (body prose) -->
    {bodyWithTooltips && (
      <section class="landing-body">
        <div class="mx-auto w-full max-w-[var(--container-max-shell)] px-[var(--space-global-gutter)] py-[var(--space-struct-y-base)]">
          <div class="prose" style="max-width: var(--container-max-prose);" set:html={bodyWithTooltips} />
        </div>
      </section>
    )}

    <!-- §3 Curriculum mapping (auto-generated) -->
    {safeStatements.length > 0 && (
      <section class="landing-curriculum" style="background: var(--bg-surface-alt);">
        <div class="mx-auto w-full max-w-[var(--container-max-shell)] px-[var(--space-global-gutter)] py-[var(--space-struct-y-base)]">
          <h2 class="landing-section__title">Curriculum alignment</h2>
          <p class="landing-curriculum__summary">
            This topic addresses
            {dfeStatements.length > 0 && (
              <>{` ${dfeStatements.length} requirement${dfeStatements.length === 1 ? '' : 's'} from the DfE statutory RSE guidance`}</>
            )}
            {dfeStatements.length > 0 && psheStatements.length > 0 && ' and'}
            {psheStatements.length > 0 && (
              <>{` ${psheStatements.length} learning outcome${psheStatements.length === 1 ? '' : 's'} from the PSHE Association Programme of Study`}</>
            )}
            {allKeyStages.length > 0 && (
              <>{`, across ${allKeyStages.join(', ')}`}</>
            )}.
          </p>
          <details class="curriculum-detail">
            <summary class="curriculum-detail__toggle">
              View all curriculum references
            </summary>
            <div class="curriculum-detail__content">
              {dfeStatements.length > 0 && (
                <>
                  <h3>{dfeStatements[0].source}</h3>
                  <ul>
                    {dfeStatements.map((s) => (
                      <li>
                        <span class="curriculum-statement__text">"{s.statement}"</span>
                        {(s.sectionReference || s.keyStages.length > 0) && (
                          <span class="curriculum-statement__ref">
                            {[s.sectionReference, s.keyStages.length > 0 ? s.keyStages.join(', ') : ''].filter(Boolean).join(' · ')}
                          </span>
                        )}
                      </li>
                    ))}
                  </ul>
                </>
              )}
              {psheStatements.length > 0 && (
                <>
                  <h3>{psheStatements[0].source}</h3>
                  <ul>
                    {psheStatements.map((s) => (
                      <li>
                        <span class="curriculum-statement__text">"{s.statement}"</span>
                        {(s.sectionReference || s.keyStages.length > 0) && (
                          <span class="curriculum-statement__ref">
                            {[s.sectionReference, s.keyStages.length > 0 ? s.keyStages.join(', ') : ''].filter(Boolean).join(' · ')}
                          </span>
                        )}
                      </li>
                    ))}
                  </ul>
                </>
              )}
            </div>
          </details>
        </div>
      </section>
    )}

    <!-- §4 CTA [A11] — mid-page -->
    <CtaExploreLessons topicTitle={landingPage.title} topicSlugs={topicSlugs} />

    <!-- §5 Questions young people ask -->
    {displayQuestions.length > 0 && (
      <section class="landing-questions">
        <div class="mx-auto w-full max-w-[var(--container-max-shell)] px-[var(--space-global-gutter)] py-[var(--space-struct-y-base)]">
          <h2 class="landing-section__title">Questions young people ask</h2>
          <div class="landing-questions__stack">
            {displayQuestions.map((q) => {
              const postItImage = getPostItImagePath(q.slug);
              return (
                <a href={`/anonymous_question/${q.slug}`} class="b11-sample-card">
                  {postItImage && (
                    <img
                      src={postItImage}
                      alt=""
                      class="b11-sample-card__postit"
                      loading="lazy"
                    />
                  )}
                  <div class="b11-sample-card__body">
                    {q.okayToAskCategory && (
                      <span class="b11-sample-card__eyebrow">{q.okayToAskCategory}</span>
                    )}
                    <div class="b11-sample-card__question">{q.question}</div>
                    {q.simpleAnswer && (
                      <p class="b11-sample-card__excerpt">{q.simpleAnswer}</p>
                    )}
                    <span class="b11-sample-card__link">Read the full answer</span>
                  </div>
                </a>
              );
            })}
          </div>
          {questions.length > 6 && (
            <div class="landing-questions__more">
              <a href="/questions/" class="btn btn--sm btn--outline has-icon-hover">
                See all {questions.length} questions
              </a>
            </div>
          )}
        </div>
      </section>
    )}

    <!-- §6 For teachers: further reading (conditional) -->
    {blogPosts.length > 0 && (
      <section class="landing-blog" style="background: var(--bg-surface-alt);">
        <div class="mx-auto w-full max-w-[var(--container-max-shell)] px-[var(--space-global-gutter)] py-[var(--space-struct-y-base)]">
          <h2 class="landing-section__title">For teachers: further reading</h2>
          <div class="landing-blog__grid">
            {blogPosts.map((bp) => (
              <a href={`/blog/${bp.slug}`} class="card blog-card">
                <div class="card__body">
                  {bp.targetAudience && (
                    <div class="card__eyebrow">{bp.targetAudience}</div>
                  )}
                  <h3 class="card__title">{bp.title}</h3>
                  {bp.author && (
                    <div class="blog-card__author">By {bp.author}</div>
                  )}
                </div>
              </a>
            ))}
          </div>
        </div>
      </section>
    )}

    <!-- §7 Related landing pages -->
    {relatedPages.length > 0 && (
      <section class="landing-related">
        <div class="mx-auto w-full max-w-[var(--container-max-shell)] px-[var(--space-global-gutter)] py-[var(--space-struct-y-base)]">
          <h2 class="landing-section__title">Related topics</h2>
          <div class="landing-related__pills">
            {relatedPages.map((rp) => (
              <a href={`/topics/${rp.slug}`} class="landing-pill">
                {rp.title}
              </a>
            ))}
          </div>
        </div>
      </section>
    )}

    <!-- §8 CTA [A12] — bottom of page  -->
    <CtaBringToSchool topicTitle={landingPage.title} serviceTarget={landingPage.serviceCtaTarget} />
  </div>
</BaseLayout>

<style>
  /* ========================================
     Landing page [C3] styles
     ======================================== */
  .landing-page {
    background: var(--bg-page);
  }

  /* --- §1 Hero --- */
  .landing-hero {
    background: var(--bg-surface);
    border-bottom: var(--border-width-xs) solid var(--border-subtle);
  }

  .landing-hero__illustration {
    margin-bottom: var(--space-global-xs);
    width: fit-content;
    background: var(--bg-surface-alt);
    border-radius: var(--radius-lg);
    overflow: hidden;
  }

  .landing-hero__illustration-img {
    width: 10rem;
    height: 10rem;
    object-fit: contain;
    display: block;
  }

  @media (min-width: 640px) {
    .landing-hero__illustration-img {
      width: 12rem;
      height: 12rem;
    }
  }

  @media (min-width: 1024px) {
    .landing-hero__illustration-img {
      width: 14rem;
      height: 14rem;
    }
  }

  .landing-hero__category {
    display: inline-block;
    font-family: var(--font-tailor-body-stack);
    font-size: var(--text-card-size-body);
    font-weight: var(--font-weight-semibold);
    color: var(--cat-color, var(--text-body-muted));
    text-transform: uppercase;
    letter-spacing: var(--section-eyebrow-ls);
    margin-bottom: var(--space-global-xs);
  }

  .landing-hero__title {
    font-family: var(--font-tailor-heading-stack);
    font-size: var(--text-display-size-h1);
    font-weight: var(--heading-weight-h1);
    color: var(--text-heading);
    margin: 0;
    line-height: var(--lh-display);
  }

  /* --- §2 Body (overview / curriculum / objectives) --- */
  .landing-body :global(.prose) {
    font-family: var(--font-tailor-body-stack);
    font-size: var(--text-prose-size-body);
    color: var(--text-body);
    line-height: var(--lh-prose);
  }

  .landing-body :global(.prose h2) {
    font-family: var(--font-tailor-heading-stack);
    font-size: var(--text-prose-size-h2);
    font-weight: var(--heading-weight-h2);
    color: var(--brand-accent-text);
    margin-top: var(--space-global-lg);
    margin-bottom: var(--space-global-sm);
  }

  .landing-body :global(.prose h3) {
    font-family: var(--font-tailor-heading-stack);
    font-size: var(--text-prose-size-h3);
    font-weight: var(--heading-weight-h3);
    color: var(--text-heading);
    margin-top: var(--space-global-md);
    margin-bottom: var(--space-global-xs);
  }

  .landing-body :global(.prose p) {
    margin-bottom: var(--space-global-sm);
  }

  .landing-body :global(.prose ul),
  .landing-body :global(.prose ol) {
    margin-bottom: var(--space-global-sm);
    padding-left: 1.5rem;
  }

  .landing-body :global(.prose li) {
    margin-bottom: 0.25rem;
  }

  .landing-body :global(.prose a) {
    color: var(--brand-accent-text);
    text-decoration: underline;
  }

  /* --- §3 Curriculum mapping --- */
  .landing-curriculum__summary {
    font-family: var(--font-tailor-body-stack);
    font-size: var(--text-prose-size-body);
    color: var(--text-body);
    line-height: var(--lh-prose);
    margin: 0 0 var(--space-global-md);
  }

  .curriculum-detail__toggle {
    font-family: var(--font-tailor-body-stack);
    font-size: var(--text-prose-size-body);
    font-weight: var(--font-weight-semibold);
    color: var(--brand-accent-text);
    cursor: pointer;
  }

  .curriculum-detail__content h3 {
    font-family: var(--font-tailor-heading-stack);
    font-size: var(--text-prose-size-h3);
    font-weight: var(--heading-weight-h3);
    color: var(--text-heading);
    margin-top: var(--space-global-md);
    margin-bottom: var(--space-global-xs);
  }

  .curriculum-detail__content ul {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .curriculum-detail__content li {
    margin-bottom: var(--space-global-xs);
    display: flex;
    flex-direction: column;
    gap: 0.125rem;
  }

  .curriculum-statement__text {
    font-family: var(--font-tailor-body-stack);
    font-size: var(--text-prose-size-body);
    color: var(--text-body);
    font-style: italic;
  }

  .curriculum-statement__ref {
    font-family: var(--font-tailor-body-stack);
    font-size: var(--text-card-size-body);
    color: var(--text-body-muted);
  }

  /* --- Shared section title --- */
  .landing-section__title {
    font-family: var(--font-tailor-heading-stack);
    font-size: var(--text-prose-size-h2);
    font-weight: var(--heading-weight-h2);
    color: var(--text-heading);
    margin: 0 0 var(--space-global-md);
  }

  /* --- §4 Questions --- */
  .landing-questions__stack {
    display: flex;
    flex-direction: column;
    gap: var(--space-global-md);
  }

  .landing-questions__more {
    display: flex;
    justify-content: center;
    margin-top: var(--space-global-xl);
  }

  /* --- §5 Blog cards --- */
  .landing-blog__grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-global-sm);
  }

  .blog-card {
    text-decoration: none;
    color: inherit;
  }

  .blog-card__author {
    font-size: var(--text-card-size-body);
    color: var(--text-body-muted);
    margin-top: var(--space-global-xs);
  }

  /* --- §7 Related topic pills --- */
  .landing-related__pills {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-global-xs);
  }

  .landing-pill {
    display: inline-block;
    padding: var(--space-global-xs) var(--space-global-sm);
    background: var(--bg-surface);
    border: var(--border-width-xs) solid var(--border-subtle);
    border-radius: var(--radius-pill);
    font-family: var(--font-tailor-body-stack);
    font-size: var(--text-card-size-body);
    font-weight: var(--font-weight-medium);
    color: var(--text-body);
    text-decoration: none;
    transition: border-color var(--transition-duration) var(--transition-easing),
                color var(--transition-duration) var(--transition-easing);
  }

  .landing-pill:hover {
    border-color: var(--brand-accent);
    color: var(--brand-accent-text);
  }

  /* --- Responsive --- */
  @media (min-width: 640px) {
    .landing-blog__grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (min-width: 1024px) {
    .landing-blog__grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }
</style>

# Notion — required for content
NOTION_API_KEY=

# Notion data source IDs. Leave blank to use production DBs baked
# into src/lib/fetchers.ts. Set per-environment when pointing at a
# staging Notion workspace.
NOTION_QUESTIONS_DB=
NOTION_GLOSSARY_DB=
NOTION_TOPICS_DB=
NOTION_CURRICULUM_DB=
NOTION_TESTIMONIALS_DB=
NOTION_LANDING_PAGES_DB=
NOTION_BLOG_DB=

# Google Analytics — optional (site works without, no tracking)
GA4_MEASUREMENT_ID=

# Resend — required for contact form to send emails
RESEND_API_KEY=

# Stripe — optional (book purchase button hidden when unset)
BOOK_STRIPE_URL=

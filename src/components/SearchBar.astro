---
/**
 * Site search bar [A4] with instant results dropdown [A5].
 * Uses Pagefind for client-side search.
 * Desktop: visible text input in header.
 * Mobile: icon toggle that expands to input.
 */
---

<div class="search-bar" id="search-bar">
  <!-- Mobile toggle -->
  <button
    class="search-bar__toggle"
    type="button"
    aria-label="Open search"
    aria-expanded="false"
    aria-controls="search-bar-input"
  >
    <svg width="20" height="20" viewBox="0 0 20 20" fill="none" aria-hidden="true">
      <circle cx="8.5" cy="8.5" r="5.75" stroke="currentColor" stroke-width="1.5"/>
      <path d="M13 13L17 17" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
    </svg>
  </button>

  <!-- Search input -->
  <div class="search-bar__input-wrap" id="search-bar-input-wrap">
    <svg class="search-bar__icon" width="18" height="18" viewBox="0 0 20 20" fill="none" aria-hidden="true">
      <circle cx="8.5" cy="8.5" r="5.75" stroke="currentColor" stroke-width="1.5"/>
      <path d="M13 13L17 17" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
    </svg>
    <input
      class="search-bar__input"
      type="search"
      id="search-bar-input"
      placeholder="Search questions, topics, glossary..."
      autocomplete="off"
      aria-label="Search the site"
    />
    <button class="search-bar__close" type="button" aria-label="Close search">
      <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
        <path d="M4 4L12 12M12 4L4 12" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
      </svg>
    </button>
  </div>

  <!-- Instant results dropdown [A5] -->
  <div class="search-bar__dropdown" id="search-dropdown" aria-live="polite" hidden>
    <div class="search-bar__results" id="search-results"></div>
    <a class="search-bar__see-all" id="search-see-all" href="/search">
      See all results &rarr;
    </a>
  </div>
</div>

<script is:inline>
  function initSearch() {
    var bar = document.getElementById('search-bar');
    if (!bar) return;

    var input = document.getElementById('search-bar-input');
    var inputWrap = document.getElementById('search-bar-input-wrap');
    var dropdown = document.getElementById('search-dropdown');
    var resultsContainer = document.getElementById('search-results');
    var seeAllLink = document.getElementById('search-see-all');
    var toggle = bar.querySelector('.search-bar__toggle');
    var closeBtn = bar.querySelector('.search-bar__close');

    var pagefind = null;
    var debounceTimer;

    // Lazy-load Pagefind
    async function loadPagefind() {
      if (pagefind) return pagefind;
      try {
        pagefind = await import('/pagefind/pagefind.js');
        await pagefind.init();
      } catch (e) {
        pagefind = null;
      }
      return pagefind;
    }

    var typeLabels = {
      'anonymous_question': 'Okay to Ask',
      'glossary': 'Glossary',
      'topics': 'Topics',
      'blog': 'Blog',
      'services': 'Services',
      'training': 'Services',
    };

    function getContentType(url) {
      if (url.includes('/anonymous_question/')) return 'anonymous_question';
      if (url.includes('/glossary/')) return 'glossary';
      if (url.includes('/topics/')) return 'topics';
      if (url.includes('/blog/')) return 'blog';
      if (url.includes('/services/') || url.includes('/training')) return 'services';
      return 'other';
    }

    async function doSearch(query) {
      if (!query || query.length < 2) {
        if (dropdown) dropdown.setAttribute('hidden', '');
        return;
      }

      var pf = await loadPagefind();
      if (!pf) return;

      var search = await pf.search(query);
      var results = await Promise.all(
        search.results.slice(0, 8).map(function(r) { return r.data(); })
      );

      if (results.length === 0) {
        if (resultsContainer) {
          resultsContainer.innerHTML = '<div class="search-bar__empty">No results for \u201c' + query + '\u201d</div>';
        }
        if (dropdown) dropdown.removeAttribute('hidden');
        if (seeAllLink) seeAllLink.style.display = 'none';
        return;
      }

      var grouped = {};
      for (var i = 0; i < results.length; i++) {
        var r = results[i];
        var type = getContentType(r.url);
        if (!grouped[type]) grouped[type] = [];
        grouped[type].push(r);
      }

      var html = '';
      var types = Object.keys(grouped);
      for (var t = 0; t < types.length; t++) {
        var type = types[t];
        var items = grouped[type];
        var label = typeLabels[type] || 'Other';
        html += '<div class="search-bar__group">';
        html += '<div class="search-bar__group-label">' + label + '</div>';
        for (var j = 0; j < items.length; j++) {
          var item = items[j];
          html += '<a class="search-bar__result" href="' + item.url + '"'
            + ' data-query="' + query + '" data-type="' + type + '" data-slug="' + item.url + '">'
            + '<span class="search-bar__result-title">' + ((item.meta && item.meta.title) || item.url) + '</span>'
            + '<span class="search-bar__result-excerpt">' + (item.excerpt || '') + '</span>'
            + '</a>';
        }
        html += '</div>';
      }

      if (resultsContainer) resultsContainer.innerHTML = html;
      if (seeAllLink) {
        seeAllLink.href = '/search?q=' + encodeURIComponent(query);
        seeAllLink.style.display = '';
      }
      if (dropdown) dropdown.removeAttribute('hidden');

      // Track search
      if (typeof window.trackEvent === 'function') {
        window.trackEvent('site_search_query', {
          query: query,
          result_count: search.results.length,
          source_page: window.location.pathname,
        });
      }

      // Track result clicks
      if (resultsContainer) {
        var resultEls = resultsContainer.querySelectorAll('.search-bar__result');
        resultEls.forEach(function(el, idx) {
          el.addEventListener('click', function() {
            if (typeof window.trackEvent === 'function') {
              window.trackEvent('site_search_result_click', {
                query: el.getAttribute('data-query'),
                result_slug: el.getAttribute('data-slug'),
                result_type: el.getAttribute('data-type'),
                position: idx + 1,
              });
            }
          }, { once: true });
        });
      }
    }

    // Input handler with debounce
    if (input) {
      input.addEventListener('input', function() {
        clearTimeout(debounceTimer);
        debounceTimer = setTimeout(function() { doSearch(input.value.trim()); }, 200);
      });
    }

    // Mobile toggle
    if (toggle) {
      toggle.addEventListener('click', function() {
        if (inputWrap) inputWrap.classList.add('is-expanded');
        toggle.setAttribute('aria-expanded', 'true');
        if (input) input.focus();
      });
    }

    // Close button
    if (closeBtn) {
      closeBtn.addEventListener('click', function() {
        if (inputWrap) inputWrap.classList.remove('is-expanded');
        if (toggle) toggle.setAttribute('aria-expanded', 'false');
        if (input) input.value = '';
        if (dropdown) dropdown.setAttribute('hidden', '');
      });
    }

    // Close dropdown on outside click
    document.addEventListener('click', function(e) {
      if (!bar.contains(e.target)) {
        if (dropdown) dropdown.setAttribute('hidden', '');
        if (inputWrap) inputWrap.classList.remove('is-expanded');
        if (toggle) toggle.setAttribute('aria-expanded', 'false');
      }
    });

    // Escape key
    if (input) {
      input.addEventListener('keydown', function(e) {
        if (e.key === 'Escape') {
          if (dropdown) dropdown.setAttribute('hidden', '');
          input.blur();
          if (inputWrap) inputWrap.classList.remove('is-expanded');
          if (toggle) toggle.setAttribute('aria-expanded', 'false');
        }
        if (e.key === 'Enter' && input.value.trim()) {
          window.location.href = '/search?q=' + encodeURIComponent(input.value.trim());
        }
      });
    }
  }

  initSearch();
  document.addEventListener('astro:after-swap', initSearch);
</script>

<style>
  .search-bar {
    position: relative;
    display: flex;
    align-items: center;
  }

  /* Mobile toggle button — hidden; inline input is always visible now */
  .search-bar__toggle {
    display: none;
  }

  /* Input wrapper — visible at all breakpoints */
  .search-bar__input-wrap {
    display: flex;
    align-items: center;
    gap: var(--space-global-xs);
    background: var(--bg-surface-alt);
    border: var(--border-width-xs) solid var(--border-subtle);
    border-radius: var(--radius-sm);
    padding: 0.375rem 0.75rem;
    width: clamp(8rem, 38vw, 14rem);
    transition: border-color var(--transition-duration) var(--transition-easing);
  }

  .search-bar__input-wrap:focus-within {
    border-color: var(--brand-accent);
    outline: var(--focus-ring-width) solid var(--focus-ring);
    outline-offset: var(--focus-ring-offset);
  }

  /* Mobile expanded state */
  .search-bar__input-wrap.is-expanded {
    display: flex;
    position: absolute;
    right: 0;
    top: 50%;
    transform: translateY(-50%);
    width: 16rem;
    z-index: var(--z-dropdown);
    background: var(--bg-surface);
    box-shadow: var(--shadow-md);
  }

  .search-bar__icon {
    flex-shrink: 0;
    color: var(--text-body-muted);
  }

  .search-bar__input {
    flex: 1;
    min-width: 0;
    border: none;
    background: transparent;
    font-family: var(--font-shell-body-stack);
    font-size: var(--text-card-size-body);
    color: var(--text-body);
    outline: none;
    padding: 0;
  }

  .search-bar__input::placeholder {
    color: var(--form-placeholder-color);
  }

  .search-bar__close {
    display: none;
    align-items: center;
    justify-content: center;
    border: none;
    background: none;
    color: var(--text-body-muted);
    cursor: pointer;
    padding: 0;
  }

  /* Dropdown [A5] */
  .search-bar__dropdown {
    position: absolute;
    top: calc(100% + 0.5rem);
    right: 0;
    width: 22rem;
    max-height: 28rem;
    overflow-y: auto;
    background: var(--bg-surface);
    border: var(--border-width-xs) solid var(--border-subtle);
    border-radius: var(--radius-base);
    box-shadow: var(--shadow-lg);
    z-index: var(--z-dropdown);
    padding: var(--space-global-xs);
  }

  .search-bar__group {
    margin-bottom: var(--space-global-xs);
  }

  .search-bar__group:last-child {
    margin-bottom: 0;
  }

  .search-bar__group-label {
    font-family: var(--font-shell-body-stack);
    font-size: var(--text-aux-size-micro);
    font-weight: 600;
    color: var(--text-body-muted);
    text-transform: uppercase;
    letter-spacing: var(--badge-letter-spacing);
    padding: 0.25rem 0.5rem;
  }

  .search-bar__result {
    display: block;
    padding: 0.5rem;
    border-radius: var(--radius-xs);
    text-decoration: none;
    color: var(--text-body);
    transition: background var(--transition-duration) var(--transition-easing);
  }

  .search-bar__result:hover {
    background: var(--bg-surface-alt);
  }

  .search-bar__result-title {
    display: block;
    font-family: var(--font-shell-body-stack);
    font-size: var(--text-card-size-body);
    font-weight: 500;
    color: var(--text-heading);
  }

  .search-bar__result-excerpt {
    display: block;
    font-size: var(--text-aux-size-micro);
    color: var(--text-body-muted);
    margin-top: 0.125rem;
    overflow: hidden;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
  }

  .search-bar__result-excerpt :global(mark) {
    background: var(--brand-accent-soft);
    color: var(--text-body);
    border-radius: 2px;
    padding: 0 1px;
  }

  .search-bar__empty {
    padding: 1rem 0.5rem;
    font-family: var(--font-shell-body-stack);
    font-size: var(--text-card-size-body);
    color: var(--text-body-muted);
    text-align: center;
  }

  .search-bar__see-all {
    display: block;
    padding: 0.5rem;
    text-align: center;
    font-family: var(--font-shell-body-stack);
    font-size: var(--text-card-size-body);
    font-weight: 500;
    color: var(--link-action-color);
    text-decoration: none;
    border-top: var(--border-width-xs) solid var(--border-subtle);
    margin-top: var(--space-global-xs);
    padding-top: var(--space-global-xs);
  }

  .search-bar__see-all:hover {
    color: var(--link-action-color-hover);
  }

  .search-bar__close {
    display: none !important;
  }
</style>

  @media (min-width: 768px) {
    .blog-filters__row {
      flex-direction: row;
      align-items: center;
      gap: var(--space-global-xs) var(--space-global-sm);
    }

    .blog-filters__label {
      margin-right: var(--space-global-xs);
    }

    .blog-filters__scroll {
      overflow-x: visible;
      scroll-snap-type: none;
      flex-wrap: wrap;
      padding-bottom: 0;
    }


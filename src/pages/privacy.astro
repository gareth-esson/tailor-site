---
/**
 * Privacy policy [B12] — /privacy
 * Standard text page. Required for GA4 and localStorage. Tailor layer.
 */
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Privacy Policy — Tailor Education">
  <article class="text-page">
    <div class="mx-auto max-w-3xl px-[var(--space-global-gutter)] py-[var(--space-global-xl)]">
      <h1 class="text-page__title">Privacy policy</h1>

      <section class="text-page__section">
        <h2>What data we collect</h2>
        <p>
          This website uses Google Analytics 4 (GA4) to collect anonymised usage data — pages visited, time on site, and general browsing patterns. This helps us understand how the site is used and improve it over time.
        </p>
        <p>
          We use browser localStorage to store your Simple Mode preference. This is stored on your device only and is not sent to our servers.
        </p>
        <p>
          We do not require user accounts on this website. No personal data is collected beyond what you voluntarily submit through the enquiry form.
        </p>
      </section>

      <section class="text-page__section">
        <h2>Enquiry form data</h2>
        <p>
          If you submit an enquiry via our contact form, we collect your name, email address, school name, and your message. This information is sent directly to our team's email inbox. It is not stored in a database and is not shared with third parties.
        </p>
        <p>
          We use your contact details only to respond to your enquiry. If you'd like us to delete your enquiry, contact us at <a href="mailto:hello@tailoreducation.org.uk">hello@tailoreducation.org.uk</a>.
        </p>
      </section>

      <section class="text-page__section">
        <h2>Cookies and localStorage</h2>
        <p>
          <strong>Google Analytics 4</strong> — uses cookies to distinguish unique users and sessions. These cookies are set by Google and are subject to <a href="https://policies.google.com/privacy" target="_blank" rel="noopener noreferrer">Google's privacy policy</a>.
        </p>
        <p>
          <strong>Simple Mode preference</strong> — stored in your browser's localStorage under the key <code>simple_mode</code>. This is not a cookie and does not leave your device. You can clear it by clearing your browser data.
        </p>
      </section>

      <section class="text-page__section">
        <h2>Third-party services</h2>
        <ul>
          <li><strong>Google Analytics 4</strong> — anonymised usage analytics</li>
          <li><strong>Google Fonts</strong> — web font delivery</li>
          <li><strong>Vercel</strong> — website hosting and serverless functions</li>
          <li><strong>Resend</strong> — enquiry form email delivery</li>
        </ul>
      </section>

      <section class="text-page__section">
        <h2>Your rights</h2>
        <p>
          Under UK GDPR, you have the right to request access to, correction of, or deletion of any personal data we hold about you. To make a request, email <a href="mailto:hello@tailoreducation.org.uk">hello@tailoreducation.org.uk</a>.
        </p>
      </section>
    </div>
  </article>
</BaseLayout>

<style>
  .text-page { background: var(--bg-page); }
  .text-page__title { font-family: var(--font-tailor-heading-stack); font-size: var(--text-display-size-h1); font-weight: var(--heading-weight-h1); color: var(--text-heading); margin: 0 0 var(--space-global-lg); }
  .text-page__section { margin-bottom: var(--space-global-xl); }
  .text-page__section h2 { font-family: var(--font-tailor-heading-stack); font-size: var(--text-prose-size-h2); font-weight: var(--heading-weight-h2); color: var(--text-heading); margin: 0 0 var(--space-global-sm); }
  .text-page__section p { font-family: var(--font-tailor-body-stack); font-size: var(--text-prose-size-body); color: var(--text-body); line-height: 1.7; margin: 0 0 var(--space-global-sm); max-width: 36rem; }
  .text-page__section ul { font-family: var(--font-tailor-body-stack); font-size: var(--text-prose-size-body); color: var(--text-body); line-height: 1.7; padding-left: 1.5rem; margin: 0; }
  .text-page__section li { margin-bottom: 0.5rem; }
  .text-page__section a { color: var(--brand-accent-text); }
  .text-page__section code { font-size: 0.9em; background: var(--bg-surface-alt); padding: 0.125rem 0.375rem; border-radius: var(--radius-xs); }
</style>

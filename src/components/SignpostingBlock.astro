---
/**
 * Signposting block [A8] — C1 question page.
 *
 * Persistent list of relevant support services. Not dismissable.
 * Renders a heading + an .alert--support alert whose body is a 2-col
 * grid of service entries on md+, 1-col on mobile.
 */
import { SUPPORT_SERVICES } from '../lib/support-services';

interface Props {
  services: string[];
}

const { services } = Astro.props;

const resolvedServices = services
  .map((name) => SUPPORT_SERVICES[name])
  .filter(Boolean);

if (resolvedServices.length === 0) return;
---

<h2 class="signposting__heading mb-[var(--space-global-md)] text-center" id="signposting-title">
  Need to talk to someone?
</h2>

<div
  class="alert alert--support"
  role="complementary"
  aria-labelledby="signposting-title"
>
  <div class="alert__content">
    <div class="alert__body">
      <ul class="signposting__list list-none p-0 m-0 grid grid-cols-1 md:grid-cols-2 gap-[var(--space-global-md)] mt-[var(--space-global-sm)]" role="list">
        {resolvedServices.map((svc) => (
          <li class="signposting__item">
            <div class="signposting__name">{svc.name}</div>
            <div class="signposting__desc">{svc.description}</div>
            <div class="signposting__contact">
              {svc.phone && (
                <>
                  <a href={`tel:${svc.phone.replace(/\s/g, '')}`} class="signposting__link">
                    {svc.phone}
                  </a>
                  {' · '}
                </>
              )}
              <a
                href={svc.url}
                target="_blank"
                rel="noopener noreferrer"
                class="signposting__link"
                data-analytics-event="signposting_click"
                data-analytics-service-name={svc.name}
              >
                {svc.urlLabel}
              </a>
            </div>
          </li>
        ))}
      </ul>
    </div>
  </div>
</div>

<style>
  .signposting__heading {
    font-family: var(--font-ota-heading-stack, inherit);
    font-size: var(--text-prose-size-h3);
    font-weight: var(--heading-ota-weight-h3, 600);
    color: var(--text-ota-heading);
    line-height: 1.25;
  }

  .signposting__name {
    font-size: var(--text-prose-size-body);
    font-weight: 700;
    color: inherit;
  }

  .signposting__desc {
    font-size: var(--text-card-size-body);
    color: var(--safeguarding-support-text, inherit);
    margin-top: 0.15rem;
    line-height: 1.5;
  }

  .signposting__contact {
    font-size: var(--text-card-size-body);
    margin-top: 0.35rem;
  }

  .signposting__link {
    color: var(--safeguarding-support-icon);
    text-decoration: underline;
    text-underline-offset: 2px;
  }

  .signposting__link:hover {
    text-decoration: none;
  }

  .signposting__link:focus-visible {
    outline: var(--focus-ring-width) solid var(--safeguarding-support-icon);
    outline-offset: var(--focus-ring-offset);
    border-radius: var(--radius-xs);
  }
</style>

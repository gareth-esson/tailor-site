---
/**
 * CTA block [A13] — bottom of blog posts [C4].
 * If serviceLink is set: "Want help with [service]? Talk to us" → enquiry form.
 * If serviceLink is "none" or empty: "Explore lessons on [topic]" → app library.
 */
import type { LandingPageRef } from '../lib/types';

interface Props {
  /** Service link value from blog post (delivery, drop-days, etc.) or "none" */
  serviceLink: string | null;
  /** Primary topic landing page ref */
  primaryTopic: LandingPageRef | null;
}

const { serviceLink, primaryTopic } = Astro.props;

const serviceMap: Record<string, { label: string; param: string }> = {
  delivery: { label: 'direct RSE delivery', param: 'Direct RSE delivery' },
  training: { label: 'RSE training', param: 'RSE training' },
  'drop-days': { label: 'drop day delivery', param: 'Drop day delivery' },
  'rse-policy-curriculum-planning': { label: 'RSE policy and curriculum planning', param: 'RSE policy & curriculum planning' },
};

const hasService = serviceLink && serviceLink !== 'none' && serviceMap[serviceLink];
const service = hasService ? serviceMap[serviceLink!] : null;
---

{service ? (
  <section class="cta-blog-bottom">
    <div class="mx-auto max-w-[var(--container-max-prose)] px-[var(--space-global-gutter)] py-[var(--space-global-lg)]">
      <div class="cta-blog-bottom__card">
        <h2 class="cta-blog-bottom__title">Want help with {service.label}?</h2>
        <p class="cta-blog-bottom__text">Talk to us about how Tailor Education can support your school.</p>
        <a
          href={`/contact?service=${encodeURIComponent(service.param)}`}
          class="btn btn--std btn--primary has-icon-hover"
          data-analytics-event="cta_click"
          data-analytics-cta-type="blog_to_service"
          data-analytics-service-type={serviceLink}
          data-analytics-target={`/contact?service=${encodeURIComponent(service.param)}`}
        >
          Get in touch
        </a>
      </div>
    </div>
  </section>
) : primaryTopic ? (
  <section class="cta-blog-bottom">
    <div class="mx-auto max-w-[var(--container-max-prose)] px-[var(--space-global-gutter)] py-[var(--space-global-lg)]">
      <div class="cta-blog-bottom__card">
        <h2 class="cta-blog-bottom__title">Explore lessons on {primaryTopic.title}</h2>
        <p class="cta-blog-bottom__text">Browse expert-written RSE lessons in the Tailor library.</p>
        <a
          href={`/topics/${primaryTopic.slug}`}
          class="btn btn--std btn--primary has-icon-hover"
          data-analytics-event="cta_click"
          data-analytics-cta-type="blog_to_app"
          data-analytics-target={`/topics/${primaryTopic.slug}`}
        >
          Explore topic
        </a>
      </div>
    </div>
  </section>
) : null}

<style>
  .cta-blog-bottom__card {
    text-align: center;
    padding: var(--space-global-xl) var(--space-global-lg);
    background: var(--bg-surface-alt);
    border-radius: var(--radius-lg);
  }

  .cta-blog-bottom__title {
    font-family: var(--font-tailor-heading-stack);
    font-size: var(--text-display-size-h3);
    font-weight: var(--heading-weight-h2);
    color: var(--text-heading);
    margin: 0 0 var(--space-global-sm);
  }

  .cta-blog-bottom__text {
    font-size: var(--text-prose-size-body);
    color: var(--text-body-muted);
    margin: 0 0 var(--space-global-md);
    margin-left: auto;
    margin-right: auto;
  }
</style>

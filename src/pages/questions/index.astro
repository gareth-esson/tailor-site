---
/**
 * Okay to Ask landing page [B8] — /questions/
 * The front door for young people. Uses OtA layer.
 * Browse all questions with client-side category filtering + pagination.
 * 7 OtA categories: Anatomy, Puberty, Relationships, Sex, Sexual Health, Sex & the Law, Contraception & Pregnancy.
 */
import BaseLayout from '../../layouts/BaseLayout.astro';
import GlossaryTooltips from '../../components/GlossaryTooltips.astro';
import QuestionCard from '../../components/QuestionCard.astro';
import SignpostingBlock from '../../components/SignpostingBlock.astro';
import { getQuestions } from '../../lib/content';
import type { QuestionRef } from '../../lib/types';

const allQuestions = await getQuestions();

// Only published questions with answers, mapped to QuestionRef
const questions: QuestionRef[] = allQuestions
  .filter((q) => q.body.length > 0)
  .sort((a, b) => a.question.localeCompare(b.question))
  .map((q) => ({
    id: q.id,
    question: q.question,
    slug: q.slug,
    okayToAskCategory: q.okayToAskCategory,
    contentTags: q.contentTags,
  }));

// The 7 OtA browsing categories
const otaCategories = [
  { name: 'Anatomy', token: 'anatomy' },
  { name: 'Puberty', token: 'puberty' },
  { name: 'Relationships', token: 'relationships' },
  { name: 'Sex', token: 'sex' },
  { name: 'Sexual Health', token: 'sexual-health' },
  { name: 'Sex & the Law', token: 'law' },
  { name: 'Contraception & Pregnancy', token: 'contraception' },
];
---

<BaseLayout
  title="Questions — Okay to Ask"
  description="Browse honest, age-appropriate answers to real questions about relationships, sex, puberty and more — from Okay to Ask by Tailor Education."
  canonicalPath="/questions/"
  layer="ota"
>
  <div class="ota-landing">

    {/* ── §1 Hero ── */}
    <section class="surface--ota w-full py-[var(--space-global-2xl)] px-[var(--space-global-gutter)]">
      <div class="mx-auto w-full max-w-[var(--container-max-reading-wide)] text-center">
        <img
          src="/assets/ota-wordmark-dark.svg"
          alt="Okay to Ask"
          class="ota-hero__wordmark mx-auto mb-[var(--space-global-md)]"
          width="280"
          height="48"
        />
        <h1 class="ota-hero__title mb-[var(--space-global-sm)]">
          Real questions from real young people. Answered honestly.
        </h1>
        <p class="ota-hero__subtitle mx-auto">
          Every question here was written anonymously by a young person. No judgement, no awkwardness — just honest answers.
        </p>
      </div>
    </section>

    {/* ── §2 Book promotion ── */}
    <section class="w-full px-[var(--space-global-gutter)]">
      <div class="mx-auto w-full max-w-[var(--container-max-reading-wide)]">
        <div class="b8-book-panel">
          <img
            src="/images/ota-book-hero.webp"
            alt="The Okay to Ask book — closed cover and open spread showing post-it questions and honest answers"
            class="ota-book__img"
            width="800"
            height="533"
            loading="lazy"
          />
          <div class="ota-book__body">
            <h2 class="ota-book__title mb-[var(--space-global-xs)]">The Okay to Ask book</h2>
            <p class="ota-book__text mb-[var(--space-global-md)]">
              Real questions, honest answers, post-it notes and all. The physical book for your home, school, or staff room.
            </p>
            <a href="/book" class="btn btn--std btn--primary has-icon-hover">Get the book</a>
          </div>
        </div>
      </div>
    </section>

    {/* ── §3 Category filter + question card grid ── */}
    <section class="surface--ota w-full py-[var(--space-struct-y-base)] px-[var(--space-global-gutter)]" id="questions-section">
      <div class="mx-auto w-full max-w-[var(--container-max-reading-wide)]">
        <h2 class="ota-questions__heading text-center mb-[var(--space-global-md)]">Browse questions</h2>

        {/* Category filter buttons */}
        <div class="ota-filters flex flex-wrap justify-center gap-[var(--space-global-xs)] mb-[var(--space-global-lg)]" role="group" aria-label="Filter by category">
          <button
            class="ota-filter btn btn--sm btn--tint is-active"
            data-category="all"
            type="button"
            aria-pressed="true"
          >
            All
          </button>
          {otaCategories.map((cat) => (
            <button
              class={`ota-filter badge badge--pill badge--ota-${cat.token}`}
              data-category={cat.name}
              type="button"
              aria-pressed="false"
            >
              {cat.name}
            </button>
          ))}
        </div>

        {/* Question card grid */}
        <ul class="list-none p-0 m-0 grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-[var(--space-global-md)]" role="list" id="question-grid">
          {questions.map((q) => (
            <li data-category={q.okayToAskCategory || ''}>
              <QuestionCard question={q} />
            </li>
          ))}
        </ul>

        {/* Pagination controls */}
        <div class="flex justify-center items-center gap-[var(--space-global-sm)] mt-[var(--space-global-lg)]" id="pagination-controls">
          <button class="btn btn--sm btn--tint" id="pagination-prev" type="button" disabled>Previous</button>
          <span id="pagination-indicator" class="b8-pagination-indicator">Page 1 of 1</span>
          <button class="btn btn--sm btn--tint" id="pagination-next" type="button">Next</button>
        </div>

        <p id="question-count" aria-live="polite" class="b8-question-count text-center mt-[var(--space-global-sm)]">
          {questions.length} questions
        </p>
      </div>
    </section>

    {/* ── §4 What is Okay to Ask? ── */}
    <section class="surface--ota-alt w-full py-[var(--space-struct-y-base)] px-[var(--space-global-gutter)]">
      <div class="mx-auto w-full max-w-[var(--container-max-prose)]">
        <h2 class="ota-about__title text-center mb-[var(--space-global-sm)]">What is Okay to Ask?</h2>
        <p class="ota-about__text">
          Okay to Ask started with anonymous question boxes in schools. Young people wrote down whatever they wanted to know about relationships, sex, their bodies, and growing up. No names, no judgement. We collected those questions and answered every single one honestly.
        </p>
        <p class="ota-about__text">
          This is a Tailor Education project. The same team that delivers RSE in schools wrote every answer on this site.
        </p>
      </div>
    </section>

    {/* ── §5 Signposting ── */}
    <section
      class="w-full py-[var(--space-struct-y-base)] px-[var(--space-global-gutter)]"
      style="background: var(--safeguarding-support-bg);"
      role="complementary"
      aria-label="Support services"
    >
      <div class="mx-auto w-full max-w-[var(--container-max-reading-wide)]">
        <SignpostingBlock services={['Childline', 'Brook', 'The Mix']} />
      </div>
    </section>

  </div>

  <GlossaryTooltips />
</BaseLayout>

<script>
  const PAGE_SIZE = 12;

  function initB8() {
    const filters = document.querySelectorAll<HTMLButtonElement>('.ota-filter');
    const grid = document.getElementById('question-grid');
    const countEl = document.getElementById('question-count');
    const prevBtn = document.getElementById('pagination-prev') as HTMLButtonElement | null;
    const nextBtn = document.getElementById('pagination-next') as HTMLButtonElement | null;
    const indicator = document.getElementById('pagination-indicator');
    const sectionHeading = document.querySelector('#questions-section h2');

    if (!grid || !countEl || !prevBtn || !nextBtn || !indicator) return;

    const allItems = Array.from(grid.querySelectorAll<HTMLLIElement>(':scope > li'));
    let filteredItems: HTMLLIElement[] = [];
    let currentPage = 1;
    let totalPages = 1;

    function applyFilter(category: string) {
      filteredItems = category === 'all'
        ? [...allItems]
        : allItems.filter((li) => li.dataset.category === category);
      currentPage = 1;
      totalPages = Math.max(1, Math.ceil(filteredItems.length / PAGE_SIZE));
      renderPage();
      countEl!.textContent = `${filteredItems.length} question${filteredItems.length !== 1 ? 's' : ''}`;
    }

    function renderPage() {
      const start = (currentPage - 1) * PAGE_SIZE;
      const end = start + PAGE_SIZE;

      allItems.forEach((li) => { li.style.display = 'none'; });

      filteredItems.forEach((li, i) => {
        li.style.display = (i >= start && i < end) ? '' : 'none';
      });

      indicator!.textContent = `Page ${currentPage} of ${totalPages}`;

      prevBtn!.disabled = currentPage <= 1;
      prevBtn!.style.opacity = currentPage <= 1 ? '0.4' : '';
      prevBtn!.style.pointerEvents = currentPage <= 1 ? 'none' : '';

      nextBtn!.disabled = currentPage >= totalPages;
      nextBtn!.style.opacity = currentPage >= totalPages ? '0.4' : '';
      nextBtn!.style.pointerEvents = currentPage >= totalPages ? 'none' : '';

      const paginationContainer = document.getElementById('pagination-controls');
      if (paginationContainer) {
        paginationContainer.style.display = totalPages <= 1 ? 'none' : '';
      }
    }

    filters.forEach((btn) => {
      btn.addEventListener('click', () => {
        filters.forEach((f) => {
          f.classList.remove('is-active');
          f.setAttribute('aria-pressed', 'false');
        });
        btn.classList.add('is-active');
        btn.setAttribute('aria-pressed', 'true');
        applyFilter(btn.dataset.category || 'all');
      });
    });

    prevBtn.addEventListener('click', () => {
      if (currentPage > 1) {
        currentPage--;
        renderPage();
        sectionHeading?.scrollIntoView({ behavior: 'smooth', block: 'start' });
      }
    });

    nextBtn.addEventListener('click', () => {
      if (currentPage < totalPages) {
        currentPage++;
        renderPage();
        sectionHeading?.scrollIntoView({ behavior: 'smooth', block: 'start' });
      }
    });

    applyFilter('all');
  }

  initB8();
  document.addEventListener('astro:after-swap', initB8);
</script>

<style>
  /* ========================================
     Okay to Ask landing [B8]
     ======================================== */
  .ota-landing {
    background: var(--bg-page);
  }

  /* --- Hero --- */
  .ota-hero__wordmark {
    height: 3rem;
    width: auto;
  }

  .ota-hero__title {
    font-size: var(--text-display-size-h1);
    color: var(--text-ota-heading);
    line-height: 1.15;
  }

  .ota-hero__subtitle {
    font-size: var(--text-prose-size-body);
    color: var(--text-ota-muted);
    line-height: var(--lh-body);
  }

  /* --- Book promotion --- */
  .b8-book-panel {
    background: var(--bg-ota-book-panel);
    border-radius: var(--radius-lg);
    box-shadow: var(--shadow-md);
    overflow: hidden;
    margin-top: var(--space-global-lg);
    margin-bottom: var(--space-global-lg);
  }

  .ota-book__title {
    font-size: var(--text-prose-size-h2);
    color: var(--text-ota-heading);
  }

  .ota-book__text {
    font-size: var(--text-prose-size-body);
    color: var(--text-ota-body);
    line-height: var(--lh-body);
  }

  .ota-book__img {
    width: 100%;
    height: auto;
    display: block;
  }

  .ota-book__body {
    padding: var(--space-global-lg) var(--space-global-xl) var(--space-global-xl);
    text-align: center;
  }

  @media (max-width: 767px) {
    .ota-book__body {
      padding: var(--space-global-md) var(--space-global-lg) var(--space-global-lg);
    }
  }

  /* --- Questions section --- */
  .ota-questions__heading {
    font-size: var(--text-prose-size-h2);
    color: var(--text-ota-heading);
  }

  .ota-filter {
    cursor: pointer;
    transition: opacity var(--transition-duration) var(--transition-easing);
  }

  .ota-filter:not(.is-active) {
    opacity: 0.55;
  }

  .ota-filter.is-active {
    opacity: 1;
    outline: var(--focus-ring-width) solid var(--focus-ring);
    outline-offset: var(--focus-ring-offset);
  }

  /* --- Pagination --- */
  .b8-pagination-indicator {
    font-size: var(--text-card-size-body);
    color: var(--text-ota-muted);
  }

  .b8-question-count {
    font-size: var(--text-card-size-body);
    color: var(--text-ota-muted);
  }

  /* --- About --- */
  .ota-about__title {
    font-size: var(--text-prose-size-h2);
    color: var(--text-ota-heading);
  }

  .ota-about__text {
    font-size: var(--text-prose-size-body);
    color: var(--text-ota-body);
    line-height: 1.7;
    max-width: 40rem;
    margin: 0 0 var(--space-global-sm);
  }

  .ota-about__text:last-child {
    margin-bottom: 0;
  }
</style>

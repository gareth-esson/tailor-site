---
/**
 * Blog post template [C4] — /blog/{slug}
 * Teacher-facing editorial content. Tailor layer.
 * Body from Notion with inline glossary tooltips.
 */
import BaseLayout from '../../layouts/BaseLayout.astro';
import GlossaryTooltips from '../../components/GlossaryTooltips.astro';
import CtaBlogBottom from '../../components/CtaBlogBottom.astro';
import { getBlogPosts, getGlossaryIndex, getLandingPages } from '../../lib/content';
import { renderBlocks } from '../../lib/render-blocks';
import { injectGlossaryTooltips } from '../../lib/glossary-tooltips';
import { getRelatedBlogPosts } from '../../lib/related-blog-posts';
import type { BlogPost, LandingPageRef } from '../../lib/types';

export const prerender = true;

export async function getStaticPaths() {
  const posts = await getBlogPosts();
  const allLandingPages = await getLandingPages();
  const glossaryIndex = await getGlossaryIndex();

  return posts.map((post) => {
    const related = getRelatedBlogPosts(post, posts, 3);

    // Resolve primary topic to a landing page ref
    const primaryTopicId = post.topicIds[0];
    const primaryLP = primaryTopicId
      ? allLandingPages.find((lp) => lp.id === primaryTopicId)
      : null;
    const primaryTopic: LandingPageRef | null = primaryLP
      ? { id: primaryLP.id, title: primaryLP.title, slug: primaryLP.slug }
      : null;

    return {
      params: { slug: post.slug },
      props: {
        post,
        relatedPosts: related,
        primaryTopic,
        glossaryIndex,
      },
    };
  });
}

interface Props {
  post: BlogPost;
  relatedPosts: BlogPost[];
  primaryTopic: LandingPageRef | null;
  glossaryIndex: Record<string, any>;
}

const { post, relatedPosts, primaryTopic, glossaryIndex } = Astro.props;

// SEO metadata
const metaTitle = post.metaTitle || `${post.title} | Tailor Education`;
const metaDescription = post.metaDescription || `${post.title} — expert RSE guidance for teachers from Tailor Education.`;
const canonicalPath = `/blog/${post.slug}/`;

// Date formatting
const formattedDate = post.publishedDate
  ? new Intl.DateTimeFormat('en-GB', { day: 'numeric', month: 'short', year: 'numeric' }).format(new Date(post.publishedDate))
  : null;

// JSON-LD — Article
const jsonLd: Record<string, any> = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: post.title,
  author: post.author ? { '@type': 'Person', name: post.author } : undefined,
  publisher: {
    '@type': 'Organization',
    name: 'Tailor Education',
    url: 'https://tailoreducation.org.uk',
  },
  articleSection: post.topics.map((t) => t.title).join(', ') || undefined,
};
if (post.featuredImage) jsonLd.image = post.featuredImage;
if (post.publishedDate) jsonLd.datePublished = post.publishedDate;

// All topics (primary + secondary)
const allTopics = [...post.topics, ...post.secondaryTopics];

// Render body content with glossary tooltips
const bodyHtml = renderBlocks(post.body);
const bodyWithTooltips = injectGlossaryTooltips(bodyHtml, glossaryIndex, undefined);
---

<BaseLayout
  title={metaTitle}
  description={metaDescription}
  canonicalPath={canonicalPath}
  ogType="article"
  ogImage={post.featuredImage || undefined}
  jsonLd={jsonLd}
>
  <article class="blog-post" data-pagefind-body>

    <!-- §1 Featured image + §2 Header -->
    <header class="blog-post__header">
      {post.featuredImage && (
        <div class="mx-auto w-full max-w-[var(--container-max-shell)] px-[var(--space-global-gutter)] pt-[var(--space-global-xl)]">
          <div class="blog-post__hero-img">
            <img
              src={post.featuredImage}
              alt={`Featured image for ${post.title}`}
              loading="eager"
            />
          </div>
        </div>
      )}

      <div class="mx-auto w-full max-w-[var(--container-max-prose)] px-[var(--space-global-gutter)] pt-[var(--space-global-lg)] pb-[var(--space-global-xl)]">
        <h1 class="blog-post__title">{post.title}</h1>

        <div class="blog-post__meta">
          <div class="blog-post__meta-left">
            {post.author && <span class="blog-post__author">By {post.author}</span>}
            {post.author && formattedDate && <span class="blog-post__sep" aria-hidden="true">·</span>}
            {formattedDate && (
              <time datetime={post.publishedDate!}>{formattedDate}</time>
            )}
            {post.targetAudience && (
              <span class="blog-post__audience">{post.targetAudience}</span>
            )}
          </div>
          <div
            class="blog-post__share-wrap"
            data-share-title={post.title}
            data-share-url={`https://tailoreducation.org.uk${canonicalPath}`}
          >
            <button
              class="blog-post__share"
              aria-label="Share this article"
              aria-expanded="false"
            >
              <svg class="share-icon" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <path d="M4 12v8a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2v-8" />
                <polyline points="16 6 12 2 8 6" />
                <line x1="12" y1="2" x2="12" y2="15" />
              </svg>
              <svg class="check-icon" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" style="display:none">
                <polyline points="20 6 9 17 4 12" />
              </svg>
              <span class="sr-only blog-post__share-feedback" aria-live="polite"></span>
            </button>
            <div class="share-dropdown" hidden>
              <a class="share-dropdown__item" data-share="twitter" aria-label="Share on X (Twitter)">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
                <span>X</span>
              </a>
              <a class="share-dropdown__item" data-share="linkedin" aria-label="Share on LinkedIn">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
                <span>LinkedIn</span>
              </a>
              <a class="share-dropdown__item" data-share="facebook" aria-label="Share on Facebook">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/></svg>
                <span>Facebook</span>
              </a>
              <a class="share-dropdown__item" data-share="whatsapp" aria-label="Share on WhatsApp">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
                <span>WhatsApp</span>
              </a>
              <a class="share-dropdown__item" data-share="email" aria-label="Share by email">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="2" y="4" width="20" height="16" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/></svg>
                <span>Email</span>
              </a>
              <button class="share-dropdown__item" data-share="copy" aria-label="Copy link">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"/><path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"/></svg>
                <span>Copy link</span>
              </button>
            </div>
          </div>
        </div>
      </div>
    </header>

    <!-- §3 Body content -->
    {bodyWithTooltips && (
      <section class="blog-post__body">
        <div class="mx-auto w-full max-w-[var(--container-max-prose)] px-[var(--space-global-gutter)] py-[var(--space-struct-y-base)]">
          <div class="prose" set:html={bodyWithTooltips} />
        </div>
      </section>
    )}

    <!-- §4 Topic tags [A16] -->
    {allTopics.length > 0 && (
      <section class="blog-post__tags-section">
        <div class="mx-auto w-full max-w-[var(--container-max-prose)] px-[var(--space-global-gutter)] pb-[var(--space-global-lg)]">
          <div class="blog-post__tags">
            <span class="blog-post__tags-label">Topics</span>
            {post.topics.map((t) => (
              <a
                href={`/topics/${t.slug}`}
                class="blog-post__tag"
                data-analytics-event="blog_to_topic_click"
                data-analytics-blog-slug={post.slug}
                data-analytics-topic-slug={t.slug}
              >
                {t.title}
              </a>
            ))}
            {post.secondaryTopics.map((t) => (
              <a
                href={`/topics/${t.slug}`}
                class="blog-post__tag blog-post__tag--secondary"
                data-analytics-event="blog_to_topic_click"
                data-analytics-blog-slug={post.slug}
                data-analytics-topic-slug={t.slug}
              >
                {t.title}
              </a>
            ))}
          </div>
        </div>
      </section>
    )}

    <!-- §5 Related blog posts [A15] -->
    {relatedPosts.length > 0 && (
      <section class="blog-post__related">
        <div class="mx-auto w-full max-w-[var(--container-max-reading-wide)] px-[var(--space-global-gutter)] py-[var(--space-struct-y-base)]">
          <h2 class="blog-post__section-title">Related articles</h2>
          <div class="blog-post__related-grid">
            {relatedPosts.map((rp) => (
              <a href={`/blog/${rp.slug}`} class="card blog-related-card">
                {rp.featuredImage && (
                  <div class="blog-related-card__img">
                    <img src={rp.featuredImage} alt={rp.title} loading="lazy" />
                  </div>
                )}
                <div class="card__body">
                  {rp.targetAudience && (
                    <div class="card__eyebrow">{rp.targetAudience}</div>
                  )}
                  <div class="card__title">{rp.title}</div>
                  {rp.author && (
                    <div class="blog-related-card__author">By {rp.author}</div>
                  )}
                  {rp.publishedDate && (
                    <div class="blog-related-card__date">
                      <time datetime={rp.publishedDate}>
                        {new Intl.DateTimeFormat('en-GB', { day: 'numeric', month: 'short', year: 'numeric' }).format(new Date(rp.publishedDate))}
                      </time>
                    </div>
                  )}
                </div>
              </a>
            ))}
          </div>
        </div>
      </section>
    )}

    <!-- §6 CTA [A13] -->
    <CtaBlogBottom serviceLink={post.serviceLink} primaryTopic={primaryTopic} />
  </article>
  <GlossaryTooltips />
</BaseLayout>

<script>
function initShare() {
  const wrap = document.querySelector<HTMLElement>('.blog-post__share-wrap');
  if (!wrap) return;

  const btn = wrap.querySelector<HTMLButtonElement>('.blog-post__share');
  const dropdown = wrap.querySelector<HTMLElement>('.share-dropdown');
  if (!btn || !dropdown) return;

  const title = encodeURIComponent(wrap.dataset.shareTitle || document.title);
  const url = encodeURIComponent(wrap.dataset.shareUrl || window.location.href);
  const rawUrl = wrap.dataset.shareUrl || window.location.href;

  function closeDropdown() {
    dropdown.hidden = true;
    btn.setAttribute('aria-expanded', 'false');
  }

  function openDropdown() {
    dropdown.hidden = false;
    btn.setAttribute('aria-expanded', 'true');
  }

  btn.addEventListener('click', async () => {
    // Mobile: use native share sheet
    if (navigator.share && 'ontouchstart' in window) {
      try {
        await navigator.share({ title: wrap.dataset.shareTitle || document.title, url: rawUrl });
      } catch (_) {}
      return;
    }
    // Desktop: toggle dropdown
    if (dropdown.hidden) {
      openDropdown();
    } else {
      closeDropdown();
    }
  });

  // Close on outside click
  document.addEventListener('click', (e) => {
    if (!wrap.contains(e.target as Node)) closeDropdown();
  });

  // Close on Escape
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape') closeDropdown();
  });

  // Handle social share clicks
  dropdown.addEventListener('click', async (e) => {
    const item = (e.target as HTMLElement).closest<HTMLElement>('[data-share]');
    if (!item) return;
    e.preventDefault();

    const type = item.dataset.share;
    const shareUrls: Record<string, string> = {
      twitter: `https://x.com/intent/tweet?text=${title}&url=${url}`,
      linkedin: `https://www.linkedin.com/sharing/share-offsite/?url=${url}`,
      facebook: `https://www.facebook.com/sharer/sharer.php?u=${url}`,
      whatsapp: `https://wa.me/?text=${title}%20${url}`,
      email: `mailto:?subject=${title}&body=${url}`,
    };

    if (type === 'copy') {
      await navigator.clipboard.writeText(rawUrl);
      const label = item.querySelector('span');
      if (label) {
        const orig = label.textContent;
        label.textContent = 'Copied!';
        setTimeout(() => { label.textContent = orig; }, 2000);
      }
      const feedback = btn.querySelector<HTMLElement>('.blog-post__share-feedback');
      if (feedback) {
        feedback.textContent = 'Link copied';
        setTimeout(() => { feedback.textContent = ''; }, 2000);
      }
    } else if (type && shareUrls[type]) {
      window.open(shareUrls[type], '_blank', 'noopener,noreferrer,width=600,height=400');
      closeDropdown();
    }
  });
}

document.addEventListener('astro:page-load', initShare);
document.addEventListener('DOMContentLoaded', initShare);
</script>

<style>
  .blog-post {
    background: var(--bg-page);
  }

  /* --- §1 + §2 Header band --- */
  .blog-post__header {
    background: var(--bg-surface);
    border-bottom: var(--border-width-xs) solid var(--border-subtle);
  }

  /* Featured image */
  .blog-post__hero-img {
    max-width: var(--container-max-reading-wide);
    margin: 0 auto;
    border-radius: var(--radius-lg);
    overflow: hidden;
    aspect-ratio: 16 / 9;
  }

  .blog-post__hero-img img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  /* Title */
  .blog-post__title {
    font-family: var(--font-tailor-heading-stack);
    font-size: var(--text-display-size-h1);
    font-weight: var(--heading-weight-h1);
    color: var(--text-heading);
    margin: 0 0 var(--space-global-sm);
    line-height: var(--lh-display);
  }

  /* Meta line */
  .blog-post__meta {
    display: flex;
    justify-content: space-between;
    align-items: center;
    font-family: var(--font-tailor-body-stack);
    font-size: var(--text-card-size-body);
    color: var(--text-body-muted);
  }

  .blog-post__meta-left {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-global-sm);
    align-items: center;
  }

  .blog-post__sep {
    color: var(--text-body-muted);
  }

  .blog-post__audience {
    padding: 0.125rem 0.5rem;
    background: var(--bg-surface-alt);
    border-radius: var(--radius-pill);
    font-weight: var(--font-weight-medium);
  }

  /* Share button + dropdown */
  .blog-post__share-wrap {
    position: relative;
    flex-shrink: 0;
  }

  .blog-post__share {
    background: none;
    border: var(--border-width-xs) solid var(--border-subtle);
    border-radius: var(--radius-pill);
    padding: 0.375rem 0.625rem;
    cursor: pointer;
    color: var(--text-body-muted);
    display: flex;
    align-items: center;
    transition: border-color var(--transition-duration) var(--transition-easing),
                color var(--transition-duration) var(--transition-easing);
  }

  .blog-post__share:hover {
    border-color: var(--brand-accent);
    color: var(--brand-accent-text);
  }

  .share-dropdown {
    position: absolute;
    top: calc(100% + var(--space-global-xs));
    right: 0;
    background: var(--bg-surface);
    border: var(--border-width-xs) solid var(--border-subtle);
    border-radius: var(--radius-md);
    box-shadow: var(--shadow-md);
    padding: var(--space-global-xs) 0;
    min-width: 10rem;
    z-index: 10;
  }

  .share-dropdown__item {
    display: flex;
    align-items: center;
    gap: var(--space-global-sm);
    padding: var(--space-global-xs) var(--space-global-sm);
    font-family: var(--font-tailor-body-stack);
    font-size: var(--text-card-size-body);
    color: var(--text-body);
    text-decoration: none;
    cursor: pointer;
    background: none;
    border: none;
    width: 100%;
    transition: background var(--transition-duration) var(--transition-easing);
  }

  .share-dropdown__item:hover {
    background: var(--bg-surface-alt);
  }

  /* --- §3 Body --- */
  .blog-post__body :global(.prose) {
    font-family: var(--font-tailor-body-stack);
    font-size: var(--text-prose-size-body);
    color: var(--text-body);
    line-height: var(--lh-prose);
  }

  .blog-post__body :global(.prose h2) {
    font-family: var(--font-tailor-heading-stack);
    font-size: var(--text-prose-size-h2);
    font-weight: var(--heading-weight-h2);
    color: var(--brand-accent-text);
    margin-top: var(--space-global-lg);
    margin-bottom: var(--space-global-sm);
  }

  .blog-post__body :global(.prose h3) {
    font-family: var(--font-tailor-heading-stack);
    font-size: var(--text-prose-size-h3);
    font-weight: var(--heading-weight-h3);
    color: var(--brand-accent-text);
    margin-top: var(--space-global-md);
    margin-bottom: var(--space-global-xs);
  }

  .blog-post__body :global(.prose p) {
    margin-bottom: var(--space-global-sm);
  }

  .blog-post__body :global(.prose ul),
  .blog-post__body :global(.prose ol) {
    margin-bottom: var(--space-global-sm);
    padding-left: 1.5rem;
  }

  .blog-post__body :global(.prose li) {
    margin-bottom: 0.25rem;
  }

  .blog-post__body :global(.prose a) {
    color: var(--brand-accent-text);
    text-decoration: underline;
  }

  .blog-post__body :global(.prose blockquote) {
    border-left: 3px solid var(--brand-accent);
    padding-left: var(--space-global-md);
    margin: var(--space-global-md) 0;
    font-style: italic;
    color: var(--text-body-muted);
  }

  /* --- §4 Topic tags --- */
  .blog-post__tags-section {
    border-top: var(--border-width-xs) solid var(--border-subtle);
    padding-top: var(--space-global-lg);
  }

  .blog-post__tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.375rem;
    align-items: center;
  }

  .blog-post__tags-label {
    font-family: var(--font-tailor-body-stack);
    font-size: var(--text-card-size-body);
    font-weight: var(--font-weight-semibold);
    color: var(--text-body-muted);
    margin-right: var(--space-global-xs);
  }

  .blog-post__tag {
    display: inline-block;
    padding: 0.25rem 0.75rem;
    background: var(--bg-tinted);
    border-radius: var(--radius-pill);
    font-family: var(--font-tailor-body-stack);
    font-size: var(--text-card-size-body);
    font-weight: var(--font-weight-medium);
    color: var(--brand-accent-text);
    text-decoration: none;
    transition: background var(--transition-duration) var(--transition-easing);
  }

  .blog-post__tag:hover {
    background: var(--brand-accent-soft);
  }

  .blog-post__tag--secondary {
    background: var(--bg-surface-alt);
    color: var(--text-body-muted);
  }

  .blog-post__tag--secondary:hover {
    color: var(--brand-accent-text);
    background: var(--bg-tinted);
  }

  /* --- §5 Related --- */
  .blog-post__related {
    border-top: var(--border-width-xs) solid var(--border-subtle);
    background: var(--bg-surface-alt);
  }

  .blog-post__section-title {
    font-family: var(--font-tailor-heading-stack);
    font-size: var(--text-prose-size-h2);

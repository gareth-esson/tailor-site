---
/**
 * Service topics strip — §8 of C5 service pages.
 * Renders a grid of topic cards (illustration + category + title) for
 * the topics most relevant to this service. Each service page passes
 * its own curated `featuredSlugs`; we only show those, so the section
 * stays focused rather than dumping all 23 topics.
 *
 * Card markup/style matches the homepage §7 topic carousel so topics
 * read as one component across the site.
 */
import { getLandingPages } from '../lib/content';
import { getTopicIllustrationPath } from '../lib/topic-illustrations';
import type { LandingPage } from '../lib/types';

interface Props {
  /** Curated slugs for this service, in order of relevance. */
  featuredSlugs: string[];
}

const { featuredSlugs } = Astro.props;

const allLandingPages = await getLandingPages();
const totalCount = allLandingPages.length;

// Resolve curated slugs in order, preserving service-author intent.
const bySlug = new Map<string, LandingPage>(allLandingPages.map((lp) => [lp.slug, lp]));
const topics: LandingPage[] = [];
for (const slug of featuredSlugs) {
  const lp = bySlug.get(slug);
  if (lp && !topics.includes(lp)) topics.push(lp);
}

const categoryTokenMap: Record<string, string> = {
  'Relationships': 'relationships',
  'Sex & Sexual Health': 'sexual-health',
  'Puberty & The Body': 'puberty',
  'Identity & Diversity': 'identity',
  'Online Safety & Media': 'online-safety',
  'Safety & Safeguarding': 'safety',
  'Health & Wellbeing': 'wellbeing',
};
---

<section class="service-topics-strip">
  <div class="mx-auto w-full max-w-[var(--container-max-shell)] px-[var(--space-global-gutter)] py-[var(--space-struct-y-base)]">
    <div class="service-topics-strip__header">
      <h2 class="service-topics-strip__label">Related topics</h2>
      <a href="/topics/" class="link-action link-action--card">
        See all {totalCount} topic guides
      </a>
    </div>
    <div class="topic-card-grid">
      {topics.map((lp) => {
        const token = categoryTokenMap[lp.category || ''] || 'relationships';
        const illustration = getTopicIllustrationPath(lp.slug);
        return (
          <a href={`/topics/${lp.slug}`} class="service-topic-card" style={`--cat-color: var(--cat-${token})`}>
            <div class="service-topic-card__illus">
              {illustration && <img src={illustration} alt="" loading="lazy" />}
            </div>
            <span class="service-topic-card__category">{lp.category}</span>
            <span class="service-topic-card__title">{lp.title}</span>
          </a>
        );
      })}
    </div>
  </div>
</section>

<style>
  .service-topics-strip {
    background: var(--bg-page);
  }

  .service-topics-strip__header {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: var(--space-global-sm);
    flex-wrap: wrap;
    margin-bottom: var(--space-global-lg);
  }

  .service-topics-strip__label {
    font-family: var(--font-tailor-heading-stack);
    font-size: var(--text-display-size-h3);
    font-weight: var(--heading-weight-h2);
    color: var(--text-heading);
    margin: 0;
  }

  /* Grid and card rules live in tailor-site-v2.css as the global
     .topic-card-grid and .service-topic-card classes so the pattern
     can be reused across service/topic/landing pages. */
</style>

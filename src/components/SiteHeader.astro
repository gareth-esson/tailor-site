---
/**
 * Site header [A1] with navigation [A3].
 * Persistent on every page. Always uses Lexend (shell layer).
 * Contains: skip link, logo, primary nav, search, mobile hamburger.
 * "Topics" nav item triggers mega menu [D8].
 * "RSE Delivery" nav item triggers a compact dropdown (D8-lite).
 *
 * Layout via Tailwind utilities; all visual values resolve to tokens
 * from tailor-site-v2.css. Shell never inherits .layer-ota typography —
 * it sits outside <main> and inherits from <body>.
 */
import TopicsMegaMenu from './TopicsMegaMenu.astro';
import SearchBar from './SearchBar.astro';

const rseDeliveryLinks = [
  { title: 'RSE for Primary Schools', href: '/services/rse-for-primary-schools' },
  { title: 'RSE for Secondary Schools', href: '/services/rse-for-secondary-schools' },
  { title: 'RSE for SEND & AP (Circuits)', href: '/services/rse-for-send-and-ap' },
  { title: 'RSE for Special Schools', href: '/services/rse-for-special-schools' },
  { title: 'Drop Days', href: '/services/drop-days' },
];

const rseTrainingLinks = [
  { title: 'RSE Training', href: '/services/rse-training' },
  { title: 'RSE Policy & Curriculum Planning', href: '/services/rse-policy-curriculum-planning' },
];

// Active-page detection for aria-current. Strip trailing slash so /blog and /blog/ both match.
const pathname = Astro.url.pathname.replace(/\/$/, '') || '/';
const startsWith = (prefix: string) => pathname === prefix || pathname.startsWith(prefix + '/');

const isTopics = startsWith('/topics');
const isQuestions = startsWith('/questions') || startsWith('/anonymous_question');
const isRseDelivery = rseDeliveryLinks.some((l) => startsWith(l.href));
const isRseTraining = rseTrainingLinks.some((l) => startsWith(l.href));
const isBlog = startsWith('/blog');
const isAbout = pathname === '/about';
const isContact = pathname === '/contact';
---

<header
  class="site-header sticky top-0 w-full h-[var(--header-height)] px-[var(--space-global-gutter)] z-[var(--z-header)]"
  id="site-header"
>
  <!-- Skip link: visible only on focus -->
  <a href="#main" class="skip-to-content">Skip to main content</a>

  <div class="site-header__inner mx-auto flex h-full w-full items-center max-w-[var(--container-max-shell)] gap-[var(--space-global-md)]">
    <!-- Slot 1: Brand -->
    <a href="/" class="site-header__brand flex items-center shrink-0" aria-label="Tailor Education — home">
      <img src="/assets/tailor-logo-lockup-dark.svg" alt="Tailor Education" class="site-header__logo" width="180" height="36" />
    </a>

    <!-- Slot 2: Primary navigation (desktop only) -->
    <nav class="site-header__nav hidden lg:flex lg:ml-auto" aria-label="Main navigation">
      <ul class="site-header__nav-list flex items-center gap-[var(--space-global-xs)] m-0 p-0 list-none" role="list">
        <li class="site-header__nav-item site-header__nav-item--has-mega relative">
          <button
            class="site-header__nav-link site-header__mega-trigger"
            aria-expanded="false"
            aria-controls="mega-menu"
            aria-current={isTopics ? 'page' : undefined}
            type="button"
          >
            Topics
            <svg class="site-header__chevron" width="12" height="12" viewBox="0 0 12 12" aria-hidden="true">
              <path d="M3 4.5L6 7.5L9 4.5" stroke="currentColor" stroke-width="1.5" fill="none" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </button>
          <TopicsMegaMenu />
        </li>
        <li class="site-header__nav-item">
          <a href="/questions/" class="site-header__nav-link" aria-current={isQuestions ? 'page' : undefined}>Okay to Ask</a>
        </li>
        <li class="site-header__nav-item site-header__nav-item--has-dropdown relative">
          <button
            class="site-header__nav-link site-header__dropdown-trigger"
            aria-expanded="false"
            aria-controls="rse-delivery-menu"
            aria-current={isRseDelivery ? 'page' : undefined}
            type="button"
          >
            RSE Delivery
            <svg class="site-header__chevron" width="12" height="12" viewBox="0 0 12 12" aria-hidden="true">
              <path d="M3 4.5L6 7.5L9 4.5" stroke="currentColor" stroke-width="1.5" fill="none" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </button>
          <div
            id="rse-delivery-menu"
            class="site-header__dropdown absolute top-full left-0 mt-1 min-w-[16rem] py-2 z-[var(--z-mega)]"
            aria-hidden="true"
          >
            <ul role="list" class="list-none p-0 m-0">
              {rseDeliveryLinks.map((link) => (
                <li>
                  <a href={link.href} class="site-header__dropdown-link block">{link.title}</a>
                </li>
              ))}
            </ul>
          </div>
        </li>
        <li class="site-header__nav-item site-header__nav-item--has-dropdown relative">
          <button
            class="site-header__nav-link site-header__dropdown-trigger"
            aria-expanded="false"
            aria-controls="rse-training-menu"
            aria-current={isRseTraining ? 'page' : undefined}
            type="button"
          >
            RSE Training &amp; Support
            <svg class="site-header__chevron" width="12" height="12" viewBox="0 0 12 12" aria-hidden="true">
              <path d="M3 4.5L6 7.5L9 4.5" stroke="currentColor" stroke-width="1.5" fill="none" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </button>
          <div
            id="rse-training-menu"
            class="site-header__dropdown absolute top-full left-0 mt-1 min-w-[16rem] py-2 z-[var(--z-mega)]"
            aria-hidden="true"
          >
            <ul role="list" class="list-none p-0 m-0">
              {rseTrainingLinks.map((link) => (
                <li>
                  <a href={link.href} class="site-header__dropdown-link block">{link.title}</a>
                </li>
              ))}
            </ul>
          </div>
        </li>
        <li class="site-header__nav-item">
          <a href="/blog/" class="site-header__nav-link" aria-current={isBlog ? 'page' : undefined}>Blog</a>
        </li>
        <li class="site-header__nav-item">
          <a href="/about" class="site-header__nav-link" aria-current={isAbout ? 'page' : undefined}>About</a>
        </li>
        <li class="site-header__nav-item">
          <a href="/contact" class="site-header__nav-link" aria-current={isContact ? 'page' : undefined}>Contact</a>
        </li>
      </ul>
    </nav>

    <!-- Slot 3: Utility cluster — search + hamburger -->
    <div class="site-header__utility flex items-center gap-[var(--space-global-sm)] shrink-0 ml-auto lg:ml-0">
      <SearchBar />

      <button
        class="site-header__hamburger flex lg:hidden flex-col items-center justify-center gap-1 w-11 h-11 p-2 bg-transparent border-0 cursor-pointer"
        type="button"
        aria-expanded="false"
        aria-controls="mobile-nav"
        aria-label="Open menu"
      >
        <span class="site-header__hamburger-line block w-5 h-[2px] rounded-[1px]"></span>
        <span class="site-header__hamburger-line block w-5 h-[2px] rounded-[1px]"></span>
        <span class="site-header__hamburger-line block w-5 h-[2px] rounded-[1px]"></span>
      </button>
    </div>
  </div>

  <!-- Mobile navigation [D3] -->
  <div
    id="mobile-nav"
    class="mobile-nav lg:hidden"
    aria-hidden="true"
    inert
  >
    <!-- Sticky topbar: Menu label + close button -->
    <div class="mobile-nav__topbar">
      <span class="mobile-nav__topbar-label">Menu</span>
      <button
        class="mobile-nav__close"
        type="button"
        aria-label="Close menu"
        data-dismiss="mobile-nav"
      >
        <svg class="mobile-nav__close-icon" width="20" height="20" viewBox="0 0 20 20" fill="none" aria-hidden="true">
          <path d="M5 5L15 15M15 5L5 15" stroke="currentColor" stroke-width="1.75" stroke-linecap="round"/>
        </svg>
      </button>
    </div>

    <nav class="mobile-nav__body" aria-label="Mobile navigation">
      <ul class="mobile-nav__list list-none p-0 m-0" role="list">
        <li class="mobile-nav__item">
          <button
            class="mobile-nav__link mobile-nav__accordion-trigger"
            aria-expanded="false"
            aria-controls="mobile-topics-panel"
            aria-current={isTopics ? 'page' : undefined}
            type="button"
          >
            <span>Topics</span>
            <svg class="mobile-nav__chevron" width="12" height="12" viewBox="0 0 12 12" aria-hidden="true">
              <path d="M3 4.5L6 7.5L9 4.5" stroke="currentColor" stroke-width="1.5" fill="none" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </button>
          <div id="mobile-topics-panel" class="mobile-nav__mega" aria-hidden="true">
            <TopicsMegaMenu mobile />
          </div>
        </li>
        <li class="mobile-nav__item">
          <a href="/questions/" class="mobile-nav__link" aria-current={isQuestions ? 'page' : undefined}>
            <span>Okay to Ask</span>
          </a>
        </li>
        <li class="mobile-nav__item">
          <button
            class="mobile-nav__link mobile-nav__accordion-trigger"
            aria-expanded="false"
            aria-controls="mobile-rse-panel"
            aria-current={isRseDelivery ? 'page' : undefined}
            type="button"
          >
            <span>RSE Delivery</span>
            <svg class="mobile-nav__chevron" width="12" height="12" viewBox="0 0 12 12" aria-hidden="true">
              <path d="M3 4.5L6 7.5L9 4.5" stroke="currentColor" stroke-width="1.5" fill="none" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </button>
          <div id="mobile-rse-panel" class="mobile-nav__accordion-panel" aria-hidden="true">
            <ul class="mobile-nav__sub-list list-none p-0 m-0" role="list">
              {rseDeliveryLinks.map((link) => (
                <li>
                  <a href={link.href} class="mobile-nav__sub-link" aria-current={pathname === link.href.replace(/\/$/, '') ? 'page' : undefined}>
                    {link.title}
                  </a>
                </li>
              ))}
            </ul>
          </div>
        </li>
        <li class="mobile-nav__item">
          <button
            class="mobile-nav__link mobile-nav__accordion-trigger"
            aria-expanded="false"
            aria-controls="mobile-rse-training-panel"
            aria-current={isRseTraining ? 'page' : undefined}
            type="button"
          >
            <span>RSE Training &amp; Support</span>
            <svg class="mobile-nav__chevron" width="12" height="12" viewBox="0 0 12 12" aria-hidden="true">
              <path d="M3 4.5L6 7.5L9 4.5" stroke="currentColor" stroke-width="1.5" fill="none" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </button>
          <div id="mobile-rse-training-panel" class="mobile-nav__accordion-panel" aria-hidden="true">
            <ul class="mobile-nav__sub-list list-none p-0 m-0" role="list">
              {rseTrainingLinks.map((link) => (
                <li>
                  <a href={link.href} class="mobile-nav__sub-link" aria-current={pathname === link.href.replace(/\/$/, '') ? 'page' : undefined}>
                    {link.title}
                  </a>
                </li>
              ))}
            </ul>
          </div>
        </li>
        <li class="mobile-nav__item">
          <a href="/blog/" class="mobile-nav__link" aria-current={isBlog ? 'page' : undefined}>
            <span>Blog</span>
          </a>
        </li>
        <li class="mobile-nav__item">
          <a href="/about" class="mobile-nav__link" aria-current={isAbout ? 'page' : undefined}>
            <span>About</span>
          </a>
        </li>
        <li class="mobile-nav__item">
          <a href="/contact" class="mobile-nav__link" aria-current={isContact ? 'page' : undefined}>
            <span>Contact</span>
          </a>
        </li>
      </ul>
    </nav>
  </div>
</header>

<!-- Scrim sits outside <header> so it can cover the viewport beneath the
     header without being inside the sticky positioning context. -->
<div class="mobile-nav-scrim lg:hidden" aria-hidden="true" data-dismiss="mobile-nav"></div>

<script>
  function initHeader() {
    const header = document.getElementById('site-header');
    if (!header) return;

    // --- Desktop mega menu + dropdown (shared toggle pattern) ---
    const flyoutTriggers = header.querySelectorAll<HTMLButtonElement>(
      '.site-header__mega-trigger, .site-header__dropdown-trigger'
    );

    flyoutTriggers.forEach((trigger) => {
      const panelId = trigger.getAttribute('aria-controls');
      const panel = panelId ? document.getElementById(panelId) : null;
      if (!panel) return;

      trigger.addEventListener('click', (e) => {
        e.stopPropagation();
        const expanded = trigger.getAttribute('aria-expanded') === 'true';
        // Close sibling flyouts
        flyoutTriggers.forEach((other) => {
          if (other !== trigger) {
            other.setAttribute('aria-expanded', 'false');
            const otherId = other.getAttribute('aria-controls');
            const otherPanel = otherId ? document.getElementById(otherId) : null;
            if (otherPanel) otherPanel.setAttribute('aria-hidden', 'true');
          }
        });
        trigger.setAttribute('aria-expanded', String(!expanded));
        panel.setAttribute('aria-hidden', String(expanded));
      });
    });

    // Close flyouts on outside click
    document.addEventListener('click', (e) => {
      if (!header.contains(e.target as Node)) {
        flyoutTriggers.forEach((trigger) => {
          trigger.setAttribute('aria-expanded', 'false');
          const panelId = trigger.getAttribute('aria-controls');
          const panel = panelId ? document.getElementById(panelId) : null;
          if (panel) panel.setAttribute('aria-hidden', 'true');
        });
      }
    });

    // Close flyouts on Escape
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape') {
        flyoutTriggers.forEach((trigger) => {
          if (trigger.getAttribute('aria-expanded') === 'true') {
            trigger.setAttribute('aria-expanded', 'false');
            const panelId = trigger.getAttribute('aria-controls');
            const panel = panelId ? document.getElementById(panelId) : null;
            if (panel) panel.setAttribute('aria-hidden', 'true');
            trigger.focus();
          }
        });
      }
    });

    // --- Mobile navigation open/close (shared by hamburger, close button,
    // scrim tap, Escape key). Extracted so all four close paths share one
    // state toggle.
    const hamburger = header.querySelector('.site-header__hamburger') as HTMLButtonElement | null;
    const mobileNav = document.getElementById('mobile-nav');

    // Make the rest of the page inert while the drawer is open so Tab
    // can't escape the drawer on mobile. Query inside the handlers (not
    // at script load) so SSR/after-swap rehydration picks up fresh
    // references each time.
    function setOutsideInert(inert: boolean) {
      const outside = document.querySelectorAll<HTMLElement>('main, footer');
      outside.forEach((el) => {
        if (inert) el.setAttribute('inert', '');
        else el.removeAttribute('inert');
      });
    }

    function openMobileNav() {
      if (!hamburger || !mobileNav) return;
      hamburger.setAttribute('aria-expanded', 'true');
      hamburger.setAttribute('aria-label', 'Close menu');
      hamburger.classList.add('is-open');
      mobileNav.setAttribute('aria-hidden', 'false');
      mobileNav.removeAttribute('inert');
      document.body.classList.add('nav-open');
      setOutsideInert(true);
      // Move focus to the close button — first focusable element in the drawer.
      const closeBtn = mobileNav.querySelector<HTMLButtonElement>('.mobile-nav__close');
      if (closeBtn) closeBtn.focus();
    }

    function closeMobileNav() {
      if (!hamburger || !mobileNav) return;
      hamburger.setAttribute('aria-expanded', 'false');
      hamburger.setAttribute('aria-label', 'Open menu');
      hamburger.classList.remove('is-open');
      mobileNav.setAttribute('aria-hidden', 'true');
      mobileNav.setAttribute('inert', '');
      document.body.classList.remove('nav-open');
      setOutsideInert(false);
      hamburger.focus();
    }

    function toggleMobileNav() {
      if (!hamburger) return;
      const expanded = hamburger.getAttribute('aria-expanded') === 'true';
      if (expanded) closeMobileNav();
      else openMobileNav();
    }

    if (hamburger && mobileNav) {
      hamburger.addEventListener('click', toggleMobileNav);
    }

    // Scrim taps + close button — any element with [data-dismiss="mobile-nav"].
    document.querySelectorAll('[data-dismiss="mobile-nav"]').forEach((el) => {
      el.addEventListener('click', closeMobileNav);
    });

    // Escape closes the mobile nav (separately handled from the desktop
    // flyout Escape handler above, which only targets .site-header__ triggers).
    document.addEventListener('keydown', (e) => {
      if (e.key !== 'Escape') return;
      if (mobileNav && mobileNav.getAttribute('aria-hidden') === 'false') {
        closeMobileNav();
      }
    });

    // --- Mobile accordion triggers (top-level: Topics, RSE Delivery, RSE Training).
    // Multi-open: opening one does not close the others.
    const topLevelAccordions = header.querySelectorAll(
      '.mobile-nav > .mobile-nav__body .mobile-nav__item > .mobile-nav__accordion-trigger'
    );
    topLevelAccordions.forEach((trigger) => {
      trigger.addEventListener('click', () => {
        const expanded = trigger.getAttribute('aria-expanded') === 'true';
        trigger.setAttribute('aria-expanded', String(!expanded));
        const panelId = trigger.getAttribute('aria-controls');
        const panel = panelId ? document.getElementById(panelId) : null;
        if (panel) panel.setAttribute('aria-hidden', String(expanded));
      });
    });

    // --- Topics mega-menu category triggers (nested inside the Topics panel).
    // One-at-a-time: tapping a new category collapses the previously-open one.
    const catTriggers = header.querySelectorAll<HTMLButtonElement>(
      '#mobile-topics-panel .mobile-nav__cat-trigger'
    );
    catTriggers.forEach((trigger) => {
      trigger.addEventListener('click', () => {
        const expanded = trigger.getAttribute('aria-expanded') === 'true';
        // Collapse siblings first.
        catTriggers.forEach((other) => {
          if (other === trigger) return;
          other.setAttribute('aria-expanded', 'false');
          const otherId = other.getAttribute('aria-controls');
          const otherPanel = otherId ? document.getElementById(otherId) : null;
          if (otherPanel) otherPanel.setAttribute('aria-hidden', 'true');
        });
        trigger.setAttribute('aria-expanded', String(!expanded));
        const panelId = trigger.getAttribute('aria-controls');
        const panel = panelId ? document.getElementById(panelId) : null;
        if (panel) panel.setAttribute('aria-hidden', String(expanded));
      });
    });

    // --- Auto-expand ancestors of the current page on mount, so a user who
    // opens the drawer on /topics/consent sees Topics open AND Relationships
    // (the category containing Consent) open.
    const currentSubLink = mobileNav?.querySelector<HTMLAnchorElement>(
      '.mobile-nav__sub-link[aria-current="page"]'
    );
    if (currentSubLink) {
      const innerPanel = currentSubLink.closest<HTMLElement>(
        '.mobile-nav__cat-panel, .mobile-nav__accordion-panel'
      );
      if (innerPanel) {
        innerPanel.setAttribute('aria-hidden', 'false');
        const innerTrigger = document.querySelector<HTMLButtonElement>(
          `[aria-controls="${innerPanel.id}"]`
        );
        if (innerTrigger) innerTrigger.setAttribute('aria-expanded', 'true');
      }
      // If the inner panel is a topics category, also expand the Topics parent.
      const outerMega = currentSubLink.closest<HTMLElement>('.mobile-nav__mega');
      if (outerMega) {
        outerMega.setAttribute('aria-hidden', 'false');
        const outerTrigger = document.querySelector<HTMLButtonElement>(
          `[aria-controls="${outerMega.id}"]`
        );
        if (outerTrigger) outerTrigger.setAttribute('aria-expanded', 'true');
      }
    }
  }

  initHeader();
  document.addEventListener('astro:after-swap', initHeader);
</script>

<style>
  /* ========================================
     Site Header [A1]
     Layout is Tailwind; visual values are tokens.
     This style block handles state-dependent
     selectors (hover, aria-expanded, focus) and
     the handful of properties that are cleanest
     expressed as CSS.
     ======================================== */
  .site-header {
    background: var(--bg-page);
    border-bottom: var(--border-width-xs) solid var(--border-subtle);
    font-family: var(--font-shell-body-stack);
  }

  .site-header__logo {
    height: 2rem;
    width: auto;
  }

  .site-header__brand:focus-visible {
    outline: var(--focus-ring-width) solid var(--focus-ring);
    outline-offset: var(--focus-ring-offset);
    border-radius: var(--radius-sm);
  }

  /* Skip link styles live globally in tailor-site-v2.css as .skip-to-content;
     focus outline is the global :focus-visible rule. */

  /* --- Nav link (desktop) --- */
  .site-header__nav-link {
    display: inline-flex;
    align-items: center;
    gap: 0.25rem;
    padding: 0.5rem 0.75rem;
    white-space: nowrap;
    font-family: var(--font-shell-body-stack);
    font-size: var(--text-card-size-body);
    font-weight: var(--font-weight-medium);
    color: var(--text-body);
    text-decoration: none;
    border: none;
    background: none;
    cursor: pointer;
    border-radius: var(--radius-sm);
    transition: background var(--transition-duration) var(--transition-easing),
                color var(--transition-duration) var(--transition-easing);
  }

  .site-header__nav-link:hover,
  .site-header__nav-link[aria-expanded="true"] {
    background: var(--bg-surface-alt);
    color: var(--brand-accent-text);
  }

  .site-header__nav-link:focus-visible {
    outline: var(--focus-ring-width) solid var(--focus-ring);
    outline-offset: var(--focus-ring-offset);
  }

  .site-header__chevron {
    transition: transform var(--transition-duration) var(--transition-easing);
  }

  .site-header__nav-link[aria-expanded="true"] .site-header__chevron {
    transform: rotate(180deg);
  }

  /* --- RSE Delivery dropdown (D8-lite) --- */
  .site-header__dropdown {
    display: none;
    background: var(--bg-page);
    border: var(--border-width-xs) solid var(--border-subtle);
    border-radius: var(--radius-md);
    box-shadow: var(--shadow-md);
  }

  .site-header__dropdown[aria-hidden="false"] {
    display: block;
  }

  .site-header__dropdown-link {
    padding: 0.5rem 1rem;
    font-family: var(--font-shell-body-stack);
    font-size: var(--text-nav-size);
    font-weight: var(--font-weight-regular);
    color: var(--text-body);
    text-decoration: none;
    transition: background var(--transition-duration) var(--transition-easing),
                color var(--transition-duration) var(--transition-easing);
  }

  .site-header__dropdown-link:hover {
    background: var(--bg-surface-alt);
    color: var(--brand-accent-text);
  }

  .site-header__dropdown-link:focus-visible {
    outline: var(--focus-ring-width) solid var(--focus-ring);
    outline-offset: calc(var(--focus-ring-offset) * -1);
  }

  /* --- Hamburger --- */
  .site-header__hamburger {
    border-radius: var(--radius-sm);
    transition: background var(--transition-duration) var(--transition-easing);
  }

  .site-header__hamburger:hover {
    background: var(--bg-surface-alt);
  }

  .site-header__hamburger:focus-visible {
    outline: var(--focus-ring-width) solid var(--focus-ring);
    outline-offset: var(--focus-ring-offset);
  }

  .site-header__hamburger-line {
    background: var(--text-body);
    transition: transform var(--transition-duration) var(--transition-easing),
                opacity var(--transition-duration) var(--transition-easing);
  }

  .site-header__hamburger.is-open .site-header__hamburger-line:nth-child(1) {
    transform: translateY(6px) rotate(45deg);
  }
  .site-header__hamburger.is-open .site-header__hamburger-line:nth-child(2) {
    opacity: 0;
  }
  .site-header__hamburger.is-open .site-header__hamburger-line:nth-child(3) {
    transform: translateY(-6px) rotate(-45deg);
  }

  /* ========================================
     Mobile Navigation [D3]
     Panel structure:
       .mobile-nav
         .mobile-nav__topbar   (sticky; "Menu" label + X close)
         .mobile-nav__body     (scrollable; nav list)
     Three close paths: X button, scrim tap, Escape.
     ======================================== */

  /* Panel: drops out from beneath the sticky header.
     Uses visibility + opacity + transform so open AND close animate;

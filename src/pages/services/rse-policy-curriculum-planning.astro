---
/**
 * Service page [C5] — /services/rse-policy-curriculum-planning
 * RSE policy and curriculum planning consultancy. Tailor layer, v3.
 * Consultancy-shaped — deliverable-focused rather than session-focused.
 */
import BaseLayout from '../../layouts/BaseLayout.astro';
import CtaServiceEnquiry from '../../components/CtaServiceEnquiry.astro';
import ServiceTopicsStrip from '../../components/ServiceTopicsStrip.astro';
import { getBlogPosts } from '../../lib/content';

// --- Data ----------------------------------------------------------
const slug = 'rse-policy-curriculum-planning';
const title = 'RSE policy and curriculum planning';
const serviceParam = 'RSE policy and curriculum planning';
const serviceName = 'RSE policy and curriculum planning';

const heroSubtitle =
  'Bespoke consultancy to develop your RSE policy, plan your curriculum, and communicate your approach to parents. Written deliverables, inspection-ready, built with you over two to four weeks.';

const heroImage: string | null = '/images/services/tailor-education-teachers-planning-rse-curriculum.webp';
const heroImageAlt = 'Teachers and a Tailor consultant planning an RSE curriculum around a table';

const descriptionLead =
  'Writing a RSE policy from scratch, or rewriting one that no longer reflects the DfE 2026 guidance, is the kind of work PSHE leads rarely have time for alongside teaching. It also requires a degree of confidence about what good looks like — particularly in the sections that parents or inspectors will scrutinise.';

const descriptionBody = [
  'We work with your PSHE lead, SLT, and governors to build a policy and curriculum map that reflects your school\'s context, meets the DfE 2026 statutory requirements, and reads confidently for the audiences that matter: parents, inspectors, and your own staff.',
  'The engagement runs over two to four weeks. We start with a scoping call, then work through a structured process — reviewing current provision, drafting policy language, mapping curriculum coverage to statutory requirements, and finalising parent-facing communication. You end with a written policy, a curriculum map, and a parent information document, all of which are yours to use and adapt.',
];

const whatSchoolsGet =
  'A written RSE policy aligned to DfE 2026 statutory guidance. A curriculum map showing which topics are covered in which year groups and how each maps to statutory requirements. A parent-facing information document explaining your approach. And a PSHE lead who has been through the process alongside a specialist — so they can defend and evolve the policy afterwards.';

const featureCards = [
  { title: 'Scoping and audit call', description: 'Initial consultation to understand your current provision, governance context, and where the gaps are.' },
  { title: 'Policy drafting', description: 'A written RSE policy that meets DfE 2026 statutory requirements and reflects your school\'s specific context and ethos.' },
  { title: 'Curriculum mapping', description: 'Topic-by-topic map of what is covered in which year groups, aligned to statutory requirements and PSHE Association framework.' },
  { title: 'Parent-facing information document', description: 'A clearly written document explaining your RSE approach to parents — proactive, reassuring, inspection-ready.' },
  { title: 'Governor and SLT briefing notes', description: 'Summary notes for governors and SLT so the policy can be adopted confidently at the next meeting.' },
  { title: 'Inspection-ready documentation', description: 'All deliverables structured so they can be referenced directly in an Ofsted inspection without rewriting.' },
  { title: 'Follow-up review', description: 'Post-engagement review call to answer questions, handle any pushback, and lock in the final version.' },
];

const processSteps = [
  { number: 1, title: 'Scoping call', description: 'We start with a 60-minute call with your PSHE lead and SLT to understand current provision, context, and priorities.' },
  { number: 2, title: 'Drafting', description: 'We draft your policy, curriculum map, and parent document. You review; we iterate.' },
  { number: 3, title: 'Finalise and adopt', description: 'Final versions delivered ready for SLT and governor adoption, with a follow-up call to handle anything that comes up afterwards.' },
];

const testimonialQuote =
  'We went from a policy held together with sellotape to something I could genuinely defend to parents and inspectors. The structured process meant we actually finished it — instead of it drifting for another term.';
const testimonialSource = 'PSHE Lead, primary school';

const featuredTopicSlugs = [
  'consent',
  'lgbtq-inclusion',
  'sex-and-the-law',
  'fgm-and-harmful-practices',
  'abuse-exploitation-and-violence',
  'mental-health-and-wellbeing',
];

// --- Content --------------------------------------------------------
const allPosts = await getBlogPosts();
const relatedPosts = allPosts.filter((p) => p.serviceLink === 'rse-policy-curriculum-planning').slice(0, 3);

const metaTitle = `${title} — RSE for Schools | Tailor Education`;
const metaDescription = 'Bespoke consultancy to develop your RSE policy, plan your curriculum, and communicate your approach to parents. DfE 2026-aligned and inspection-ready.';
---

<BaseLayout
  title={metaTitle}
  description={metaDescription}
  canonicalPath={`/services/${slug}/`}
  ogImage={heroImage ?? undefined}
  jsonLd={{
    '@context': 'https://schema.org',
    '@type': 'Service',
    name: title,
    description: metaDescription,
    provider: { '@type': 'Organization', name: 'Tailor Education', url: 'https://tailoreducation.org.uk' },
  }}
>
  <article class="service-page" data-pagefind-body>

    <header class="service-hero">
      <div class="service-hero__inner">
        <div class="service-hero__text">
            <span class="service-hero__eyebrow">Services</span>
            <h1 class="service-hero__title">{title}</h1>
            <p class="service-hero__subtitle">{heroSubtitle}</p>
            <a
              href={`/contact?service=${encodeURIComponent(serviceParam)}`}
              class="btn btn--std btn--primary has-icon-hover"
              data-analytics-event="cta_click"
              data-analytics-cta-type="hero_enquire"
              data-analytics-service-type={serviceParam}
            >Enquire now</a>
          </div>
          <div class="service-hero__image">
            {heroImage ? (
              <img src={heroImage} alt={heroImageAlt} loading="eager" />
            ) : (
              <div class="service-hero__image-placeholder">Hero photography required — source before launch</div>
            )}
          </div>
        </div>
    </header>

    <section class="service-description">
      <div class="mx-auto w-full max-w-[var(--container-max-prose)] px-[var(--space-global-gutter)] py-[var(--space-struct-y-base)]">
        <p class="service-description__lead">{descriptionLead}</p>
        {descriptionBody.map((para) => (<p>{para}</p>))}
        {whatSchoolsGet && (
          <>
            <h2 class="service-description__sub-title">What schools get</h2>
            <p>{whatSchoolsGet}</p>
          </>
        )}
      </div>
    </section>

    <section class="service-features">
      <div class="mx-auto w-full max-w-[var(--container-max-shell)] px-[var(--space-global-gutter)] py-[var(--space-struct-y-base)]">
        <h2 class="service-section-title">What's included</h2>
        <div class="service-features__grid">
          {featureCards.map((card) => (
            <div class="feature-card">
              <h3 class="feature-card__title">{card.title}</h3>
              <p class="feature-card__text">{card.description}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    {processSteps && (
      <section class="service-process">
        <div class="mx-auto w-full max-w-[var(--container-max-shell)] px-[var(--space-global-gutter)] py-[var(--space-struct-y-base)]">
          <h2 class="service-section-title">How it works</h2>
          <div class="service-process__grid">
            {processSteps.map((step) => (
              <div class="process-step">
                <div class="process-step__number">{step.number}</div>
                <h3 class="process-step__title">{step.title}</h3>
                <p class="process-step__text">{step.description}</p>
              </div>
            ))}
          </div>
        </div>
      </section>
    )}

    <section class="service-proof-band">
      <div class="mx-auto w-full max-w-[var(--container-max-prose)] px-[var(--space-global-gutter)] py-[var(--space-struct-y-base)]">
        <div class="service-proof-band__inner">
          {testimonialQuote && (
            <>
              <blockquote>
                <p class="service-proof-band__quote">"{testimonialQuote}"</p>
              </blockquote>
              <span class="service-proof-band__source">— {testimonialSource}</span>
            </>
          )}
          <div class="service-proof-band__cta-wrap">
            <a
              href={`/contact?service=${encodeURIComponent(serviceParam)}`}
              class="btn btn--std btn--white-primary has-icon-hover"
              data-analytics-event="cta_click"
              data-analytics-cta-type="proof_band_enquire"
              data-analytics-service-type={serviceParam}
            >Enquire about {serviceName}</a>
            <a href="/testimonials" class="link-action link-action--muted link-action--card">Read more testimonials</a>
          </div>
        </div>
      </div>
    </section>

    {relatedPosts.length > 0 && (
      <section class="service-blog">
        <div class="mx-auto w-full max-w-[var(--container-max-shell)] px-[var(--space-global-gutter)] py-[var(--space-struct-y-base)]">
          <h2 class="service-section-title">Related articles</h2>
          <div class="service-blog__grid">
            {relatedPosts.map((bp) => (
              <a href={`/blog/${bp.slug}`} class="card card--lift service-blog-card">
                {bp.featuredImage && (
                  <div class="service-blog-card__img">
                    <img src={bp.featuredImage} alt="" loading="lazy" />
                  </div>
                )}
                <div class="card__body">
                  {bp.targetAudience && <div class="card__eyebrow">{bp.targetAudience}</div>}
                  <h3 class="card__title">{bp.title}</h3>
                  {bp.author && <div class="service-blog-card__author">By {bp.author}</div>}
                </div>
              </a>
            ))}
          </div>
        </div>
      </section>
    )}

    <ServiceTopicsStrip featuredSlugs={featuredTopicSlugs} />

    <CtaServiceEnquiry serviceName={serviceName} serviceParam={serviceParam} variant="alt" />

  </article>
</BaseLayout>

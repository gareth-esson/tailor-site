---
/**
 * Services hub [B5] — /services
 * Card per service line linking to individual pages. Tailor layer.
 */
import BaseLayout from '../../layouts/BaseLayout.astro';

const services = [
  {
    title: 'RSE for Primary Schools',
    description: 'Age-appropriate RSE for KS1 and KS2, delivered by a specialist educator who understands primary school settings.',
    href: '/services/rse-for-primary-schools',
  },
  {
    title: 'RSE for Secondary Schools',
    description: 'Expert-led RSE for KS3 and KS4 — covering the topics students are actually thinking about, delivered with confidence.',
    href: '/services/rse-for-secondary-schools',
  },
  {
    title: 'RSE for SEND & AP (Circuits)',
    description: 'Workbook-based RSE designed for SEND and alternative provision. Self-paced, simplified keynotes, doodle and game space.',
    href: '/services/rse-for-send-and-ap',
  },
  {
    title: 'Drop Days',
    description: 'A full day of RSE delivery across multiple year groups — maximum impact, minimum disruption.',
    href: '/services/drop-days',
  },
  {
    title: 'RSE Training',
    description: 'CPD-accredited training that gives your staff the confidence and skills to deliver RSE effectively.',
    href: '/services/rse-training',
  },
  {
    title: 'RSE Policy & Curriculum Planning',
    description: 'Expert guidance to develop your RSE policy, plan your curriculum, and communicate your approach to parents.',
    href: '/services/rse-policy-curriculum-planning',
  },
];
---

<BaseLayout
  title="RSE Services for Schools — Tailor Education"
  description="Expert RSE delivery, training, drop days and curriculum planning for schools. Explore Tailor Education's full range of services."
  canonicalPath="/services/"
  jsonLd={{
    '@context': 'https://schema.org',
    '@type': 'Service',
    name: 'RSE Services for Schools',
    description: 'Expert RSE delivery, training, drop days and curriculum planning for schools.',
    provider: { '@type': 'Organization', name: 'Tailor Education', url: 'https://tailoreducation.org.uk' },
  }}
>
  <section class="services-hub">
    <div class="mx-auto max-w-4xl px-[var(--space-global-gutter)] py-[var(--space-global-xl)]">
      <div class="services-hub__header">
        <div class="services-hub__header-text">
          <h1 class="services-hub__title">RSE services for schools</h1>
          <p class="services-hub__intro">
            Whether you need someone to deliver RSE directly, training for your staff, or support with policy and curriculum — we can help.
          </p>
        </div>
        <div class="services-hub__header-photo">
          <img
            src="/images/services/tailor-education-rse-consultant-school-corridor.webp"
            alt="A Tailor consultant arriving at a school to deliver RSE support"
            loading="eager"
          />
        </div>
      </div>

      <div class="services-hub__grid">
        {services.map((s) => (
          <a href={s.href} class="card services-hub__card">
            <div class="card__body">
              <div class="card__title">{s.title}</div>
              <p class="card__text">{s.description}</p>
              <span class="link-action">Learn more</span>
            </div>
          </a>
        ))}
      </div>

      <!-- Trust signal -->
      <div class="services-hub__trust">
        <p class="services-hub__trust-text">
          All services are aligned to DfE statutory guidance, the PSHE Association framework, and international best practice.
        </p>
      </div>

      <!-- CTA -->
      <div class="services-hub__cta">
        <p class="services-hub__cta-text">Not sure what you need?</p>
        <a href="/contact" class="btn btn--std btn--primary has-icon-hover">Get in touch</a>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .services-hub {
    background: var(--bg-page);
  }

  .services-hub__header {
    display: grid;
    gap: var(--space-global-lg);
    align-items: center;
    margin-bottom: var(--space-global-xl);
  }

  .services-hub__header-photo img {
    width: 100%;
    height: auto;
    border-radius: var(--radius-lg);
    display: block;
    aspect-ratio: 16 / 10;
    object-fit: cover;
  }

  @media (min-width: 768px) {
    .services-hub__header {
      grid-template-columns: 1.1fr 1fr;
      gap: var(--space-global-xl);
    }
  }

  .services-hub__title {
    font-family: var(--font-tailor-heading-stack);
    font-size: var(--text-display-size-h1);
    font-weight: var(--heading-weight-h1);
    color: var(--text-heading);
    margin: 0 0 var(--space-global-sm);
  }

  .services-hub__intro {
    font-family: var(--font-tailor-body-stack);
    font-size: var(--text-prose-size-body);
    color: var(--text-body-muted);
    max-width: 36rem;
    margin: 0;
    line-height: 1.6;
  }

  .services-hub__grid {
    display: grid;
    gap: var(--space-global-md);
    margin-bottom: var(--space-global-xl);
  }

  .services-hub__card {
    text-decoration: none;
    color: inherit;
  }

  .services-hub__card .card__text {
    font-size: var(--text-card-size-body);
    color: var(--text-body-muted);
    margin: var(--space-global-xs) 0 var(--space-global-sm);
    line-height: 1.6;
  }

  .services-hub__trust {
    padding: var(--space-global-md);
    background: var(--bg-tinted);
    border-radius: var(--radius-lg);
    margin-bottom: var(--space-global-xl);
  }

  .services-hub__trust-text {
    font-family: var(--font-tailor-body-stack);
    font-size: var(--text-prose-size-body);
    color: var(--text-body);
    text-align: center;
    margin: 0;
    line-height: 1.6;
  }

  .services-hub__cta {
    text-align: center;
    padding: var(--space-global-xl) 0;
  }

  .services-hub__cta-text {
    font-family: var(--font-tailor-body-stack);
    font-size: var(--text-prose-size-body);
    color: var(--text-body-muted);
    margin: 0 0 var(--space-global-md);
  }

  @media (min-width: 768px) {
    .services-hub__grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }
</style>

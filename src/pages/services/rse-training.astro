---
/**
 * Service page [C5] — /services/rse-training
 * RSE training for school staff. Tailor layer, v3.
 * Highest-traffic service page. Richest content.
 * Replaces the old standalone /rse-training (B4) page.
 */
import BaseLayout from '../../layouts/BaseLayout.astro';
import CtaServiceEnquiry from '../../components/CtaServiceEnquiry.astro';
import ServiceTopicsStrip from '../../components/ServiceTopicsStrip.astro';
import ServicePageStyles from '../../components/ServicePageStyles.astro';
import { getBlogPosts, getTestimonials } from '../../lib/content';

// --- Data ----------------------------------------------------------
const slug = 'rse-training';
const title = 'RSE training';
const serviceParam = 'RSE training';
const serviceName = 'RSE training';

const heroSubtitle =
  'CPD-accredited training that gives your staff the confidence, knowledge, and practical toolkit to deliver RSE well. Half-day, full-day, or bespoke programmes — in person or remote — led by a specialist who has delivered it in hundreds of schools.';

const heroImage: string | null = '/images/services/tailor-education-rse-cpd-workshop-facilitator.webp';
const heroImageAlt = 'A Tailor facilitator leading a CPD workshop for school staff on RSE delivery';

const descriptionLead =
  'The biggest barrier to good RSE in most schools isn\'t policy or curriculum — it\'s teacher confidence. Staff are asked to deliver topics they were never trained in, sometimes with a few hours\' notice, often with no clear framework for what to say when a student asks the question they were dreading.';

// H2 shown above the description body on the C5 page.
// Placeholder — Gareth: review/replace per service if this isn't the right framing.
const descriptionHeading = 'What is RSE training?';

const descriptionBody = [
  'Our training is built around that reality. Rather than walking staff through a generic RSE overview, we focus on the specific moments teachers find hardest: managing disclosures, handling unexpected questions, pitching content age-appropriately, navigating parent concerns, and building the personal confidence to hold the room.',
  'Every session is led by a specialist who has delivered RSE directly to students in hundreds of schools. That matters. The training isn\'t theoretical — it\'s shaped by what actually happens in the classroom, and what actually works.',
  'We offer half-day, full-day, and multi-session programmes, delivered in person at your school or remotely. All programmes are CPD-accredited and aligned to DfE statutory guidance, KCSIE, and the PSHE Association framework.',
];

const whatSchoolsGet =
  'Staff who feel genuinely prepared, not just compliant. A shared vocabulary and framework that the whole RSE team is working from. Concrete scripts for the hardest moments — disclosures, off-topic questions, parent conversations. And a written resource pack staff can return to after the training.';

const featureCards = [
  { title: 'Confidence-building framework', description: 'A concrete toolkit for the moments teachers dread — not generic theory. Built from years of classroom delivery.' },
  { title: 'Managing disclosures', description: 'How to respond when a student discloses. What to say in the moment. What to do afterwards. Fully KCSIE-aligned.' },
  { title: 'Handling difficult questions', description: 'The questions students ask that staff most fear. Practical scripts and a framework for any question you haven\'t heard yet.' },
  { title: 'Age-appropriate pitching', description: 'Matching content to year groups — what to include, what to hold back, how to read a room that isn\'t ready.' },
  { title: 'Parent and community communication', description: 'How to communicate your RSE approach to parents, answer their concerns, and pre-empt objections with confidence.' },
  { title: 'CPD certification and resource pack', description: 'All attendees receive CPD accreditation and a written resource pack to reference after the training.' },
];

const _testimonials = await getTestimonials();
const _match = _testimonials.find((t) => t.serviceTags.includes('RSE training')) || null;
const testimonialQuote: string | null = _match?.quote || null;
const testimonialSource: string | null = _match
  ? [_match.role || _match.name, _match.organisation].filter(Boolean).join(', ')
  : null;

const featuredTopicSlugs = [
  'consent',
  'masculinity-and-misogyny',
  'pornography-and-media-literacy',
  'lgbtq-inclusion',
  'abuse-exploitation-and-violence',
  'sexting-and-sharing-nudes',
];

// --- Content --------------------------------------------------------
const allPosts = await getBlogPosts();
const relatedPosts = allPosts.filter((p) => p.serviceLink === 'training').slice(0, 3);

const metaTitle = `${title} for school staff — RSE for Schools | Tailor Education`;
const metaDescription = 'CPD-accredited RSE training for school staff, led by specialist educators. Half-day, full-day, or bespoke programmes — in person or remote.';
---

<BaseLayout
  title={metaTitle}
  description={metaDescription}
  canonicalPath={`/services/${slug}/`}
  ogImage={heroImage ?? undefined}
  jsonLd={{
    '@context': 'https://schema.org',
    '@type': 'Service',
    name: title,
    description: metaDescription,
    provider: { '@type': 'Organization', name: 'Tailor Education', url: 'https://tailoreducation.org.uk' },
  }}
>
  <article class="service-page" data-pagefind-body>

    <header class="service-hero">
      <div class="service-hero__wrap">
        <div class="service-hero__inner">
          <div class="service-hero__text">
            <span class="service-hero__eyebrow">Services</span>
            <h1 class="service-hero__title">{title}</h1>
            <p class="service-hero__subtitle">{heroSubtitle}</p>
            <a
              href={`/contact?service=${encodeURIComponent(serviceParam)}`}
              class="btn btn--std btn--primary has-icon-hover"
              data-analytics-event="cta_click"
              data-analytics-cta-type="hero_enquire"
              data-analytics-service-type={serviceParam}
            >Enquire now</a>
          </div>
          <div class="service-hero__image">
            {heroImage ? (
              <img src={heroImage} alt={heroImageAlt} loading="eager" />
            ) : (
              <div class="service-hero__image-placeholder">Hero photography required — source before launch</div>
            )}
          </div>
        </div>
      </div>
    </header>

    <section class="service-description">
      <div class="service-description__inner py-[var(--space-struct-y-base)]">
        <div class="service-description__col">
          <h2 class="service-description__heading">{descriptionHeading}</h2>
          <p class="service-description__lead">{descriptionLead}</p>
          {descriptionBody.map((para) => (<p>{para}</p>))}
          {whatSchoolsGet && (
            <>
              <h2 class="service-description__sub-title">What schools get</h2>
              <p>{whatSchoolsGet}</p>
            </>
          )}
        </div>
      </div>
    </section>

    <section class="service-features">
      <div class="mx-auto w-full max-w-[var(--container-max-shell)] px-[var(--space-global-gutter)] py-[var(--space-struct-y-base)]">
        <h2 class="service-section-title">What's included</h2>
        <div class="service-features__grid">
          {featureCards.map((card) => (
            <div class="feature-card">
              <h3 class="feature-card__title">{card.title}</h3>
              <p class="feature-card__text">{card.description}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <section class="service-proof-band">
      <div class="mx-auto w-full max-w-[var(--container-max-prose)] px-[var(--space-global-gutter)] py-[var(--space-struct-y-base)]">
        <div class="service-proof-band__inner">
          {testimonialQuote && (
            <>
              <blockquote>
                <p class="service-proof-band__quote">"{testimonialQuote}"</p>
              </blockquote>
              <span class="service-proof-band__source">— {testimonialSource}</span>
            </>
          )}
          <div class="service-proof-band__cta-wrap">
            <a
              href={`/contact?service=${encodeURIComponent(serviceParam)}`}
              class="btn btn--std btn--white-primary has-icon-hover"
              data-analytics-event="cta_click"
              data-analytics-cta-type="proof_band_enquire"
              data-analytics-service-type={serviceParam}
            >Enquire about {serviceName}</a>
            <a href="/testimonials" class="service-proof-band__testimonials-link">Read more testimonials →</a>
          </div>
        </div>
      </div>
    </section>

    <ServiceTopicsStrip featuredSlugs={featuredTopicSlugs} />

    {relatedPosts.length > 0 && (
      <section class="service-blog">
        <div class="mx-auto w-full max-w-[var(--container-max-shell)] px-[var(--space-global-gutter)] py-[var(--space-struct-y-base)]">
          <h2 class="service-section-title">Related articles</h2>
          <div class="service-blog__grid">
            {relatedPosts.map((bp) => (
              <a href={`/blog/${bp.slug}`} class="card service-blog-card">
                {bp.featuredImage && (
                  <div class="service-blog-card__img">
                    <img src={bp.featuredImage} alt="" loading="lazy" />
                  </div>
                )}
                <div class="card__body">
                  {bp.targetAudience && <div class="card__eyebrow">{bp.targetAudience}</div>}
                  <h3 class="card__title">{bp.title}</h3>
                  {bp.author && <div class="service-blog-card__author">By {bp.author}</div>}
                </div>
              </a>
            ))}
          </div>
        </div>
      </section>
    )}

    <CtaServiceEnquiry serviceName={serviceName} serviceParam={serviceParam} variant="alt" />

  </article>
  <ServicePageStyles />
</BaseLayout>

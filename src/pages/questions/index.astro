---
/**
 * Okay to Ask landing page [B8] — /questions/
 * The front door for young people. Uses OtA layer.
 * Browse all questions with client-side category filtering.
 * 7 OtA categories: Anatomy, Puberty, Relationships, Sex, Sexual Health, Sex & the Law, Contraception & Pregnancy.
 */
import BaseLayout from '../../layouts/BaseLayout.astro';
import GlossaryTooltips from '../../components/GlossaryTooltips.astro';
import { getQuestions } from '../../lib/content';

const allQuestions = await getQuestions();

// Only published questions with answers
const questions = allQuestions
  .filter((q) => q.body.length > 0)
  .sort((a, b) => a.question.localeCompare(b.question));

// The 7 OtA browsing categories
const otaCategories = [
  { name: 'Anatomy', token: 'anatomy' },
  { name: 'Puberty', token: 'puberty' },
  { name: 'Relationships', token: 'relationships' },
  { name: 'Sex', token: 'sex' },
  { name: 'Sexual Health', token: 'sexual-health' },
  { name: 'Sex & the Law', token: 'law' },
  { name: 'Contraception & Pregnancy', token: 'contraception' },
];

// Map OtA category to badge class
function otaBadgeClass(cat: string | null): string {
  const map: Record<string, string> = {
    'Anatomy': 'badge--ota-anatomy',
    'Puberty': 'badge--ota-puberty',
    'Relationships': 'badge--ota-relationships',
    'Sex': 'badge--ota-sex',
    'Sexual Health': 'badge--ota-sexual-health',
    'Sex & the Law': 'badge--ota-law',
    'Contraception & Pregnancy': 'badge--ota-contraception',
  };
  return map[cat || ''] || '';
}
---

<BaseLayout title="Questions — Okay to Ask" layer="ota">
  <div class="ota-landing">
    <!-- 1. Hero -->
    <section class="ota-hero surface--ota">
      <div class="mx-auto max-w-4xl px-[var(--space-global-gutter)] py-[var(--space-global-2xl)]">
        <img src="/assets/ota-wordmark-dark.svg" alt="Okay to Ask" class="ota-hero__wordmark" width="280" height="48" />
        <h1 class="ota-hero__title">Real questions from real young people. Answered honestly.</h1>
        <p class="ota-hero__subtitle">
          Every question here was written anonymously by a young person. No judgement, no awkwardness — just honest answers.
        </p>
      </div>
    </section>

    <!-- 2. Book promotion -->
    <section class="ota-book surface--ota-alt">
      <div class="mx-auto max-w-4xl px-[var(--space-global-gutter)] py-[var(--space-global-lg)]">
        <div class="ota-book__card">
          <div class="ota-book__content">
            <h2 class="ota-book__title">The Okay to Ask book</h2>
            <p class="ota-book__text">
              Real questions, honest answers, post-it notes and all. The physical book for your home, school, or staff room.
            </p>
            <a href="/book" class="btn btn--std btn--primary has-icon-hover">Get the book</a>
          </div>
          <div class="ota-book__image">
            <!-- Book cover placeholder -->
            <div class="ota-book__placeholder" aria-hidden="true">
              <span>Book cover</span>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- 3. Browse by category + 4. Question list -->
    <section class="ota-questions surface--ota" id="questions-section">
      <div class="mx-auto max-w-4xl px-[var(--space-global-gutter)] py-[var(--space-global-lg)]">
        <h2 class="ota-questions__heading">Browse questions</h2>

        <!-- Category filter buttons -->
        <div class="ota-filters" role="group" aria-label="Filter by category">
          <button
            class="ota-filter btn btn--sm btn--tint is-active"
            data-category="all"
            type="button"
          >
            All
          </button>
          {otaCategories.map((cat) => (
            <button
              class={`ota-filter badge badge--pill ${`badge--ota-${cat.token}`}`}
              data-category={cat.name}
              type="button"
            >
              {cat.name}
            </button>
          ))}
        </div>

        <!-- Question list -->
        <ul class="ota-question-list" role="list" id="question-list">
          {questions.map((q) => (
            <li class="ota-question-list__item" data-category={q.okayToAskCategory || ''}>
              <a href={`/anonymous_question/${q.slug}`} class="ota-question-list__link">
                {q.question}
              </a>
              {q.okayToAskCategory && (
                <span class={`badge badge--pill ${otaBadgeClass(q.okayToAskCategory)}`}>
                  {q.okayToAskCategory}
                </span>
              )}
            </li>
          ))}
        </ul>

        <p class="ota-question-count" id="question-count" aria-live="polite">
          {questions.length} questions
        </p>
      </div>
    </section>

    <!-- 5. What is Okay to Ask? -->
    <section class="ota-about surface--ota-alt">
      <div class="mx-auto max-w-4xl px-[var(--space-global-gutter)] py-[var(--space-global-lg)]">
        <h2 class="ota-about__title">What is Okay to Ask?</h2>
        <p class="ota-about__text">
          Okay to Ask started with anonymous question boxes in schools. Young people wrote down whatever they wanted to know about relationships, sex, their bodies, and growing up. No names, no judgement. We collected those questions and answered every single one honestly.
        </p>
        <p class="ota-about__text">
          This is a Tailor Education project. The same team that delivers RSE in schools wrote every answer on this site.
        </p>
      </div>
    </section>

    <!-- 6. General signposting -->
    <section class="ota-signpost surface--ota">
      <div class="mx-auto max-w-4xl px-[var(--space-global-gutter)] py-[var(--space-global-lg)]">
        <div class="alert alert--support">
          <div class="alert__content">
            <div class="alert__title">Need to talk to someone?</div>
            <div class="alert__body">
              <p>
                <strong>Childline</strong> — free, confidential support for young people.
                Call <a href="tel:08001111">0800 1111</a> or visit
                <a href="https://www.childline.org.uk" target="_blank" rel="noopener noreferrer">childline.org.uk</a>
              </p>
              <p>
                <strong>Brook</strong> — sexual health and wellbeing for under 25s.
                Visit <a href="https://www.brook.org.uk" target="_blank" rel="noopener noreferrer">brook.org.uk</a>
              </p>
              <p>
                <strong>The Mix</strong> — support for under 25s on any issue.
                Call <a href="tel:08088084994">0808 808 4994</a> or visit
                <a href="https://www.themix.org.uk" target="_blank" rel="noopener noreferrer">themix.org.uk</a>
              </p>
            </div>
          </div>
        </div>
      </div>
    </section>
  </div>

  <GlossaryTooltips />
</BaseLayout>

<script>
  function initFilters() {
    const filters = document.querySelectorAll('.ota-filter');
    const questionList = document.getElementById('question-list');
    const countEl = document.getElementById('question-count');
    if (!questionList || !countEl) return;

    const items = questionList.querySelectorAll('.ota-question-list__item');

    filters.forEach((btn) => {
      btn.addEventListener('click', () => {
        const category = (btn as HTMLElement).dataset.category;

        // Update active state
        filters.forEach((f) => f.classList.remove('is-active'));
        btn.classList.add('is-active');

        // Filter items
        let visible = 0;
        items.forEach((item) => {
          const itemCat = (item as HTMLElement).dataset.category;
          const show = category === 'all' || itemCat === category;
          (item as HTMLElement).style.display = show ? '' : 'none';
          if (show) visible++;
        });

        // Update count
        countEl.textContent = `${visible} question${visible !== 1 ? 's' : ''}`;
      });
    });
  }

  initFilters();
  document.addEventListener('astro:after-swap', initFilters);
</script>

<style>
  /* ========================================
     Okay to Ask landing [B8]
     ======================================== */
  .ota-landing {
    background: var(--bg-ota-surface);
  }

  /* --- Hero --- */
  .ota-hero {
    text-align: center;
  }

  .ota-hero__wordmark {
    height: 3rem;
    width: auto;
    margin-bottom: var(--space-global-md);
  }

  .ota-hero__title {
    font-size: var(--text-display-size-h1);
    color: var(--text-ota-heading);
    margin: 0 0 var(--space-global-sm);
    line-height: 1.15;
  }

  .ota-hero__subtitle {
    font-size: var(--text-prose-size-body);
    color: var(--text-ota-muted);
    max-width: 32rem;
    margin: 0 auto;
    line-height: 1.6;
  }

  /* --- Book promotion --- */
  .ota-book__card {
    display: grid;
    gap: var(--space-global-md);
    padding: var(--space-global-lg);
    background: var(--bg-surface);
    border-radius: var(--radius-lg);
    border: var(--border-width-xs) solid var(--border-subtle);
  }

  .ota-book__title {
    font-size: var(--text-prose-size-h2);
    color: var(--text-ota-heading);
    margin: 0 0 var(--space-global-xs);
  }

  .ota-book__text {
    font-size: var(--text-prose-size-body);
    color: var(--text-ota-body);
    margin: 0 0 var(--space-global-md);
    line-height: 1.6;
  }

  .ota-book__placeholder {
    width: 100%;
    aspect-ratio: 3/4;
    max-width: 12rem;
    background: var(--surface-ota-postit-soft);
    border: 2px dashed var(--surface-ota-postit);
    border-radius: var(--radius-sm);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: var(--text-card-size-body);
    color: var(--text-body-muted);
  }

  /* --- Questions section --- */
  .ota-questions__heading {
    font-size: var(--text-prose-size-h2);
    color: var(--text-ota-heading);
    margin: 0 0 var(--space-global-md);
  }

  .ota-filters {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin-bottom: var(--space-global-md);
  }

  .ota-filter {
    cursor: pointer;
    transition: opacity var(--transition-duration) var(--transition-easing);
  }

  .ota-filter:not(.is-active) {
    opacity: 0.6;
  }

  .ota-filter.is-active {
    opacity: 1;
    outline: 2px solid var(--brand-accent);
    outline-offset: 2px;
  }

  .ota-question-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 0.375rem;
  }

  .ota-question-list__item {
    display: flex;
    align-items: baseline;
    gap: var(--space-global-xs);
    padding: 0.75rem 1rem;
    background: var(--bg-surface);
    border: var(--border-width-xs) solid var(--border-subtle);
    border-radius: var(--radius-sm);
    transition: border-color var(--transition-duration) var(--transition-easing);
  }

  .ota-question-list__item:hover {
    border-color: var(--brand-accent);
  }

  .ota-question-list__link {
    flex: 1;
    font-size: var(--text-prose-size-body);
    color: var(--link-ota-contextual);
    text-decoration: none;
    font-weight: 500;
  }

  .ota-question-list__link:hover {
    text-decoration: underline;
  }

  .ota-question-count {
    font-size: var(--text-card-size-body);
    color: var(--text-ota-muted);
    margin-top: var(--space-global-sm);
  }

  /* --- About --- */
  .ota-about__title {
    font-size: var(--text-prose-size-h2);
    color: var(--text-ota-heading);
    margin: 0 0 var(--space-global-sm);
  }

  .ota-about__text {
    font-size: var(--text-prose-size-body);
    color: var(--text-ota-body);
    line-height: 1.7;
    max-width: 40rem;
    margin: 0 0 var(--space-global-sm);
  }

  .ota-about__text:last-child {
    margin-bottom: 0;
  }

  /* --- Responsive --- */
  @media (min-width: 768px) {
    .ota-book__card {
      grid-template-columns: 1fr auto;
      align-items: center;
    }
  }
</style>

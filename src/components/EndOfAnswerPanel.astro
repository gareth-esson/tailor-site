---
/**
 * End-of-answer panel [A17] — C1 question page.
 *
 * A single book CTA panel — mirrors the homepage OtA book promotion.
 * Sits on the page's .surface--ota-alt band; the page template owns the
 * outer section/background. This component owns the panel itself.
 *
 * (Previously a 3-up triptych, then a 2-up book/topic grid; reduced to
 * a single buy-the-book CTA so the end-of-answer moment doesn't read
 * as a conversion block.)
 *
 * Props are accepted but unused — kept for API stability with the page
 * template until the call site is updated.
 *
 * All visual values resolve to tokens in tailor-site-v2.css.
 */
interface Props {
  topicName?: string;
  topicSlug?: string;
}

const _ = Astro.props as Props;
---

<a
  href="/book"
  class="end-book-panel"
  data-analytics-event="end_panel_click"
  data-analytics-panel="book"
>
  <img
    src="/images/ota-book-cover.webp"
    alt="Okay to Ask book cover"
    class="end-book-panel__cover"
    width="240"
    height="360"
    loading="lazy"
  />
  <div class="end-book-panel__text">
    <span class="end-book-panel__eyebrow">The Okay to Ask book</span>
    <h2 class="end-book-panel__title">The book that answers the questions young people really ask</h2>
    <p class="end-book-panel__desc">Real questions, honest answers, post-it notes and all.</p>
    <span class="link-action">Buy the book</span>
  </div>
</a>

<style>
  .end-book-panel {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-global-xl);
    padding: var(--space-global-xl);
    max-width: 48rem;
    margin: 0 auto;
    background: var(--bg-ota-book-panel);
    border-radius: var(--radius-lg);
    box-shadow: var(--shadow-md);
    text-decoration: none;
    color: inherit;
    transition:
      transform var(--transition-duration) var(--transition-easing),
      box-shadow var(--transition-duration) var(--transition-easing);
  }

  .end-book-panel:hover {
    box-shadow: var(--shadow-lg);
    transform: translateY(-2px);
  }

  .end-book-panel:focus-visible {
    outline: var(--focus-ring-width) solid var(--focus-ring);
    outline-offset: var(--focus-ring-offset);
    border-radius: var(--radius-lg);
  }

  .end-book-panel__cover {
    flex-shrink: 0;
    width: 10rem;
    max-width: 10rem;
    height: auto;
    border-radius: var(--radius-sm);
    box-shadow: var(--shadow-sm);
  }

  .end-book-panel__text {
    text-align: center;
    display: flex;
    flex-direction: column;
    gap: var(--space-global-sm);
  }

  .end-book-panel__eyebrow {
    font-family: var(--font-ota-body-stack, inherit);
    font-size: var(--text-util-preheader-size, 0.75rem);
    font-weight: var(--font-weight-bold);
    text-transform: uppercase;
    letter-spacing: var(--card-eyebrow-ls, 0.08em);
    color: var(--text-ota-muted);
  }

  .end-book-panel__title {
    font-family: var(--font-ota-heading-stack, inherit);
    font-size: var(--text-prose-size-h3);
    font-weight: var(--heading-ota-weight-h2, 600);
    color: var(--text-ota-heading);
    line-height: var(--lh-heading);
    margin: 0;
  }

  .end-book-panel__desc {
    font-family: var(--font-ota-body-stack, inherit);
    font-size: var(--text-prose-size-body);
    color: var(--text-ota-body);
    line-height: var(--lh-body);
    margin: 0;
  }

  @media (min-width: 768px) {
    .end-book-panel {
      flex-direction: row;
      align-items: center;
      text-align: left;
    }
    .end-book-panel__text {
      text-align: left;
    }
    .end-book-panel__cover {
      width: 12rem;
      max-width: 12rem;
    }
  }
</style>

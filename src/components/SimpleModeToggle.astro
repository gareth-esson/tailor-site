---
/**
 * Simple Mode toggle [A6] — toggle switch variant.
 * A single switch with "Simple version" label.
 * Reads from localStorage, updates visibility of data-mode elements.
 */
---

<label class="simple-toggle" for="simple-mode-switch">
  <span class="simple-toggle__label">Simplify</span>
  <span class="simple-toggle__track">
    <input
      type="checkbox"
      id="simple-mode-switch"
      class="simple-toggle__input"
      role="switch"
      aria-checked="false"
    />
    <span class="simple-toggle__thumb" aria-hidden="true"></span>
  </span>
</label>

<script>
  function initToggle() {
    const input = document.getElementById('simple-mode-switch') as HTMLInputElement;
    if (!input) return;

    const isSimple = localStorage.getItem('simple_mode') === 'true';

    function setMode(simple: boolean) {
      input.checked = simple;
      input.setAttribute('aria-checked', simple ? 'true' : 'false');
      if (simple) {
        document.documentElement.classList.add('simple-active');
      } else {
        document.documentElement.classList.remove('simple-active');
      }
      localStorage.setItem('simple_mode', simple ? 'true' : 'false');
    }

    // Set initial state from localStorage
    setMode(isSimple);

    input.addEventListener('change', () => setMode(input.checked));
  }

  // Run on initial load and on Astro page transitions
  initToggle();
  document.addEventListener('astro:after-swap', initToggle);
</script>

<style>
  .simple-toggle {
    display: inline-flex;
    align-items: center;
    gap: var(--space-global-sm);
    cursor: pointer;
    user-select: none;
  }

  .simple-toggle__label {
    font-family: var(--font-ota-body-stack, inherit);
    font-size: var(--toggle-mode-font-size);
    font-weight: var(--toggle-mode-font-weight);
    color: var(--text-ota-body);
    line-height: 1;
  }

  .simple-toggle__track {
    position: relative;
    display: inline-flex;
    align-items: center;
    width: 2.75rem;
    height: 1.5rem;
    background: var(--toggle-mode-bg);
    border-radius: var(--toggle-mode-radius);
    transition: background var(--toggle-mode-transition);
    flex-shrink: 0;
  }

  .simple-toggle__input {
    position: absolute;
    width: 100%;
    height: 100%;
    margin: 0;
    padding: 0;
    opacity: 0;
    cursor: pointer;
  }

  .simple-toggle__thumb {
    position: absolute;
    left: var(--toggle-mode-gap);
    width: 1.25rem;
    height: 1.25rem;
    background: var(--bg-surface);
    border-radius: var(--radius-circle);
    box-shadow: var(--shadow-sm);
    transition: transform var(--toggle-mode-transition);
    pointer-events: none;
  }

  .simple-toggle__input:checked ~ .simple-toggle__thumb {
    transform: translateX(1.25rem);
  }

  .simple-toggle__input:checked + .simple-toggle__thumb {
    transform: translateX(1.25rem);
  }

  .simple-toggle__track:has(.simple-toggle__input:checked) {
    background: var(--toggle-mode-bg-active);
  }

  .simple-toggle__input:focus-visible ~ .simple-toggle__thumb {
    outline: var(--focus-ring-width) solid var(--focus-ring);
    outline-offset: var(--focus-ring-offset);
  }
</style>

---
/**
 * Service page [C5] — /services/rse-for-primary-schools
 * RSE delivery for primary schools. Tailor layer.
 */
import BaseLayout from '../../layouts/BaseLayout.astro';
import CtaServiceEnquiry from '../../components/CtaServiceEnquiry.astro';
import TopicsOverviewGrid from '../../components/TopicsOverviewGrid.astro';
import ServicePageStyles from '../../components/ServicePageStyles.astro';
import { getBlogPosts } from '../../lib/content';

const allPosts = await getBlogPosts();
const relatedPosts = allPosts.filter((p) => p.serviceLink === 'delivery').slice(0, 3);
---

<BaseLayout
  title="RSE for Primary Schools — RSE for Schools | Tailor Education"
  description="Age-appropriate RSE for KS1 and KS2, delivered by a specialist educator who understands primary school settings."
  canonicalPath="/services/rse-for-primary-schools/"
  jsonLd={{
    '@context': 'https://schema.org',
    '@type': 'Service',
    name: 'RSE for Primary Schools',
    description: 'Age-appropriate RSE for KS1 and KS2, delivered by a specialist educator.',
    provider: { '@type': 'Organization', name: 'Tailor Education', url: 'https://tailoreducation.org.uk' },
  }}
>
  <article class="service-page" data-pagefind-body>

    <!-- §1 Hero -->
    <header class="service-page__header">
      <div class="mx-auto w-full max-w-[var(--container-max-shell)] px-[var(--space-global-gutter)] py-[var(--space-global-xl)]">
        <span class="service-page__eyebrow">Services · RSE Delivery</span>
        <h1 class="service-page__title">RSE for primary schools</h1>
        <p class="service-page__subtitle">
          Expert-led RSE tailored for KS1 and KS2, delivered by a specialist educator who understands primary school settings.
        </p>
      </div>
    </header>

    <!-- §2 Service detail -->
    <section class="service-page__detail">
      <div class="mx-auto w-full max-w-[var(--container-max-prose)] px-[var(--space-global-gutter)] py-[var(--space-struct-y-base)]">

        <!-- [IMAGE PLACEHOLDER: Primary school RSE session — educator with young children in a bright classroom] -->
        <div class="service-page__image-placeholder" style="margin-bottom: var(--space-global-lg)">
          Image — RSE session in a primary school classroom (educator with KS1/KS2 age children)
        </div>

        <div class="service-page__detail-stack">

          <div class="service-page__detail-block">
            <h2 class="service-page__section-title">What this service is</h2>
            <p>A specialist RSE educator delivers age-appropriate lessons directly to your primary school students. Sessions are designed around the realities of teaching young children about relationships, bodies, boundaries, and staying safe — using language and activities that feel natural for the age group.</p>
            <p>We cover the topics that primary staff often find hardest to approach: puberty, consent in age-appropriate terms, healthy friendships, and online safety for younger children.</p>
          </div>

          <div class="service-page__detail-block">
            <h2 class="service-page__section-title">Who it's for</h2>
            <p>Primary schools who want specialist support for RSE delivery. Particularly valued by schools where staff feel uncertain about teaching puberty or relationships topics, where parents need reassurance about what's being taught, or where an external specialist voice helps normalise conversations that children need to have.</p>
          </div>

          <div class="service-page__detail-block">
            <h2 class="service-page__section-title">What's included</h2>
            <ul>
              <li>Pre-visit consultation with your PSHE lead or headteacher</li>
              <li>Lessons designed for KS1 and KS2 developmental stages</li>
              <li>Age-appropriate language and activities throughout</li>
              <li>Topics aligned to the DfE statutory RSE and health education guidance</li>
              <li>Post-session summary for staff, including talking points for follow-up</li>
              <li>Parent-facing information available on request</li>
            </ul>
          </div>

          <div class="service-page__detail-block">
            <h2 class="service-page__section-title">What schools get</h2>
            <p>Students who can name body parts accurately, understand what makes a healthy friendship, recognise the difference between appropriate and inappropriate touch, and know how to ask for help. Staff who feel more confident continuing RSE conversations after the session. And parents who can see that the school takes this seriously and handles it well.</p>
          </div>

        </div>
      </div>
    </section>

    <!-- §4 CTA [A13] — primary -->
    <CtaServiceEnquiry serviceName="RSE for primary schools" serviceParam="RSE for primary schools" />

    <!-- §5 Testimonial -->
    <section class="service-page__testimonial">
      <div class="mx-auto w-full max-w-[var(--container-max-prose)] px-[var(--space-global-gutter)] py-[var(--space-struct-y-base)]">
        <blockquote class="testimonial-pullquote">
          <p class="testimonial-pullquote__text">"The children were completely engaged. The educator pitched it perfectly for our Year 5s — honest and clear without being overwhelming. Several parents commented on how well their children talked about the session at home."</p>
          <footer class="testimonial-pullquote__footer">
            <span class="testimonial-pullquote__source">— PSHE Lead, primary school</span>
            <a href="/testimonials" class="testimonial-pullquote__link">Read more testimonials</a>
          </footer>
        </blockquote>
      </div>
    </section>

    <!-- §6 Related blog posts -->
    {relatedPosts.length > 0 && (
      <section class="service-page__blog">
        <div class="mx-auto w-full max-w-[var(--container-max-shell)] px-[var(--space-global-gutter)] py-[var(--space-struct-y-base)]">
          <h2 class="service-page__section-title" style="margin-bottom: var(--space-global-md)">Related articles</h2>
          <div class="service-page__blog-grid">
            {relatedPosts.map((bp) => (
              <a href={`/blog/${bp.slug}`} class="card service-blog-card">
                {bp.featuredImage && (
                  <div class="service-blog-card__img">
                    <img src={bp.featuredImage} alt={bp.title} loading="lazy" />
                  </div>
                )}
                <div class="card__body">
                  {bp.targetAudience && <div class="card__eyebrow">{bp.targetAudience}</div>}
                  <div class="card__title">{bp.title}</div>
                  {bp.author && <div class="service-blog-card__author">By {bp.author}</div>}
                </div>
              </a>
            ))}
          </div>
        </div>
      </section>
    )}

    <!-- §7 Topics overview grid -->
    <TopicsOverviewGrid />

    <!-- §8 CTA [A13] — repeated -->
    <CtaServiceEnquiry serviceName="RSE for primary schools" serviceParam="RSE for primary schools" variant="alt" />

  </article>
  <ServicePageStyles />
</BaseLayout>

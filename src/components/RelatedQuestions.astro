---
/**
 * Related questions [A15] — question variant.
 * Shows 3–5 related question cards with links.
 */
import type { QuestionRef } from '../lib/types';

interface Props {
  questions: QuestionRef[];
}

const { questions } = Astro.props;

if (questions.length === 0) return;
---

<section class="mx-auto max-w-3xl px-[var(--space-global-gutter)] py-[var(--space-global-lg)]">
  <h2>Related questions</h2>
  <ul class="grid gap-[var(--space-global-sm)]" style="list-style: none; padding: 0;">
    {questions.map((q) => (
      <li>
        <a
          href={`/anonymous_question/${q.slug}`}
          class="link-action"
          style={`display: block; padding: var(--space-global-sm); background: var(--bg-surface); border-radius: var(--radius-md); border: var(--border-width-xs) solid var(--border-subtle); text-decoration: none;`}
          data-analytics-event="related_question_click"
          data-analytics-target-slug={q.slug}
        >
          {q.question}
        </a>
      </li>
    ))}
  </ul>
</section>

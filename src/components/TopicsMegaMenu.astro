---
/**
 * Topics mega menu [D8].
 * Shows all 23 landing pages grouped by 7 app categories.
 * Desktop: multi-column flyout from "Topics" nav item.
 * Mobile: accordion panel inside D3.
 *
 * Layout via Tailwind utilities; visual values via tokens.
 */

interface Props {
  mobile?: boolean;
}

const { mobile = false } = Astro.props;

const categories = [
  {
    name: 'Relationships',
    token: 'relationships',
    pages: [
      { title: 'Consent', slug: 'consent' },
      { title: 'Healthy relationships', slug: 'healthy-relationships' },
      { title: 'Friendships', slug: 'friendships' },
      { title: 'Families', slug: 'families' },
      { title: 'Sex and intimacy', slug: 'sex-and-intimacy' },
    ],
  },
  {
    name: 'Sex & Sexual Health',
    token: 'sexual-health',
    pages: [
      { title: 'Contraception', slug: 'contraception' },
      { title: 'STIs and sexual health', slug: 'stis-and-sexual-health' },
      { title: 'Pregnancy and reproductive health', slug: 'pregnancy-and-reproductive-health' },
      { title: 'Sex and the law', slug: 'sex-and-the-law' },
    ],
  },
  {
    name: 'Puberty & The Body',
    token: 'puberty',
    pages: [
      { title: 'Puberty', slug: 'puberty' },
      { title: 'Body image', slug: 'body-image' },
      { title: 'Bodies and anatomy', slug: 'bodies-and-anatomy' },
    ],
  },
  {
    name: 'Identity & Diversity',
    token: 'identity',
    pages: [
      { title: 'LGBTQ+ inclusion', slug: 'lgbtq-inclusion' },
      { title: 'Masculinity and misogyny', slug: 'masculinity-and-misogyny' },
      { title: 'Gender stereotypes and discrimination', slug: 'gender-stereotypes-and-discrimination' },
    ],
  },
  {
    name: 'Online Safety & Media',
    token: 'online-safety',
    pages: [
      { title: 'Online safety', slug: 'online-safety' },
      { title: 'Sexting and sharing nudes', slug: 'sexting-and-sharing-nudes' },
      { title: 'Pornography and media literacy', slug: 'pornography-and-media-literacy' },
    ],
  },
  {
    name: 'Safety & Safeguarding',
    token: 'safety',
    pages: [
      { title: 'Abuse, exploitation and violence', slug: 'abuse-exploitation-and-violence' },
      { title: 'FGM and harmful practices', slug: 'fgm-and-harmful-practices' },
      { title: 'Personal safety', slug: 'personal-safety' },
    ],
  },
  {
    name: 'Health & Wellbeing',
    token: 'wellbeing',
    pages: [
      { title: 'Mental health and wellbeing', slug: 'mental-health-and-wellbeing' },
      { title: 'Self-esteem', slug: 'self-esteem' },
    ],
  },
];
---

{mobile ? (
  <div class="mega-mobile">
    {categories.map((cat) => (
      <div class="mega-mobile__group" data-cat-token={cat.token}>
        <button
          class="mega-mobile__cat-trigger mobile-nav__cat-trigger"
          type="button"
          aria-expanded="false"
          aria-controls={`mobile-cat-${cat.token}`}
          style={`--cat-color: var(--cat-${cat.token})`}
        >
          <span class="mega-mobile__cat-label">{cat.name}</span>
          <svg class="mega-mobile__cat-chevron mobile-nav__chevron" width="12" height="12" viewBox="0 0 12 12" aria-hidden="true">
            <path d="M3 4.5L6 7.5L9 4.5" stroke="currentColor" stroke-width="1.5" fill="none" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </button>
        <div
          id={`mobile-cat-${cat.token}`}
          class="mega-mobile__cat-panel mobile-nav__cat-panel"
          aria-hidden="true"
        >
          <ul class="mega-mobile__list list-none p-0 m-0" role="list">
            {cat.pages.map((page) => (
              <li>
                <a href={`/topics/${page.slug}`} class="mega-mobile__link mobile-nav__sub-link">{page.title}</a>
              </li>
            ))}
          </ul>
        </div>
      </div>
    ))}
    <a href="/topics/" class="mega-mobile__view-all">View all topics <span aria-hidden="true">&rarr;</span></a>
  </div>
) : (
  <div
    id="mega-menu"
    class="mega-menu absolute top-full left-0 mt-1 z-[var(--z-mega)] w-[max(70vw,56rem)] max-w-[calc(100vw-2rem)]"
    aria-hidden="true"
    role="region"
    aria-label="Topics menu"
  >
    <div class="mega-menu__inner px-[var(--space-global-lg)] pt-[var(--space-global-lg)] pb-[var(--space-global-md)]">
      <div class="mega-menu__grid grid grid-cols-3 xl:grid-cols-4 gap-y-[var(--space-global-lg)] gap-x-[var(--space-global-md)]">
        {categories.map((cat) => (
          <div class="mega-menu__group min-w-0">
            <div
              class="mega-menu__heading border-b-2 pb-1.5 mb-2"
              style={`--cat-color: var(--cat-${cat.token})`}
            >
              {cat.name}
            </div>
            <ul class="mega-menu__list list-none p-0 m-0 flex flex-col gap-0.5" role="list">
              {cat.pages.map((page) => (
                <li>
                  <a href={`/topics/${page.slug}`} class="mega-menu__link block">{page.title}</a>
                </li>
              ))}
            </ul>
          </div>
        ))}
      </div>
      <div class="mega-menu__footer mt-[var(--space-global-md)] pt-[var(--space-global-sm)] text-center">
        <a href="/topics/" class="mega-menu__view-all">View all topics</a>
      </div>
    </div>
  </div>
)}

<style>
  /* ========================================
     Desktop Mega Menu [D8]
     ======================================== */
  .mega-menu {
    display: none;
    background: var(--bg-page);
    border: var(--border-width-xs) solid var(--border-subtle);
    border-radius: var(--radius-md);
    box-shadow: var(--shadow-lg);
  }

  .mega-menu[aria-hidden="false"] {
    display: block;
  }

  .mega-menu__heading {
    font-family: var(--font-shell-body-stack);
    font-size: var(--text-card-size-body);
    font-weight: var(--font-weight-semibold);
    color: var(--brand-accent-text);
    border-bottom-color: var(--brand-accent-text);
  }

  .mega-menu__link {
    padding: 0.3rem 0.5rem;
    font-family: var(--font-shell-body-stack);
    font-size: var(--text-nav-size-sm);
    font-weight: var(--font-weight-regular);
    color: var(--text-body);
    text-decoration: none;
    border-radius: var(--radius-xs);
    transition: background var(--transition-duration) var(--transition-easing),
                color var(--transition-duration) var(--transition-easing);
  }

  .mega-menu__link:hover {
    background: var(--bg-surface-alt);
    color: var(--brand-accent-text);
  }

  .mega-menu__link:focus-visible {
    outline: var(--focus-ring-width) solid var(--focus-ring);
    outline-offset: var(--focus-ring-offset);
  }

  .mega-menu__footer {
    border-top: var(--border-width-xs) solid var(--border-subtle);
  }

  .mega-menu__view-all {
    font-family: var(--font-shell-body-stack);
    font-size: var(--text-card-size-body);
    font-weight: var(--font-weight-medium);
    color: var(--brand-accent-text);
    text-decoration: none;
  }

  .mega-menu__view-all:hover {
    text-decoration: underline;
  }

  /* ========================================
     Mobile Mega Menu (inside D3)
     Nested accordion: one category open at a time.
     Category trigger + link styles are shared with
     .mobile-nav__cat-trigger / .mobile-nav__sub-link
     in SiteHeader.astro — the mega-mobile__* classes
     only own per-component details (label underline,
     view-all link).
     ======================================== */
  .mega-mobile {
    padding: 0;
  }

  .mega-mobile__group {
    /* No bottom border — category trigger separators live on the trigger itself. */
  }

  .mega-mobile__cat-label {
    display: inline-block;
    padding-bottom: 0.125rem;
    border-bottom: 2px solid var(--cat-color, var(--border-subtle));
    color: var(--cat-color, var(--text-heading));
  }

  .mega-mobile__link {
    /* Typography inherited from .mobile-nav__sub-link. */
  }

  .mega-mobile__view-all {
    display: flex;
    align-items: center;
    min-height: 2.75rem;
    padding: var(--space-global-xs) var(--space-global-sm);
    padding-inline-start: var(--space-global-md);
    font-family: var(--font-shell-body-stack);
    font-size: var(--text-nav-size);
    font-weight: var(--font-weight-medium);
    color: var(--brand-accent-text);
    text-decoration: none;
    gap: var(--space-global-xs);
  }

  .mega-mobile__view-all:hover {
    text-decoration: underline;
  }

  .mega-mobile__view-all:focus-visible {
    outline: var(--focus-ring-width) solid var(--focus-ring);
    outline-offset: calc(var(--focus-ring-offset) * -1);
    border-radius: var(--radius-xs);
  }
</style>

---
/**
 * Glossary term page [C2] — /glossary/{slug}
 * Reference page: dictionary entry feel. Definition is the hero.
 * OtA visual identity. Atkinson body, Fraunces headings.
 */
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getGlossaryTerms, getGlossaryIndex, getLandingPages } from '../../lib/content';
import { renderBlocks } from '../../lib/render-blocks';
import { injectGlossaryTooltips } from '../../lib/glossary-tooltips';
import type { GlossaryTerm, GlossaryIndex } from '../../lib/types';

import SimpleModeToggle from '../../components/SimpleModeToggle.astro';
import GlossaryTooltips from '../../components/GlossaryTooltips.astro';
import GlossaryTermCard from '../../components/GlossaryTermCard.astro';
import SignpostingBlock from '../../components/SignpostingBlock.astro';
import QuestionCard from '../../components/QuestionCard.astro';

export const prerender = true;

export async function getStaticPaths() {
  const terms = await getGlossaryTerms();
  const glossaryIndex = await getGlossaryIndex();
  const landingPages = await getLandingPages();

  return terms.map((t) => {
    // Resolve the term's granular topic to its parent landing page,
    // since /topics/{slug} routes to landing-page slugs only — not
    // granular topic slugs. Falls back to null if no parent matches.
    const landing = t.topic
      ? landingPages.find((lp) => lp.granularTopicIds.includes(t.topic!.id)) || null
      : null;
    const landingTopic = landing
      ? { name: landing.title, slug: landing.slug }
      : null;

    return {
      params: { slug: t.slug },
      props: { term: t, glossaryIndex, landingTopic },
    };
  });
}

interface Props {
  term: GlossaryTerm;
  glossaryIndex: GlossaryIndex;
  landingTopic: { name: string; slug: string } | null;
}

const { term, glossaryIndex, landingTopic } = Astro.props;

// SEO metadata
const metaTitle = term.metaTitle || `What is ${term.term}? | Tailor Education`;
const metaDescription = term.metaDescription || term.shortDefinition || `Learn the meaning of ${term.term} — clear, age-appropriate RSE glossary from Tailor Education.`;
const canonicalPath = `/glossary/${term.slug}/`;

// JSON-LD — DefinedTerm
const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'DefinedTerm',
  name: term.term,
  description: term.shortDefinition,
};

// --- Data preparation ---

// Render standard explainer body with glossary tooltips
const standardBodyHtml = renderBlocks(term.body);
const standardWithTooltips = injectGlossaryTooltips(
  standardBodyHtml,
  glossaryIndex,
  term.slug
);

// Simple explainer — from Notion field, falls back to standard
const simpleExplainerHtml = term.simpleExplainer
  ? `<p>${term.simpleExplainer.replace(/\n\n/g, '</p><p>').replace(/\n/g, '<br>')}</p>`
  : standardBodyHtml;
const simpleWithTooltips = injectGlossaryTooltips(
  simpleExplainerHtml,
  glossaryIndex,
  term.slug
);

// Topic info for CTA — resolved to the parent landing page (what
// /topics/{slug} actually routes to), not the granular topic.
const topicName = landingTopic?.name || '';
const topicSlug = landingTopic?.slug || '';

// Limit referencing questions to 6
const referencedQuestions = term.referencedIn.slice(0, 6);
---

<BaseLayout
  title={metaTitle}
  description={metaDescription}
  canonicalPath={canonicalPath}
  layer="ota"
  jsonLd={jsonLd}
>
  {/* §1–§2 white content panel on .surface--ota ground */}
  <div class="surface--ota w-full" data-pagefind-body>
    <div class="pt-[var(--space-struct-y-hero)] pb-[var(--space-struct-y-base)] px-[var(--space-global-gutter)]">

      {/* Back link — smart: returns to referring question, or falls back to Okay to Ask */}
      <nav class="mx-auto w-full max-w-[var(--container-max-reading-wide)] mb-[var(--space-global-sm)]" aria-label="Back">
        <a
          id="glossary-back-link"
          href="/questions/"
          class="inline-flex items-center gap-[0.35em] text-[var(--text-card-size-body)] text-[var(--text-ota-muted)] hover:text-[var(--brand-accent-text)] transition-colors no-underline"
        >
          <span aria-hidden="true">&larr;</span>
          <span id="glossary-back-label">Okay to Ask</span>
        </a>
      </nav>

      <div class="c2-content-panel mx-auto w-full max-w-[var(--container-max-reading-wide)]">

        {/* §1 — Term heading + definition */}
        <section aria-labelledby="term-heading">
          <div class="mx-auto w-full max-w-[var(--container-max-prose)] pt-[var(--space-global-2xl)] px-[var(--space-global-lg)]">
            <h1
              id="term-heading"
              class="text-center mb-[var(--space-global-lg)]"
              style={`font-size: var(--text-display-size-h1); font-weight: var(--heading-ota-weight-h1); line-height: var(--lh-heading); color: var(--text-ota-heading);`}
            >
              {term.term}
            </h1>

            {/* Definition — standard (italic Fraunces, dictionary style) */}
            <p class="c2-definition" data-mode="standard">{term.shortDefinition}</p>
            {/* Definition — simple */}
            <p class="c2-definition" data-mode="simple">{term.simpleDefinition || term.shortDefinition}</p>

            {/* Decorative divider */}
            <hr class="c2-divider mx-auto mt-[var(--space-global-xl)] mb-0" />
          </div>
        </section>

        {/* §2 — Toggle + explainer */}
        <section aria-labelledby="explainer-heading">
          <div class="mx-auto w-full max-w-[var(--container-max-prose)] px-[var(--space-global-lg)] pb-[var(--space-global-2xl)]">
            {/* Toggle row */}
            <div class="flex items-center justify-end gap-[var(--space-global-md)] mb-[var(--space-global-lg)] pt-[var(--space-global-lg)] pb-[var(--space-global-md)] border-b-[var(--border-width-xs)] border-[var(--border-subtle)]">
              <SimpleModeToggle />
            </div>

            {/* Explainer body */}
            {term.body.length > 0 && (
              <>
                <div data-mode="standard" class="mode-content ota-prose">
                  <Fragment set:html={standardWithTooltips} />
                </div>
                <div data-mode="simple" class="mode-content ota-prose">
                  <Fragment set:html={simpleWithTooltips} />
                </div>
              </>
            )}
          </div>
        </section>

      </div>
    </div>
  </div>

  {/* §3 — Related glossary terms */}
  {term.relatedTerms.length > 0 && (
    <section class="w-full py-[var(--space-struct-y-base)] px-[var(--space-global-gutter)]" aria-labelledby="related-terms-heading">
      <div class="mx-auto w-full max-w-[var(--container-max-reading-wide)]">
        <h2
          id="related-terms-heading"
          class="text-center mb-[var(--space-global-lg)]"
          style={`font-size: var(--text-prose-size-h2); font-weight: var(--heading-ota-weight-h2); color: var(--text-ota-heading);`}
        >
          Related terms
        </h2>
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-[var(--space-global-md)]">
          {term.relatedTerms.map((t) => (
            <GlossaryTermCard term={t} />
          ))}
        </div>
      </div>
    </section>
  )}

  {/* §4 — Questions that reference this term */}
  {referencedQuestions.length > 0 && (
    <section class="w-full py-[var(--space-struct-y-base)] px-[var(--space-global-gutter)]" aria-labelledby="referencing-questions-heading">
      <div class="mx-auto w-full max-w-[var(--container-max-reading-wide)]">
        <h2
          id="referencing-questions-heading"
          class="text-center mb-[var(--space-global-lg)]"
          style={`font-size: var(--text-prose-size-h2); font-weight: var(--heading-ota-weight-h2); color: var(--text-ota-heading);`}
        >
          Questions about this
        </h2>
        <ul class="list-none p-0 m-0 grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-[var(--space-global-md)]" role="list">
          {referencedQuestions.map((q) => (
            <li>
              <QuestionCard question={q} />
            </li>
          ))}
        </ul>
      </div>
    </section>
  )}

  {/* §5 — Signposting (conditional) */}
  {term.topic && (
    <section
      class="w-full pt-[var(--space-global-2xl)] pb-[var(--space-struct-y-base)] px-[var(--space-global-gutter)]"
      style="background-color: var(--safeguarding-support-bg);"
      aria-labelledby="signposting-title"
    >
      <div class="mx-auto w-full max-w-[var(--container-max-reading-wide)]">
        <SignpostingBlock services={['Childline']} />
      </div>
    </section>
  )}

  {/* §6 — CTA */}
  {topicName && topicSlug && (
    <section class="surface--ota-alt w-full py-[var(--space-struct-y-base)] px-[var(--space-global-gutter)]" aria-labelledby="cta-heading">
      <div class="mx-auto w-full max-w-[var(--container-max-reading-wide)] text-center">
        <p class="text-[var(--text-card-size-body)] font-[var(--font-weight-semibold)] uppercase tracking-[0.08em] text-[var(--text-ota-muted)] mb-[var(--space-global-xs)]">For Teachers</p>
        <h2
          id="cta-heading"
          class="mb-[var(--space-global-md)]"
          style={`font-size: var(--text-prose-size-h3); font-weight: var(--heading-ota-weight-h3); color: var(--text-ota-heading);`}
        >
          Explore {topicName}
        </h2>
        <div class="flex justify-center mt-[var(--space-global-md)]">
          <a href={`/topics/${topicSlug}`} class="btn btn--tint btn--std has-icon-hover">
            See everything on {topicName}
          </a>
        </div>
      </div>
    </section>
  )}

  {/* Glossary tooltip runtime */}
  <GlossaryTooltips />
</BaseLayout>

<style>
  /* Simple Mode visibility */
  [data-mode="simple"] {
    display: none;
  }
  :global(.simple-active [data-mode="standard"]) {
    display: none !important;
  }
  :global(.simple-active [data-mode="simple"]) {
    display: block !important;
  }

  /* Teal accent on prose headings within the glossary explainer */
  :global(.ota-prose h2),
  :global(.ota-prose h3) {
    color: var(--brand-accent-text);
  }
</style>

<script>
  // Upgrade the back link if the user arrived from an internal page that
  // embeds glossary tooltips: a question, a topic detail page, or a blog post.
  // Falls back to the default "Okay to Ask" link for direct visits and
  // external referrers.
  const link = document.getElementById('glossary-back-link') as HTMLAnchorElement | null;
  const label = document.getElementById('glossary-back-label');
  if (link && label) {
    const ref = document.referrer;
    try {
      const url = ref ? new URL(ref) : null;
      if (url && url.origin === window.location.origin) {
        const path = url.pathname;
        // Question detail: /anonymous_question/{slug}
        if (path.startsWith('/anonymous_question/')) {
          link.href = path;
          label.textContent = 'Back to question';
        }
        // Topic detail: /topics/{slug} (but not the /topics/ index)
        else if (path.startsWith('/topics/') && path !== '/topics/' && path !== '/topics') {
          link.href = path;
          label.textContent = 'Back to topic';
        }
        // Blog post: /blog/{slug} (but not the /blog/ index)
        else if (path.startsWith('/blog/') && path !== '/blog/' && path !== '/blog') {
          link.href = path;
          label.textContent = 'Back to article';
        }
      }
    } catch { /* ignore malformed referrer */ }
  }
</script>

---
/**
 * Service page [C5] — /services/rse-policy-curriculum-planning
 * RSE policy and curriculum planning consultancy. Tailor layer.
 */
import BaseLayout from '../../layouts/BaseLayout.astro';
import CtaServiceEnquiry from '../../components/CtaServiceEnquiry.astro';
import TopicsOverviewGrid from '../../components/TopicsOverviewGrid.astro';
import ServicePageStyles from '../../components/ServicePageStyles.astro';
import { getBlogPosts } from '../../lib/content';

const allPosts = await getBlogPosts();
const relatedPosts = allPosts.filter((p) => p.serviceLink === 'rse-policy-curriculum-planning').slice(0, 3);
---

<BaseLayout
  title="RSE Policy & Curriculum Planning — RSE for Schools | Tailor Education"
  description="Expert support writing your RSE policy and mapping your curriculum — ensuring compliance with DfE statutory guidance and a programme that actually works."
  canonicalPath="/services/rse-policy-curriculum-planning/"
  jsonLd={{
    '@context': 'https://schema.org',
    '@type': 'Service',
    name: 'RSE Policy & Curriculum Planning',
    description: 'Expert support writing your RSE policy and mapping your curriculum.',
    provider: { '@type': 'Organization', name: 'Tailor Education', url: 'https://tailoreducation.org.uk' },
  }}
>
  <article class="service-page" data-pagefind-body>

    <!-- §1 Hero -->
    <header class="service-page__header">
      <div class="mx-auto w-full max-w-[var(--container-max-shell)] px-[var(--space-global-gutter)] py-[var(--space-global-xl)]">
        <span class="service-page__eyebrow">Services</span>
        <h1 class="service-page__title">RSE policy & curriculum planning</h1>
        <p class="service-page__subtitle">
          Expert support writing your RSE policy and mapping your curriculum — ensuring statutory compliance and a programme that works for your school.
        </p>
      </div>
    </header>

    <!-- §2 Service detail -->
    <section class="service-page__detail">
      <div class="mx-auto w-full max-w-[var(--container-max-prose)] px-[var(--space-global-gutter)] py-[var(--space-struct-y-base)]">

        <!-- [IMAGE PLACEHOLDER: Policy and curriculum work — documents, planning session, school leadership meeting] -->
        <div class="service-page__image-placeholder" style="margin-bottom: var(--space-global-lg)">
          Image — RSE policy and curriculum planning (planning documents, leadership meeting, or curriculum mapping session)
        </div>

        <div class="service-page__detail-stack">

          <div class="service-page__detail-block">
            <h2 class="service-page__section-title">What this service is</h2>
            <p>We help schools write, review, or rewrite their RSE policy and build a curriculum map that meets statutory requirements and actually works in practice. This isn't a template — it's bespoke consultancy that understands your school's context, values, and the communities you serve.</p>
            <p>Many schools have an RSE policy that's technically compliant but doesn't reflect what happens in the classroom. We fix that gap — creating documentation that staff can use, leaders can defend, and inspectors can see is genuine.</p>
          </div>

          <div class="service-page__detail-block">
            <h2 class="service-page__section-title">Who it's for</h2>
            <p>Schools writing or updating their RSE policy to meet the 2026 DfE statutory guidance. Schools whose current policy is out of date, generic, or disconnected from their actual provision. Schools preparing for inspection who need their RSE documentation to stand up to scrutiny. And school leaders who want expert reassurance that their RSE programme is properly structured and defensible.</p>
          </div>

          <div class="service-page__detail-block">
            <h2 class="service-page__section-title">What's included</h2>
            <ul>
              <li>Review of your current RSE policy and curriculum provision</li>
              <li>Consultation with SLT, PSHE leads, and governors as needed</li>
              <li>Bespoke RSE policy document — compliant, practical, and specific to your school</li>
              <li>Curriculum map showing topic coverage across year groups and key stages</li>
              <li>Alignment to DfE 2026 statutory guidance and PSHE Association frameworks</li>
              <li>Guidance on parent consultation and communication</li>
              <li>Follow-up review to ensure implementation is on track</li>
            </ul>
          </div>

          <div class="service-page__detail-block">
            <h2 class="service-page__section-title">What schools get</h2>
            <p>A clear, defensible RSE policy that reflects your school's actual provision. A curriculum map that shows exactly what's taught, when, and why. Documentation that gives SLT, governors, and parents confidence. And the peace of mind that comes from knowing your RSE programme meets every statutory requirement.</p>
          </div>

        </div>
      </div>
    </section>

    <!-- §4 CTA [A13] — primary -->
    <CtaServiceEnquiry serviceName="RSE policy and curriculum planning" serviceParam="RSE policy & curriculum planning" />

    <!-- §5 Testimonial -->
    <section class="service-page__testimonial">
      <div class="mx-auto w-full max-w-[var(--container-max-prose)] px-[var(--space-global-gutter)] py-[var(--space-struct-y-base)]">
        <blockquote class="testimonial-pullquote">
          <p class="testimonial-pullquote__text">"We'd been putting off rewriting our RSE policy for years. Tailor made it straightforward — we now have a document we're genuinely proud of, and the curriculum map has been invaluable for showing governors exactly what we cover and when."</p>
          <footer class="testimonial-pullquote__footer">
            <span class="testimonial-pullquote__source">— Headteacher, primary school</span>
            <a href="/testimonials" class="testimonial-pullquote__link">Read more testimonials</a>
          </footer>
        </blockquote>
      </div>
    </section>

    <!-- §6 Related blog posts -->
    {relatedPosts.length > 0 && (
      <section class="service-page__blog">
        <div class="mx-auto w-full max-w-[var(--container-max-shell)] px-[var(--space-global-gutter)] py-[var(--space-struct-y-base)]">
          <h2 class="service-page__section-title" style="margin-bottom: var(--space-global-md)">Related articles</h2>
          <div class="service-page__blog-grid">
            {relatedPosts.map((bp) => (
              <a href={`/blog/${bp.slug}`} class="card service-blog-card">
                {bp.featuredImage && (
                  <div class="service-blog-card__img">
                    <img src={bp.featuredImage} alt={bp.title} loading="lazy" />
                  </div>
                )}
                <div class="card__body">
                  {bp.targetAudience && <div class="card__eyebrow">{bp.targetAudience}</div>}
                  <div class="card__title">{bp.title}</div>
                  {bp.author && <div class="service-blog-card__author">By {bp.author}</div>}
                </div>
              </a>
            ))}
          </div>
        </div>
      </section>
    )}

    <!-- §7 Topics overview grid -->
    <TopicsOverviewGrid />

    <!-- §8 CTA [A13] — repeated -->
    <CtaServiceEnquiry serviceName="RSE policy and curriculum planning" serviceParam="RSE policy & curriculum planning" variant="alt" />

  </article>
  <ServicePageStyles />
</BaseLayout>

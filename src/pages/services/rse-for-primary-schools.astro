---
export const prerender = true;
/**
 * Service page [C5] — /services/rse-for-primary-schools
 * RSE delivery for primary schools. Tailor layer, v3.
 */
import BaseLayout from '../../layouts/BaseLayout.astro';
import CtaServiceEnquiry from '../../components/CtaServiceEnquiry.astro';
import ServiceTopicsStrip from '../../components/ServiceTopicsStrip.astro';
import { getBlogPosts } from '../../lib/content';

// --- Data ----------------------------------------------------------
const slug = 'rse-for-primary-schools';
const title = 'RSE for primary schools';
const serviceParam = 'RSE for primary schools';
const serviceName = 'RSE for primary schools';

const heroSubtitle =
  'Expert-led RSE tailored for KS1 and KS2, delivered by a specialist educator who understands primary school settings — using language and activities that feel natural for the age group.';

const heroImage: string | null = '/images/services/tailor-education-primary-rse-circle-time.webp';
const heroImageAlt = 'Primary school pupils gathered for a circle-time RSE session led by a Tailor educator';

const descriptionLead =
  'A specialist RSE educator delivers age-appropriate lessons directly to your primary school students. Sessions are designed around the realities of teaching young children about relationships, bodies, boundaries, and staying safe — using language and activities that feel natural for the age group.';

const descriptionBody = [
  'We cover the topics that primary staff often find hardest to approach: puberty, consent in age-appropriate terms, healthy friendships, and online safety for younger children. Every session is planned with your PSHE lead in advance so it fits the year group, the school ethos, and anything your cohort is working through.',
];

const whatSchoolsGet =
  'Students who can name body parts accurately, understand what makes a healthy friendship, recognise the difference between appropriate and inappropriate touch, and know how to ask for help. Staff who feel more confident continuing RSE conversations after the session. And parents who can see that the school takes this seriously and handles it well.';

const featureCards = [
  { title: 'Pre-visit curriculum consultation', description: 'Planning call with your PSHE lead or headteacher to agree topics, year groups, and approach before we arrive.' },
  { title: 'KS1 and KS2 lesson design', description: 'Sessions designed for primary developmental stages — language and activities that feel natural for the age group.' },
  { title: 'Age-appropriate delivery', description: 'Content pitched right for young children — honest and clear without being overwhelming.' },
  { title: 'DfE statutory alignment', description: 'All topics aligned to the DfE statutory RSE and health education guidance.' },
  { title: 'Post-session staff summary', description: 'Written debrief for staff including talking points for follow-up conversations in the classroom.' },
  { title: 'Parent-facing information', description: 'Available on request — helps schools communicate what was covered and why.' },
];

const processSteps = [
  { number: 1, title: 'We plan together', description: 'Pre-visit consultation to agree topics, year groups, and the approach that fits your school.' },
  { number: 2, title: 'We deliver', description: 'A specialist educator delivers age-appropriate sessions directly to your students.' },
  { number: 3, title: 'You get results', description: 'Staff summary, follow-up resources, and students who can have the conversations that matter.' },
];

const testimonialQuote =
  'The children were completely engaged. The educator pitched it perfectly for our Year 5s — honest and clear without being overwhelming. Several parents commented on how well their children talked about the session at home.';
const testimonialSource = 'PSHE Lead, primary school';

const featuredTopicSlugs = [
  'puberty',
  'friendships',
  'families',
  'bodies-and-anatomy',
  'personal-safety',
  'online-safety',
];

// --- Content --------------------------------------------------------
const allPosts = await getBlogPosts();
const relatedPosts = allPosts.filter((p) => p.serviceLink === 'delivery').slice(0, 3);

const metaTitle = `${title} — RSE for Schools | Tailor Education`;
const metaDescription = 'Age-appropriate RSE for KS1 and KS2, delivered by a specialist educator who understands primary school settings.';
---

<BaseLayout
  title={metaTitle}
  description={metaDescription}
  canonicalPath={`/services/${slug}/`}
  ogImage={heroImage ?? undefined}
  jsonLd={{
    '@context': 'https://schema.org',
    '@type': 'Service',
    name: title,
    description: metaDescription,
    provider: { '@type': 'Organization', name: 'Tailor Education', url: 'https://tailoreducation.org.uk' },
  }}
>
  <article class="service-page" data-pagefind-body>

    <!-- §1 Hero -->
    <header class="service-hero">
      <div class="mx-auto w-full max-w-[var(--container-max-shell)] px-[var(--space-global-gutter)] py-[var(--space-struct-y-base)]">
        <div class="service-hero__inner">
          <div class="service-hero__text">
            <span class="service-hero__eyebrow">Services</span>
            <h1 class="service-hero__title">{title}</h1>
            <p class="service-hero__subtitle">{heroSubtitle}</p>
            <a
              href={`/contact?service=${encodeURIComponent(serviceParam)}`}
              class="btn btn--std btn--primary has-icon-hover"
              data-analytics-event="cta_click"
              data-analytics-cta-type="hero_enquire"
              data-analytics-service-type={serviceParam}
            >Enquire now</a>
          </div>
          <div class="service-hero__image">
            {heroImage ? (
              <img src={heroImage} alt={heroImageAlt} loading="eager" />
            ) : (
              <div class="service-hero__image-placeholder">Hero photography required — source before launch</div>
            )}
          </div>
        </div>
      </div>
    </header>

    <!-- §3 Description -->
    <section class="service-description">
      <div class="mx-auto w-full max-w-[var(--container-max-prose)] px-[var(--space-global-gutter)] py-[var(--space-struct-y-base)]">
        <p class="service-description__lead">{descriptionLead}</p>
        {descriptionBody.map((para) => (<p>{para}</p>))}
        {whatSchoolsGet && (
          <>
            <h2 class="service-description__sub-title">What schools get</h2>
            <p>{whatSchoolsGet}</p>
          </>
        )}
      </div>
    </section>

    <!-- §4 Feature cards -->
    <section class="service-features">
      <div class="mx-auto w-full max-w-[var(--container-max-shell)] px-[var(--space-global-gutter)] py-[var(--space-struct-y-base)]">
        <h2 class="service-section-title">What's included</h2>
        <div class="service-features__grid">
          {featureCards.map((card) => (
            <div class="feature-card">
              <h3 class="feature-card__title">{card.title}</h3>
              <p class="feature-card__text">{card.description}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- §5 Process steps -->
    {processSteps && (
      <section class="service-process">
        <div class="mx-auto w-full max-w-[var(--container-max-shell)] px-[var(--space-global-gutter)] py-[var(--space-struct-y-base)]">
          <h2 class="service-section-title">How it works</h2>
          <div class="service-process__grid">
            {processSteps.map((step) => (
              <div class="process-step">
                <div class="process-step__number">{step.number}</div>
                <h3 class="process-step__title">{step.title}</h3>
                <p class="process-step__text">{step.description}</p>
              </div>
            ))}
          </div>
        </div>
      </section>
    )}

    <!-- §6 Dark proof band -->
    <section class="service-proof-band">
      <div class="mx-auto w-full max-w-[var(--container-max-prose)] px-[var(--space-global-gutter)] py-[var(--space-struct-y-base)]">
        <div class="service-proof-band__inner">
          {testimonialQuote && (
            <>
              <blockquote>
                <p class="service-proof-band__quote">"{testimonialQuote}"</p>
              </blockquote>
              <span class="service-proof-band__source">— {testimonialSource}</span>
            </>
          )}
          <div class="service-proof-band__cta-wrap">
            <a
              href={`/contact?service=${encodeURIComponent(serviceParam)}`}
              class="btn btn--std btn--white-primary has-icon-hover"
              data-analytics-event="cta_click"
              data-analytics-cta-type="proof_band_enquire"
              data-analytics-service-type={serviceParam}
            >Enquire about {serviceName}</a>
            <a href="/testimonials" class="service-proof-band__testimonials-link">Read more testimonials →</a>
          </div>
        </div>
      </div>
    </section>

    <!-- §7 Related blog posts -->
    {relatedPosts.length > 0 && (
      <section class="service-blog">
        <div class="mx-auto w-full max-w-[var(--container-max-shell)] px-[var(--space-global-gutter)] py-[var(--space-struct-y-base)]">
          <h2 class="service-section-title">Related articles</h2>
          <div class="service-blog__grid">
            {relatedPosts.map((bp) => (
              <a href={`/blog/${bp.slug}`} class="card service-blog-card">
                {bp.featuredImage && (
                  <div class="service-blog-card__img">
                    <img src={bp.featuredImage} alt="" loading="lazy" />
                  </div>
                )}
                <div class="card__body">
                  {bp.targetAudience && <div class="card__eyebrow">{bp.targetAudience}</div>}
                  <h3 class="card__title">{bp.title}</h3>
                  {bp.author && <div class="service-blog-card__author">By {bp.author}</div>}
                </div>
              </a>
            ))}
          </div>
        </div>
      </section>
    )}

    <!-- §8 Topics strip -->
    <ServiceTopicsStrip featuredSlugs={featuredTopicSlugs} />

    <!-- §9 Closing enquiry CTA -->
    <CtaServiceEnquiry serviceName={serviceName} serviceParam={serviceParam} variant="alt" />

  </article>
</BaseLayout>

---
/**
 * C1 question page template — /anonymous_question/{slug}
 *
 * Layout follows docs/Tailor_Layout_Spec_C1.md. Structure in order:
 *   §1 Crisis support (A9)           [conditional, 56rem column]
 *   §2 Age flag (D1)                 [conditional, stacks with §1]
 *   ── .c1-content-panel (white "book page") ──
 *   §3 Post-it + question heading    [56rem, centred]
 *   §4 Reading level toggle + answer [44rem prose measure, sticky toggle]
 *   ── signposting surface band ──
 *   §5 Signposting (A8)              [56rem, --safeguarding-support-bg]
 *   ── .surface--ota band ──
 *   §6 Related questions (A15)       [56rem, card grid]
 *   §8 Topic tags (A16)              [inline inside §6, top-border separator]
 *   ── .surface--ota-alt band ──
 *   §7 End-of-answer panel (A17)     [56rem, 3-col triptych]
 *
 * Notion content pipeline, SEO metadata, JSON-LD, and Simple Mode swap JS
 * are preserved unchanged from the previous version. This commit is a
 * layout-only change.
 */
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getQuestions, getGlossaryIndex, getTopics } from '../../lib/content';
import { renderBlocks } from '../../lib/render-blocks';
import { injectGlossaryTooltips } from '../../lib/glossary-tooltips';
import { getPostItImagePath } from '../../lib/post-it-images';
import { selectRelatedQuestions } from '../../lib/related-questions';
import type { Question, Topic, GlossaryIndex } from '../../lib/types';

import SimpleModeToggle from '../../components/SimpleModeToggle.astro';
import GlossaryTooltips from '../../components/GlossaryTooltips.astro';
import CrisisSupport from '../../components/CrisisSupport.astro';
import AgeFlag from '../../components/AgeFlag.astro';
import SignpostingBlock from '../../components/SignpostingBlock.astro';
import EndOfAnswerPanel from '../../components/EndOfAnswerPanel.astro';
import RelatedQuestions from '../../components/RelatedQuestions.astro';

export const prerender = true;

export async function getStaticPaths() {
  const questions = await getQuestions();
  const glossaryIndex = await getGlossaryIndex();
  const topics = await getTopics();
  const topicMap = new Map(topics.map((t) => [t.id, t]));

  return questions.map((q) => ({
    params: { slug: q.slug },
    props: {
      question: q,
      allQuestions: questions,
      glossaryIndex,
      fullTopic: q.topicIds[0] ? topicMap.get(q.topicIds[0]) || null : null,
    },
  }));
}

interface Props {
  question: Question;
  allQuestions: Question[];
  glossaryIndex: GlossaryIndex;
  fullTopic: Topic | null;
}

const { question, allQuestions, glossaryIndex, fullTopic } = Astro.props;

// --- Data preparation ---

const postItImage = getPostItImagePath(question.slug);

const isSafeguarding = question.topic?.category === 'Safety & Safeguarding';
const showCrisis = isSafeguarding;
const crisisService = fullTopic?.crisisService || 'Childline';

const showAgeFlag = question.ageTier === 'Age-flagged Year 9+';
const showAlertBand = showCrisis || (showAgeFlag && !!question.topic);

// Answer bodies — both rendered at build time, JS toggles visibility.
const standardBodyHtml = renderBlocks(question.body);
const standardWithTooltips = injectGlossaryTooltips(standardBodyHtml, glossaryIndex);

const simpleAnswerHtml = question.simpleAnswer
  ? `<p>${question.simpleAnswer.replace(/\n\n/g, '</p><p>').replace(/\n/g, '<br>')}</p>`
  : '';
const simpleWithTooltips = injectGlossaryTooltips(simpleAnswerHtml, glossaryIndex);

const relatedQuestions = selectRelatedQuestions(question, allQuestions);

const topicName = question.topic?.name || 'this topic';
const topicSlug = question.topic?.slug || '';

// Category chip shown at the top of the post-it column.
const categoryBadgeMap: Record<string, string> = {
  'Anatomy': 'ota-anatomy',
  'Puberty': 'ota-puberty',
  'Relationships': 'ota-relationships',
  'Sex': 'ota-sex',
  'Sexual Health': 'ota-sexual-health',
  'Sex & the Law': 'ota-law',
  'Contraception': 'ota-contraception',
};
const categoryBadge = question.okayToAskCategory
  ? categoryBadgeMap[question.okayToAskCategory]
  : null;

// SEO + JSON-LD
const metaTitle = question.metaTitle || `${question.question} | Okay to Ask`;
const metaDescription = question.metaDescription
  || question.simpleAnswer?.slice(0, 155)
  || `Find the answer to "${question.question}" — honest, age-appropriate RSE from Okay to Ask.`;
const canonicalPath = `/anonymous_question/${question.slug}/`;

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: [{
    '@type': 'Question',
    name: question.question,
    acceptedAnswer: {
      '@type': 'Answer',
      text: question.simpleAnswer || metaDescription,
    },
  }],
};

// §3 top padding. With no crisis/age-flag above, the post-it gets hero
// air; otherwise it sits on a base struct gap.
const postItTopPadding = showAlertBand
  ? 'pt-[var(--space-struct-y-base)]'
  : 'pt-[var(--space-struct-y-hero)]';
---

<BaseLayout
  title={metaTitle}
  description={metaDescription}
  canonicalPath={canonicalPath}
  ogType="article"
  layer="ota"
  jsonLd={jsonLd}
  preloadImage={postItImage ?? undefined}
>
  {/* ─────────────────────────────────────────────
      §1 + §2 — Crisis support (A9) and Age flag (D1)
      A single wrapping section so the two alerts
      stack in the same 56rem reading column when
      both are present. Crisis is always first.
      ───────────────────────────────────────────── */}
  {showAlertBand && (
    <section
      class="w-full pt-[var(--space-global-xl)] px-[var(--space-global-gutter)]"
      aria-label="Important information"
    >
      <div class="mx-auto w-full max-w-[var(--container-max-reading-wide)] flex flex-col gap-[var(--space-global-md)]">
        {showCrisis && <CrisisSupport crisisService={crisisService} />}
        {showAgeFlag && question.topic && (
          <AgeFlag topicLabel={question.topic.name} topicSlug={question.topic.slug} />
        )}
      </div>
    </section>
  )}

  {/* ─────────────────────────────────────────────
      .c1-content-panel — §3, §4
      Content "book page" panel: white surface, shadow, radius.
      Sits on --bg-page ground, not full-bleed.
      ───────────────────────────────────────────── */}
  <div
    class="c1-content-panel mx-auto w-full max-w-[var(--container-max-reading-wide)] px-[var(--space-global-gutter)]"
    data-pagefind-body
    data-page-type="question"
    data-slug={question.slug}
    data-topic={topicName}
    data-age-tier={question.ageTier || ''}
  >
    {/* §3 — Post-it image + question heading */}
    <section
      class:list={[
        'w-full pb-[var(--space-global-xl)]',
        postItTopPadding,
      ]}
      aria-labelledby="question-heading"
    >
      <div class="mx-auto w-full max-w-[var(--container-max-reading-wide)] flex flex-col items-center text-center">
        {/* Scanned post-it artefact */}
        {postItImage && (
          <figure
            id="question-post-it"
            class="flex flex-col items-center mb-[var(--space-global-lg)]"
          >
            <img
              src={postItImage}
              alt={`Handwritten question: ${question.question}`}
              class="postit-image"
              loading="eager"
            />
            <figcaption
              id="question-post-it-caption"
              class="c1-postit-caption mt-[var(--space-global-sm)]"
            >
              A real question from a young person, submitted anonymously.
            </figcaption>
          </figure>
        )}

        {/* The question itself — single page h1 */}
        <h1
          id="question-heading"
          class="c1-question-heading text-center mt-[var(--space-global-lg)] mb-0 max-w-[38rem] mx-auto"
        >
          {question.question}
        </h1>
      </div>
    </section>

    {/* §4 — Reading level toggle (A6) + answer body */}
    <section
      class="w-full pb-[var(--space-global-2xl)]"
      aria-label="Answer"
    >
      <div class="mx-auto w-full max-w-[var(--container-max-prose)]">
        {/* Simple Mode toggle — sticky on desktop */}
        <div class="c1-toggle-sticky lg:sticky lg:top-[var(--header-height)] z-[20]">
          <div class="c1-toggle-row flex items-center justify-between gap-[var(--space-global-md)] py-[var(--space-global-md)] border-b-[var(--border-width-xs)] border-[var(--border-subtle)]">
            {question.okayToAskCategory ? (
              <span
                class="c1-category-eyebrow"
                style={categoryBadge ? `color: var(--ota-cat-${categoryBadge.replace('ota-', '')})` : undefined}
              >
                {question.okayToAskCategory}
              </span>
            ) : <span />}
            <SimpleModeToggle />
          </div>
        </div>

        {/* Answer bodies — both views live in the DOM; JS toggles visibility */}
        <div class="c1-answer">
          <div
            data-mode="standard"
            data-reading-level="standard"
            class="mode-content ota-prose"
            aria-live="polite"
          >
            <Fragment set:html={standardWithTooltips} />
          </div>
          <div
            data-mode="simple"
            data-reading-level="simple"
            class="mode-content ota-prose"
            aria-live="polite"
          >
            <Fragment set:html={simpleWithTooltips} />
          </div>
        </div>
      </div>
    </section>
  </div>

  {/* §5 — Signposting block (A8) — own surface band
      Cool blue ground separates support info from answer content. */}
  {question.signposting.length > 0 && (
    <section
      class="w-full pt-[var(--space-global-2xl)] pb-[var(--space-struct-y-base)] px-[var(--space-global-gutter)]"
      style="background: var(--safeguarding-support-bg);"
      aria-label="Support services"
    >
      <div class="mx-auto w-full max-w-[var(--container-max-reading-wide)]">
        <SignpostingBlock services={question.signposting} />
      </div>
    </section>
  )}

  {/* ─────────────────────────────────────────────
      §6 — Related questions (A15)
      Cards on --bg-page ground (no surface class).
      ───────────────────────────────────────────── */}
  <div class="w-full">
    <section
      class="w-full py-[var(--space-struct-y-base)] px-[var(--space-global-gutter)]"
      aria-labelledby="related-heading"
    >
      <div class="mx-auto w-full max-w-[var(--container-max-reading-wide)]">
        {relatedQuestions.length > 0 && (
          <div id="related-heading">
            <RelatedQuestions questions={relatedQuestions} />
          </div>
        )}

      </div>
    </section>
  </div>

  {/* ─────────────────────────────────────────────
      §7 — End-of-answer panel (A17)
      Own .surface--ota-alt band — the visual surface
      shift that breaks the continuous warm paper ground.
      ───────────────────────────────────────────── */}
  <section
    class="surface--ota-alt w-full py-[var(--space-struct-y-base)] px-[var(--space-global-gutter)]"
    aria-labelledby="end-of-answer-heading"
  >
    <div class="mx-auto w-full max-w-[var(--container-max-reading-wide)]">
      <EndOfAnswerPanel topicName={topicName} topicSlug={topicSlug} />
    </div>
  </section>

  {/* Glossary tooltip runtime */}
  <GlossaryTooltips />
</BaseLayout>

<style>
  /* Simple Mode visibility — driven by .simple-active on <html>.
     Both answer views live in the DOM at build time; only the text
     swaps, layout stays stable (D5 rule). */
  [data-mode="simple"] {
    display: none;
  }
  :global(.simple-active [data-mode="standard"]) {
    display: none !important;
  }
  :global(.simple-active [data-mode="simple"]) {
    display: block !important;
  }

  /* "Book page" panel — white surface that lifts off the --bg-page ground */
  .c1-content-panel {
    background: var(--bg-page);
    border-radius: var(--radius-lg);
    box-shadow: var(--shadow-md);
    margin-top: var(--space-global-lg);
    margin-bottom: var(--space-global-lg);
    overflow: hidden;
  }

  /* Post-it figcaption — muted source attribution */
  .c1-postit-caption {
    font-family: var(--font-ota-body-stack, inherit);
    font-size: var(--text-util-micro-size, 0.75rem);
    color: var(--text-ota-muted);
  }
  .c1-postit-caption:focus {
    outline: var(--focus-ring-width) solid var(--focus-ring);
    outline-offset: var(--focus-ring-offset);
    border-radius: var(--radius-xs);
  }

  /* Question display heading — Fraunces, display ramp, generous leading */
  .c1-question-heading {
    font-family: var(--font-ota-heading-stack, inherit);
    font-size: var(--text-display-size-h1);
    font-weight: var(--heading-ota-weight-h1, 700);
    line-height: var(--lh-heading);
    color: var(--text-ota-heading);
  }

  /* Sticky Simple Mode toggle row (desktop only) */
  .c1-toggle-sticky {
    background: var(--bg-surface);
    margin-bottom: var(--space-global-xl);
  }

  @media (max-width: 1023px) {
    .c1-toggle-sticky {
      position: static;
      margin-bottom: var(--space-global-lg);
    }
  }

  .c1-category-eyebrow {
    font-size: var(--text-util-micro-size, 0.75rem);
    font-weight: var(--font-weight-semibold);
    text-transform: uppercase;
    letter-spacing: var(--section-eyebrow-ls);
    color: var(--text-ota-muted);
  }

  .c1-answer {
    /* The prose column width is already set by the section wrapper
       (--container-max-prose). Individual elements need no further
       constraints. */
  }
</style>

<!-- .ota-prose styles now live in tailor-site-v2.css -->

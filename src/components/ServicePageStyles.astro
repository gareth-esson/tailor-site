---
/**
 * ServicePageStyles — shared scoped styles for all C5 service pages.
 * Import this component at the bottom of each service page to inject
 * consistent styling without duplicating CSS across 7 files.
 */
---

<style is:global>
  .service-page {
    background: var(--bg-page);
  }

  /* --- §1 Hero --- */
  .service-page__header {
    background: var(--bg-surface);
    border-bottom: var(--border-width-xs) solid var(--border-subtle);
  }

  .service-page__eyebrow {
    display: inline-block;
    font-family: var(--font-tailor-body-stack);
    font-size: var(--text-card-size-body);
    font-weight: var(--font-weight-semibold);
    color: var(--brand-accent-text);
    text-transform: uppercase;
    letter-spacing: var(--text-eyebrow-ls);
    margin-bottom: var(--space-global-xs);
  }

  .service-page__title {
    font-family: var(--font-tailor-heading-stack);
    font-size: var(--text-display-size-h1);
    font-weight: var(--heading-weight-h1);
    color: var(--text-heading);
    margin: 0 0 var(--space-global-sm);
    line-height: var(--lh-display);
  }

  .service-page__subtitle {
    font-family: var(--font-tailor-body-stack);
    font-size: var(--text-prose-size-body);
    color: var(--text-body-muted);
    max-width: var(--container-max-prose);
    margin: 0;
    line-height: var(--lh-body);
  }

  /* --- §2 Service detail --- */
  .service-page__detail {
    font-family: var(--font-tailor-body-stack);
    font-size: var(--text-prose-size-body);
    color: var(--text-body);
    line-height: var(--lh-prose);
  }

  .service-page__detail-stack {
    display: flex;
    flex-direction: column;
    gap: var(--space-global-lg);
  }

  .service-page__section-title {
    font-family: var(--font-tailor-heading-stack);
    font-size: var(--text-prose-size-h2);
    font-weight: var(--heading-weight-h2);
    color: var(--text-heading);
    margin: 0 0 var(--space-global-sm);
  }

  .service-page__detail ul {
    padding-left: 1.5rem;
    margin: 0;
  }

  .service-page__detail li {
    margin-bottom: 0.375rem;
  }

  .service-page__detail p {
    margin: 0 0 var(--space-global-sm);
  }

  .service-page__detail p:last-child {
    margin-bottom: 0;
  }

  /* --- §3 Hub navigation cards --- */
  .service-page__hub-nav-grid {
    display: grid;
    gap: var(--space-global-sm);
  }

  .hub-nav-card {
    display: flex;
    flex-direction: column;
    padding: var(--space-global-lg);
    background: var(--bg-surface);
    border: var(--border-width-xs) solid var(--border-subtle);
    border-radius: var(--radius-lg);
    text-decoration: none;
    color: inherit;
    transition: border-color var(--transition-duration) var(--transition-easing);
  }

  .hub-nav-card:hover {
    border-color: var(--brand-accent);
  }

  .hub-nav-card__title {
    font-family: var(--font-tailor-heading-stack);
    font-size: var(--text-card-size-h2);
    font-weight: var(--heading-weight-h2);
    color: var(--text-heading);
    line-height: var(--lh-heading-sub);
    margin: 0 0 var(--space-global-xs);
  }

  .hub-nav-card__summary {
    font-family: var(--font-tailor-body-stack);
    font-size: var(--text-card-size-body);
    color: var(--text-body-muted);
    line-height: var(--lh-body);
    margin: 0 0 var(--space-global-sm);
    flex-grow: 1;
  }

  .hub-nav-card__link {
    font-size: var(--text-card-size-body);
    font-weight: var(--font-weight-bold);
    color: var(--link-action-color);
  }

  .hub-nav-card__link::after {
    content: ' \2192';
  }

  /* --- §5 Testimonial --- */
  .service-page__testimonial {
    background: var(--bg-surface-alt);
  }

  .testimonial-pullquote {
    padding-left: var(--space-global-lg);
    border-left: 4px solid var(--brand-accent);
    margin: 0;
  }

  .testimonial-pullquote__text {
    font-family: var(--font-tailor-body-stack);
    font-size: var(--text-prose-size-body);
    font-style: italic;
    color: var(--text-body);
    line-height: var(--lh-prose);
    margin: 0 0 var(--space-global-sm);
  }

  .testimonial-pullquote__footer {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-global-sm);
    align-items: baseline;
  }

  .testimonial-pullquote__source {
    font-family: var(--font-tailor-body-stack);
    font-size: var(--text-card-size-body);
    font-weight: var(--font-weight-semibold);
    font-style: normal;
    color: var(--text-heading);
  }

  .testimonial-pullquote__link {
    font-size: var(--text-card-size-body);
    color: var(--brand-accent-text);
    text-decoration: none;
  }

  .testimonial-pullquote__link:hover {
    text-decoration: underline;
  }

  /* --- §6 Blog posts --- */
  .service-page__blog {
    border-top: var(--border-width-xs) solid var(--border-subtle);
  }

  .service-page__blog-grid {
    display: grid;
    gap: var(--space-global-sm);
  }

  .service-blog-card {
    text-decoration: none;
    color: inherit;
  }

  .service-blog-card__img {
    aspect-ratio: 16 / 9;
    overflow: hidden;
    border-radius: var(--card-radius, var(--radius-md)) var(--card-radius, var(--radius-md)) 0 0;
  }

  .service-blog-card__img img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .service-blog-card__author {
    font-size: var(--text-card-size-body);
    color: var(--text-body-muted);
    margin-top: 0.25rem;
  }

  /* --- Image placeholder --- */
  .service-page__image-placeholder {
    display: flex;
    align-items: center;
    justify-content: center;
    background: var(--bg-surface-alt);
    border: 2px dashed var(--border-subtle);
    border-radius: var(--radius-lg);
    aspect-ratio: 16 / 9;
    font-family: var(--font-tailor-body-stack);
    font-size: var(--text-card-size-body);
    color: var(--text-body-muted);
    text-align: center;
    padding: var(--space-global-md);
  }

  @media (min-width: 640px) {
    .service-page__hub-nav-grid {
      grid-template-columns: repeat(2, 1fr);
    }
    .service-page__blog-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (min-width: 768px) {
    .service-page__blog-grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }
</style>

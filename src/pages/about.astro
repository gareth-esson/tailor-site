---
/**
 * About page [B2] — /about
 * Mission, team, Okay to Ask project, framework alignment. Tailor layer.
 */
import BaseLayout from '../layouts/BaseLayout.astro';

---

<BaseLayout
  title="About — Tailor Education"
  description="Tailor Education creates expert RSE resources, training and support for schools. Meet the team and learn about Okay to Ask."
  canonicalPath="/about"
>
  <article class="about-page">
    <!-- 1. Tailor Education -->
    <section class="about-hero">
      <div class="mx-auto max-w-4xl px-[var(--space-global-gutter)] py-[var(--space-global-xl)]">
        <h1 class="about-hero__title">About Tailor Education</h1>
        <p class="about-hero__text">
          Tailor Education is a community interest company dedicated to providing expert relationships and sex education for UK schools. We believe every young person deserves honest, inclusive, and age-appropriate RSE — and every teacher deserves the tools and confidence to deliver it.
        </p>
      </div>
    </section>

    <!-- 2. Meet the team -->
    <section class="about-section about-section--alt">
      <div class="mx-auto max-w-4xl px-[var(--space-global-gutter)] py-[var(--space-global-lg)]">
        <h2 class="about-section__title">Meet the team</h2>
        <div class="team-grid">
          <div class="team-card">
            <div class="team-card__avatar" aria-hidden="true">GE</div>
            <div class="team-card__info">
              <h3 class="team-card__name">Gareth Esson</h3>
              <p class="team-card__role">Founder & RSE Specialist</p>
              <p class="team-card__bio">
                Gareth is an experienced RSE educator who has worked directly with schools across the UK. He writes all Tailor Education content and delivers training and RSE sessions in schools.
              </p>
            </div>
          </div>
          <div class="team-card">
            <div class="team-card__avatar" aria-hidden="true">TE</div>
            <div class="team-card__info">
              <h3 class="team-card__name">Team member</h3>
              <p class="team-card__role">Role TBC</p>
              <p class="team-card__bio">Bio coming soon.</p>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- 3. The Okay to Ask project -->
    <section class="about-section">
      <div class="mx-auto max-w-4xl px-[var(--space-global-gutter)] py-[var(--space-global-lg)]">
        <h2 class="about-section__title">The Okay to Ask project</h2>
        <p class="about-section__text">
          Okay to Ask started with anonymous question boxes in schools. Young people wrote down whatever they wanted to know — no names, no judgement. We collected those questions and answered every single one honestly.
        </p>
        <p class="about-section__text">
          The result is a growing collection of over 150 real questions and honest answers, published online and in print. The Okay to Ask book brings these questions to life with the original handwritten post-it notes and expert answers.
        </p>
        <a href="/book" class="link-action">Learn about the book</a>
      </div>
    </section>

    <!-- 4. Framework alignment -->
    <section class="about-section about-section--alt">
      <div class="mx-auto max-w-4xl px-[var(--space-global-gutter)] py-[var(--space-global-lg)]">
        <h2 class="about-section__title">Framework alignment</h2>
        <p class="about-section__text">
          All Tailor Education content is aligned to national and international RSE frameworks, including DfE statutory guidance, the PSHE Association Programme of Study, UNESCO, and WHO standards.
        </p>
        <a href="/our-approach" class="link-action">Read about our approach</a>
      </div>
    </section>

    <!-- 5. CTA -->
    <section class="about-cta">
      <div class="mx-auto max-w-4xl px-[var(--space-global-gutter)] py-[var(--space-global-xl)]">
        <div class="about-cta__card">
          <a href="/our-approach" class="btn btn--std btn--tint">See our approach</a>
          <a href="/contact" class="btn btn--std btn--primary has-icon-hover">Get in touch</a>
        </div>
      </div>
    </section>
  </article>
</BaseLayout>

<style>
  .about-page { background: var(--bg-page); }
  .about-hero { background: var(--bg-surface); border-bottom: var(--border-width-xs) solid var(--border-subtle); }
  .about-hero__title { font-family: var(--font-tailor-heading-stack); font-size: var(--text-display-size-h1); font-weight: var(--heading-weight-h1); color: var(--text-heading); margin: 0 0 var(--space-global-md); }
  .about-hero__text { font-family: var(--font-tailor-body-stack); font-size: var(--text-prose-size-body); color: var(--text-body); max-width: 36rem; margin: 0; line-height: 1.7; }
  .about-section { font-family: var(--font-tailor-body-stack); }
  .about-section--alt { background: var(--bg-surface-alt); }
  .about-section__title { font-family: var(--font-tailor-heading-stack); font-size: var(--text-prose-size-h2); font-weight: var(--heading-weight-h2); color: var(--text-heading); margin: 0 0 var(--space-global-sm); }
  .about-section__text { font-size: var(--text-prose-size-body); color: var(--text-body); line-height: 1.7; max-width: 36rem; margin: 0 0 var(--space-global-sm); }

  .team-grid { display: grid; gap: var(--space-global-md); }
  .team-card { display: flex; gap: var(--space-global-md); padding: var(--space-global-md); background: var(--bg-surface); border-radius: var(--radius-lg); border: var(--border-width-xs) solid var(--border-subtle); }
  .team-card__avatar { width: 3.5rem; height: 3.5rem; border-radius: 50%; background: var(--bg-tinted); display: flex; align-items: center; justify-content: center; font-family: var(--font-tailor-body-stack); font-weight: var(--font-weight-bold); color: var(--brand-accent-text); flex-shrink: 0; }
  .team-card__name { font-size: var(--text-prose-size-body); font-weight: var(--font-weight-semibold); color: var(--text-heading); margin: 0; }
  .team-card__role { font-size: var(--text-card-size-body); color: var(--brand-accent-text); margin: 0 0 var(--space-global-xs); }
  .team-card__bio { font-size: var(--text-card-size-body); color: var(--text-body-muted); margin: 0; line-height: 1.5; }

  .about-cta__card { display: flex; flex-wrap: wrap; gap: var(--space-global-sm); justify-content: center; }

  @media (min-width: 768px) { .team-grid { grid-template-columns: repeat(2, 1fr); } }
</style>

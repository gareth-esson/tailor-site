---
/**
 * Service page [C5] — /services/rse-for-send-and-ap
 * Circuits: RSE for SEND and alternative provision. Tailor layer, v3.
 * Distinct workbook-based product line — self-paced, simplified keynotes,
 * doodle and game space in workbooks that students keep.
 */
import BaseLayout from '../../layouts/BaseLayout.astro';
import CtaServiceEnquiry from '../../components/CtaServiceEnquiry.astro';
import ServiceTopicsStrip from '../../components/ServiceTopicsStrip.astro';
import { getBlogPosts } from '../../lib/content';

// --- Data ----------------------------------------------------------
const slug = 'rse-for-send-and-ap';
const title = 'RSE for SEND and AP (Circuits)';
const serviceParam = 'RSE for SEND and AP';
const serviceName = 'Circuits';

const heroSubtitle =
  'Circuits is a workbook-led RSE programme built for SEND and alternative provision. Self-paced, visually simplified, with doodle and game space woven through — so students engage on their own terms and keep the workbook afterwards as something that\'s theirs.';

const heroImage: string | null = '/images/services/tailor-education-primary-pupil-rse-worksheet.webp';
const heroImageAlt = 'A pupil working through a Circuits RSE workbook at their own pace';

const descriptionLead =
  'Mainstream RSE lessons assume a classroom that moves at one pace, reads the same way, and processes information the same way. Circuits is designed from the opposite starting point — that every student in a SEND or AP setting is arriving at this content differently, and the delivery should flex to meet them.';

const descriptionBody = [
  'Each student works through their own workbook alongside a Tailor educator. Keynote content is simplified visually — fewer words per page, clearer imagery, more space to think. Activities include doodle space, games, and reflective prompts, so students can engage in the way that works for them. The workbook belongs to the student afterwards — a reference they can come back to in their own time.',
  'Sessions can be delivered 1:1, in small groups, or integrated into existing SEND provision blocks. We work with your team to agree pace, grouping, and which topics are most relevant for your cohort.',
];

const whatSchoolsGet =
  'Students who have actually engaged with RSE content — not students who sat through a session and switched off. A workbook each student keeps, so the learning doesn\'t stop at the end of the session. Staff briefed on each student\'s progress and anything flagged along the way.';

const featureCards = [
  { title: 'Self-paced workbook delivery', description: 'Students work through their own copy alongside a specialist educator. No forced pace, no falling behind.' },
  { title: 'Simplified keynote content', description: 'Fewer words per page, clearer visuals, more white space — designed for processing, not covering ground.' },
  { title: 'Doodle and game space', description: 'Workbooks include doodle prompts, games, and reflection activities — multiple ways in for students who learn differently.' },
  { title: 'Workbooks students keep', description: 'The workbook belongs to the student afterwards. A reference they can return to in their own time.' },
  { title: '1:1 or small group delivery', description: 'Flexible grouping — 1:1 where that works, small groups where connection helps. We agree it with your SEND or AP team beforehand.' },
  { title: 'Pre-delivery planning with your team', description: 'We meet your SENCO or AP lead in advance to agree pace, topics, and any student-specific considerations.' },
];

const processSteps = [
  { number: 1, title: 'We adapt', description: 'Planning call with your SENCO or AP lead to agree topics, pace, grouping, and any student-specific considerations.' },
  { number: 2, title: 'They learn at their pace', description: 'A specialist educator works through workbooks with your students — self-paced, low-pressure, on their terms.' },
  { number: 3, title: 'They keep the workbook', description: 'The workbook stays with the student as a reference they can return to. Staff get a debrief on progress and anything flagged.' },
];

const testimonialQuote =
  'Our students engaged in a way they rarely do with whole-class sessions. The workbooks gave them something concrete to hold, and the fact they got to keep them mattered more than I expected.';
const testimonialSource = 'SENCO, alternative provision';

const featuredTopicSlugs = [
  'personal-safety',
  'healthy-relationships',
  'puberty',
  'body-image',
  'friendships',
  'consent',
];

// --- Content --------------------------------------------------------
const allPosts = await getBlogPosts();
const relatedPosts = allPosts.filter((p) => p.serviceLink === 'delivery').slice(0, 3);

const metaTitle = 'RSE for SEND & AP (Circuits) — RSE for Schools | Tailor Education';
const metaDescription = 'Circuits is a workbook-led, self-paced RSE programme designed for SEND and alternative provision settings.';
---

<BaseLayout
  title={metaTitle}
  description={metaDescription}
  canonicalPath={`/services/${slug}/`}
  ogImage={heroImage ?? undefined}
  jsonLd={{
    '@context': 'https://schema.org',
    '@type': 'Service',
    name: 'RSE for SEND and AP (Circuits)',
    description: metaDescription,
    provider: { '@type': 'Organization', name: 'Tailor Education', url: 'https://tailoreducation.org.uk' },
  }}
>
  <article class="service-page" data-pagefind-body>

    <header class="service-hero">
      <div class="service-hero__inner">
        <div class="service-hero__text">
            <span class="service-hero__eyebrow">Services</span>
            <h1 class="service-hero__title">{title}</h1>
            <p class="service-hero__subtitle">{heroSubtitle}</p>
            <a
              href={`/contact?service=${encodeURIComponent(serviceParam)}`}
              class="btn btn--std btn--primary has-icon-hover"
              data-analytics-event="cta_click"
              data-analytics-cta-type="hero_enquire"
              data-analytics-service-type={serviceParam}
            >Enquire now</a>
          </div>
          <div class="service-hero__image">
            {heroImage ? (
              <img src={heroImage} alt={heroImageAlt} loading="eager" />
            ) : (
              <div class="service-hero__image-placeholder">Hero photography required — source before launch</div>
            )}
          </div>
        </div>
    </header>

    <section class="service-description">
      <div class="mx-auto w-full max-w-[var(--container-max-prose)] px-[var(--space-global-gutter)] py-[var(--space-struct-y-base)]">
        <p class="service-description__lead">{descriptionLead}</p>
        {descriptionBody.map((para) => (<p>{para}</p>))}
        {whatSchoolsGet && (
          <>
            <h2 class="service-description__sub-title">What schools get</h2>
            <p>{whatSchoolsGet}</p>
          </>
        )}
      </div>
    </section>

    <section class="service-features">
      <div class="mx-auto w-full max-w-[var(--container-max-shell)] px-[var(--space-global-gutter)] py-[var(--space-struct-y-base)]">
        <h2 class="service-section-title">What's included</h2>
        <div class="service-features__grid">
          {featureCards.map((card) => (
            <div class="feature-card">
              <h3 class="feature-card__title">{card.title}</h3>
              <p class="feature-card__text">{card.description}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    {processSteps && (
      <section class="service-process">
        <div class="mx-auto w-full max-w-[var(--container-max-shell)] px-[var(--space-global-gutter)] py-[var(--space-struct-y-base)]">
          <h2 class="service-section-title">How it works</h2>
          <div class="service-process__grid">
            {processSteps.map((step) => (
              <div class="process-step">
                <div class="process-step__number">{step.number}</div>
                <h3 class="process-step__title">{step.title}</h3>
                <p class="process-step__text">{step.description}</p>
              </div>
            ))}
          </div>
        </div>
      </section>
    )}

    <section class="service-proof-band">
      <div class="mx-auto w-full max-w-[var(--container-max-prose)] px-[var(--space-global-gutter)] py-[var(--space-struct-y-base)]">
        <div class="service-proof-band__inner">
          {testimonialQuote && (
            <>
              <blockquote>
                <p class="service-proof-band__quote">"{testimonialQuote}"</p>
              </blockquote>
              <span class="service-proof-band__source">— {testimonialSource}</span>
            </>
          )}
          <div class="service-proof-band__cta-wrap">
            <a
              href={`/contact?service=${encodeURIComponent(serviceParam)}`}
              class="btn btn--std btn--white-primary has-icon-hover"
              data-analytics-event="cta_click"
              data-analytics-cta-type="proof_band_enquire"
              data-analytics-service-type={serviceParam}
            >Enquire about {serviceName}</a>
            <a href="/testimonials" class="link-action link-action--muted link-action--card">Read more testimonials</a>
          </div>
        </div>
      </div>
    </section>

    {relatedPosts.length > 0 && (
      <section class="service-blog">
        <div class="mx-auto w-full max-w-[var(--container-max-shell)] px-[var(--space-global-gutter)] py-[var(--space-struct-y-base)]">
          <h2 class="service-section-title">Related articles</h2>
          <div class="service-blog__grid">
            {relatedPosts.map((bp) => (
              <a href={`/blog/${bp.slug}`} class="card card--lift service-blog-card">
                {bp.featuredImage && (
                  <div class="service-blog-card__img">
                    <img src={bp.featuredImage} alt="" loading="lazy" />
                  </div>
                )}
                <div class="card__body">
                  {bp.targetAudience && <div class="card__eyebrow">{bp.targetAudience}</div>}
                  <h3 class="card__title">{bp.title}</h3>
                  {bp.author && <div class="service-blog-card__author">By {bp.author}</div>}
                </div>
              </a>
            ))}
          </div>
        </div>
      </section>
    )}

    <ServiceTopicsStrip featuredSlugs={featuredTopicSlugs} />

    <CtaServiceEnquiry serviceName={serviceName} serviceParam={serviceParam} variant="alt" />

  </article>
</BaseLayout>

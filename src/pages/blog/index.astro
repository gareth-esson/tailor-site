---
/**
 * Blog index [B9] — /blog/
 * Layout spec: Tailor_Layout_Spec_B9.md v2.2
 *
 * One job: present every published blog post in a browsable, filterable grid.
 * No featured/hero post — all posts sit in one uniform grid, newest first.
 *
 * Surface rhythm: tinted hero → page ground (rest of page). One switch.
 * Intentionally quiet — the posts carry the visual interest.
 */
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getBlogPosts } from '../../lib/content';
import {
  formatDate,
  deriveExcerpt,
  sortPostsForIndex,
} from '../../lib/blog-helpers';

// --- Data ----------------------------------------------------------------
const allPosts = await getBlogPosts();
const posts = sortPostsForIndex(allPosts);

// Pre-compute excerpts + formatted dates at build time.
const cards = posts.map((p) => ({
  ...p,
  excerpt: deriveExcerpt(p.body, 140),
  dateLabel: formatDate(p.publishedDate),
}));

// --- Filter populations --------------------------------------------------
// Category — fixed canonical list per spec §2.4.
const CATEGORY_ORDER = ['RSE in Practice', 'Guidance and Policy', 'Our Work'];
const categoryPostCounts = new Map<string, number>();
CATEGORY_ORDER.forEach((cat) => categoryPostCounts.set(cat, 0));
posts.forEach((p) => {
  if (p.category && categoryPostCounts.has(p.category)) {
    categoryPostCounts.set(p.category, (categoryPostCounts.get(p.category) ?? 0) + 1);
  }
});

// Topic — deduplicated, preserving first-appearance order.
type TopicChip = { slug: string; title: string };
const topicMap = new Map<string, TopicChip>();
posts.forEach((p) => {
  (p.topics ?? []).forEach((t) => {
    if (!topicMap.has(t.title)) topicMap.set(t.title, { slug: t.slug, title: t.title });
  });
});
const topics: TopicChip[] = [...topicMap.values()];

// --- Load-more gating ----------------------------------------------------
const POSTS_PER_PAGE = 12;
const showLoadMore = posts.length > 24;

// --- JSON-LD -------------------------------------------------------------
const siteUrl = 'https://tailoreducation.org.uk';
const jsonLd = posts.length > 0
  ? {
      '@context': 'https://schema.org',
      '@type': 'Blog',
      name: 'Tailor Education — Blog',
      url: `${siteUrl}/blog/`,
      blogPost: posts.slice(0, 50).map((p) => {
        const entry: Record<string, unknown> = {
          '@type': 'BlogPosting',
          headline: p.title,
          url: `${siteUrl}/blog/${p.slug}/`,
        };
        if (p.publishedDate) entry.datePublished = p.publishedDate;
        if (p.author) entry.author = { '@type': 'Person', name: p.author };
        if (p.featuredImage) entry.image = p.featuredImage;
        if (p.metaDescription) entry.description = p.metaDescription;
        return entry;
      }),
    }
  : undefined;
---

<BaseLayout
  title="Blog — Tailor Education"
  description="Practical guidance on RSE teaching, curriculum planning, and bringing relationships education to life in schools."
  canonicalPath="/blog/"
  jsonLd={jsonLd}
>
  {/* §1 — Hero (tinted band, text-only) --------------------------------- */}
  <header class="blog-index-hero">
    <div class="blog-index-hero__inner">
      <span class="blog-index-hero__eyebrow">Writing</span>
      <h1 class="blog-index-hero__title">Blog</h1>
      <p class="blog-index-hero__intro">
        Practical guidance for RSE teaching, curriculum planning, and bringing relationships education to life in schools.
      </p>
    </div>
  </header>

  <div class="blog-index">
    {/* §2 — Filter bar (category + topic) ------------------------------- */}
    <section class="blog-filters" aria-label="Filter posts" data-pagefind-ignore="all">
      <div class="blog-filters__inner">

        <div class="blog-filters__row" role="toolbar" aria-label="Filter by category">
          <span class="blog-filters__label" id="filter-category-label">Category</span>
          <div class="blog-filters__scroll" aria-labelledby="filter-category-label">
            <button class="blog-filter-chip is-active" type="button" data-filter-type="category" data-filter-value="all" aria-pressed="true" tabindex="0">All</button>
            {CATEGORY_ORDER.map((cat) => {
              const count = categoryPostCounts.get(cat) ?? 0;
              const disabled = count === 0;
              return (
                <button
                  class:list={['blog-filter-chip', { 'is-disabled': disabled }]}
                  type="button"
                  data-filter-type="category"
                  data-filter-value={cat}
                  aria-pressed="false"
                  aria-disabled={disabled ? 'true' : undefined}
                  tabindex={-1}
                >{cat}</button>
              );
            })}
          </div>
        </div>

        {topics.length > 0 && (
          <div class="blog-filters__row" role="toolbar" aria-label="Filter by topic">
            <span class="blog-filters__label" id="filter-topic-label">Topic</span>
            <div class="blog-filters__scroll" aria-labelledby="filter-topic-label">
              <button class="blog-filter-chip is-active" type="button" data-filter-type="topic" data-filter-value="all" aria-pressed="true" tabindex="0">All</button>
              {topics.map((t) => (
                <button class="blog-filter-chip" type="button" data-filter-type="topic" data-filter-value={t.title} aria-pressed="false" tabindex={-1}>{t.title}</button>
              ))}
            </div>
          </div>
        )}

        <p class="blog-filters__count" aria-live="polite">
          Showing {Math.min(cards.length, POSTS_PER_PAGE)} of {cards.length} posts
        </p>
      </div>
    </section>

    {/* §3 — Post grid ----------------------------------------------------- */}
    <section class="blog-grid-section">
      <div class="blog-grid-section__inner">

        {cards.length > 0 ? (
          <ul class="blog-grid" role="list">
            {cards.map((post, i) => (
              <li
                class="blog-grid__item"
                data-category={post.category ?? ''}
                data-topics={post.topics.length > 0 ? `|${post.topics.map((t) => t.title).join('|')}|` : ''}
              >
                <a href={`/blog/${post.slug}/`} class="blog-index-card">
                  <div class="blog-index-card__img">
                    {post.featuredImage
                      ? <img src={post.featuredImage} alt="" loading={i < 3 ? 'eager' : 'lazy'} />
                      : <div class="blog-index-card__img-fallback" aria-hidden="true" />}
                  </div>
                  <div class="blog-index-card__body">
                    {post.category && <div class="blog-index-card__eyebrow">{post.category}</div>}
                    <h3 class="blog-index-card__title">{post.title}</h3>
                    {post.excerpt && <p class="blog-index-card__excerpt">{post.excerpt}</p>}
                    <div class="blog-index-card__meta">
                      {post.author && <span class="blog-index-card__author">By {post.author}</span>}
                      {post.author && post.dateLabel && <span class="blog-index-card__meta-sep" aria-hidden="true">&middot;</span>}
                      {post.dateLabel && post.publishedDate && (
                        <time datetime={post.publishedDate} class="blog-index-card__date">{post.dateLabel}</time>
                      )}
                    </div>
                    {post.topics.length > 0 && (
                      <div class="blog-index-card__topics">
                        {post.topics.slice(0, 3).map((t, ti) => (
                          <span class="blog-index-card__topic">
                            {t.title}
                            {ti < Math.min(post.topics.length, 3) - 1 && <span class="blog-index-card__topic-sep" aria-hidden="true"> &middot; </span>}
                          </span>
                        ))}
                        {post.topics.length > 3 && (
                          <span class="blog-index-card__topic blog-index-card__topic--more">+{post.topics.length - 3} more</span>
                        )}
                      </div>
                    )}
                  </div>
                </a>
              </li>
            ))}
          </ul>
        ) : (
          <div class="blog-empty">
            <h2 class="blog-empty__title">No posts yet</h2>
            <p class="blog-empty__body">Check back soon, or explore topics.</p>
            <div class="blog-empty__actions">
              <a class="btn btn--std btn--primary has-icon-hover" href="/topics/">Browse topics</a>
            </div>
          </div>
        )}

        {/* §4 — Empty / no-results state (filter-driven, JS toggles) */}
        {cards.length > 0 && (
          <div class="blog-empty" id="blog-empty-filtered" hidden>
            <h2 class="blog-empty__title">No posts match these filters</h2>
            <p class="blog-empty__body">Try clearing a filter or browse all topics.</p>
            <div class="blog-empty__actions">
              <button class="btn btn--std btn--outline blog-empty__clear" type="button">Clear filters</button>
              <a class="btn btn--std btn--primary has-icon-hover" href="/topics/">Browse topics</a>
            </div>
          </div>
        )}
      </div>
    </section>

    {/* §5 — Load more (pagination) ---------------------------------------- */}
    {showLoadMore && (
      <nav class="blog-pagination" aria-label="Blog pagination" data-pagefind-ignore="all">
        <div class="blog-pagination__inner">
          <p class="blog-pagination__status" aria-live="polite">
            Showing {POSTS_PER_PAGE} of {cards.length} posts
          </p>
          <button class="btn btn--std btn--outline blog-pagination__load-more" type="button">Load more posts</button>
        </div>
      </nav>
    )}
  </div>
</BaseLayout>

<style>
  /* ── §1 Hero ──────────────────────────────────────────────────────────── */
  .blog-index-hero {
    width: 100%;
    background: var(--bg-tinted);
    border-bottom: var(--border-width-xs) solid var(--border-subtle);
    padding: var(--space-struct-y-base) var(--space-global-gutter);
  }

  .blog-index-hero__inner {
    margin-inline: auto;
    width: 100%;
    max-width: var(--container-max-shell);
  }

  .blog-index-hero__eyebrow {
    display: block;
    font-family: var(--font-tailor-body-stack);
    font-size: var(--text-card-size-body);
    font-weight: var(--font-weight-semibold);
    text-transform: uppercase;
    letter-spacing: var(--text-eyebrow-ls);
    color: var(--brand-accent-text);
    margin: 0 0 var(--space-global-xs);
  }

  .blog-index-hero__title {
    font-family: var(--font-tailor-heading-stack);
    font-size: var(--text-display-size-h1);
    font-weight: var(--heading-weight-h1);
    line-height: var(--lh-display);
    color: var(--text-heading);
    margin: 0 0 var(--space-global-sm);
  }

  .blog-index-hero__intro {
    font-family: var(--font-tailor-body-stack);
    font-size: var(--text-prose-size-body);
    font-weight: var(--font-weight-regular);
    line-height: var(--lh-body);
    color: var(--text-body-muted);
    max-width: var(--container-max-prose);
    margin: 0;
  }

  /* ── §2 Filter bar ────────────────────────────────────────────────────── */

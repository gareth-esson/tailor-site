---
/**
 * Homepage [B1] — /
 * v2: Teacher-first. 8 sections, 1 layer switch.
 * Surface rhythm: dark → white → alt → white → alt → warm → ground → dark
 * Layer rhythm:   T → T → T → T → T → OtA → T → T
 */
import BaseLayout from '../layouts/BaseLayout.astro';
import TopicsOverviewGrid from '../components/TopicsOverviewGrid.astro';
import QuestionCard from '../components/QuestionCard.astro';
import { getQuestions } from '../lib/content';
import type { QuestionRef } from '../lib/types';

const allQuestions = await getQuestions();

// Featured questions: pick 3 answered questions with post-it scans
const answered = allQuestions.filter((q) => q.body.length > 0 && q.hasPostItScan);
// Fisher-Yates shuffle for unbiased randomisation
for (let i = answered.length - 1; i > 0; i--) {
  const j = Math.floor(Math.random() * (i + 1));
  [answered[i], answered[j]] = [answered[j], answered[i]];
}
const featured: QuestionRef[] = answered.slice(0, 3).map((q) => ({
  id: q.id,
  question: q.question,
  slug: q.slug,
  okayToAskCategory: q.okayToAskCategory,
  contentTags: q.contentTags,
}));

// Hero photograph — conditionally rendered
const heroPhoto = '/images/services/tailor-education-secondary-rse-group-activity.webp' as string | null;

// §2 product screenshot — conditionally rendered
const appScreenshot = '/images/homepage/app-placeholder.svg' as string | null;

// §3 delivery photograph — conditionally rendered
const deliveryPhoto = '/images/services/tailor-education-primary-rse-discussion-circle.webp' as string | null;

// §4 training photograph — conditionally rendered
const trainingPhoto = '/images/services/tailor-education-teachers-reviewing-rse-resources.webp' as string | null;

---

<BaseLayout
  title="Tailor Education — Expert RSE for schools"
  description="Expert RSE resources, training and delivery for schools. Curriculum-aligned lessons, CPD, and the Okay to Ask project — from Tailor Education."
  canonicalPath="/"
>
  <!-- ═══ §1 TEACHER HERO ═══ -->
  <section class="hero-teacher surface--dark" aria-labelledby="hero-heading">
    <div class="hero-teacher__inner">
      <div class={heroPhoto ? '' : 'hero-teacher__text-only'}>
        <p class="preheader hero-teacher__eyebrow">Tailor Education</p>
        <h1 id="hero-heading" class="hero-teacher__title">Expert RSE lessons and training for schools</h1>
        <p class="hero-teacher__subtitle">
          Curriculum-aligned relationships and sex education for UK schools. Written by specialists, built for teachers.
        </p>
        <div class="hero-teacher__actions">
          <a href="/topics" class="btn btn--std btn--primary has-icon-hover">
            Explore RSE lessons
          </a>
          <a href="/services" class="btn btn--std btn--white-outline has-icon-hover">
            Bring Tailor to your school
          </a>
        </div>
      </div>
      {heroPhoto && (
        <div class="hero-photo-wrap hidden lg:block">
          <img src={heroPhoto} alt="Secondary students in a Tailor RSE group session" class="hero-photo" loading="eager" />
        </div>
      )}
    </div>
  </section>

  <!-- ═══ §2 PLATFORM / TAILOR TEACH ═══ -->
  <section class="home-platform" aria-labelledby="platform-heading">
    <div class="home-platform__inner">
      <div class={appScreenshot ? '' : 'home-platform__text-only'}>
        <span class="preheader home-platform__preheader">Tailor Teach</span>
        <h2 id="platform-heading" class="home-platform__title">Expert-authored RSE lessons, ready to teach</h2>
        <p class="home-platform__intro">
          The Tailor Teach app gives your team structured, curriculum-aligned RSE lessons written by subject specialists. Every lesson is ready to deliver — no preparation needed.
        </p>
        <ul class="home-platform__features">
          <li>Expert-authored, curriculum-aligned content</li>
          <li>Structured by topic and key stage</li>
          <li>Built for teacher confidence</li>
          <li>Simple Mode and accessibility built in</li>
        </ul>
        <a href="/topics" class="btn btn--std btn--primary has-icon-hover">
          Explore the lesson library
        </a>
      </div>
      {appScreenshot && (
        <div class="hidden lg:block">
          <img
            src={appScreenshot}
            alt="Screenshot of the Tailor Teach lesson interface"
            class="home-platform__screenshot"
            loading="lazy"
          />
        </div>
      )}
    </div>
  </section>

  <!-- ═══ §3 DELIVERY ═══ -->
  <section class="home-delivery surface--alt" aria-labelledby="delivery-heading">
    <div class="home-delivery__inner">
      {deliveryPhoto && (
        <div class="hidden lg:block">
          <img
            src={deliveryPhoto}
            alt="A Tailor educator leading a primary RSE discussion circle"
            class="home-delivery__photo"
            loading="lazy"
          />
        </div>
      )}
      <div class={deliveryPhoto ? '' : 'home-delivery__text-only'}>
        <span class="preheader home-delivery__preheader">In-school delivery</span>
        <h2 id="delivery-heading" class="home-delivery__title">We deliver RSE in your school</h2>
        <p class="home-delivery__desc">
          Our qualified facilitators come to your school and deliver curriculum-aligned RSE directly. Expert-led, sensitive, age-appropriate. Your school gets lesson delivery, teacher guidance, parent communication, and follow-up.
        </p>
        <ol class="home-delivery__steps">
          <li class="home-delivery__step">
            <span class="home-delivery__step-num" aria-hidden="true">1</span>
            <span class="home-delivery__step-text">Get in touch and tell us what you need</span>
          </li>
          <li class="home-delivery__step">
            <span class="home-delivery__step-num" aria-hidden="true">2</span>
            <span class="home-delivery__step-text">We plan together around your school context</span>
          </li>
          <li class="home-delivery__step">
            <span class="home-delivery__step-num" aria-hidden="true">3</span>
            <span class="home-delivery__step-text">We deliver — and follow up afterwards</span>
          </li>
        </ol>
        <a href="/services" class="btn btn--std btn--primary has-icon-hover">
          Explore delivery options
        </a>
      </div>
    </div>
  </section>

  <!-- ═══ §4 TRAINING & SUPPORT ═══ -->
  <section class="home-training" aria-labelledby="training-heading">
    <div class="home-training__inner">
      <div class={trainingPhoto ? '' : 'home-training__text-only'}>
        <span class="preheader home-training__preheader">CPD &amp; support</span>
        <h2 id="training-heading" class="home-training__title">Training and support for your RSE team</h2>
        <p class="home-training__intro">
          We don't just provide resources — we help your team feel confident, compliant, and supported in delivering RSE.
        </p>
        <p class="home-training__detail">
          CPD workshops, RSE policy development, curriculum mapping across key stages, and DfE statutory alignment — in-school or online.
        </p>
        <div class="home-training__actions">
          <a href="/services/rse-training" class="btn btn--std btn--primary has-icon-hover">
            Explore training options
          </a>
          <a href="/contact" class="btn btn--std btn--outline has-icon-hover">
            Talk to us about support
          </a>
        </div>
      </div>
      {trainingPhoto && (
        <div class="hidden lg:block">
          <img
            src={trainingPhoto}
            alt="Teachers reviewing RSE resources together during CPD"
            class="home-training__photo"
            loading="lazy"
          />
        </div>
      )}
    </div>
  </section>

  <!-- ═══ §5 TRUST SIGNALS ═══ -->
  <section class="home-trust surface--alt" aria-labelledby="trust-heading">
    <div class="home-trust__inner">
      <div class="home-trust__badges-wrap">
        <span class="preheader home-trust__preheader">Frameworks &amp; standards</span>
        <h2 id="trust-heading" class="home-trust__title">Aligned with national and international frameworks</h2>
        <div class="home-trust__badges">
          <div class="trust-badge">
            <span>DfE Statutory RSE Guidance</span>
          </div>
          <div class="trust-badge">
            <span>PSHE Association Programme of Study</span>
          </div>
          <div class="trust-badge">
            <span>UNESCO International Technical Guidance</span>
          </div>
          <div class="trust-badge">
            <span>WHO Standards for Sexuality Education</span>
          </div>
        </div>
      </div>

      <div class="home-trust__quote-wrap">
        <blockquote class="home-trust__quote">
          <p class="home-trust__quote-text">
            "Tailor Education's content is some of the best RSE material I've seen. Thoughtful, inclusive, and genuinely useful."
          </p>
          <div class="home-trust__attribution">
            <cite class="home-trust__cite">PSHE Coordinator</cite>
          </div>
        </blockquote>
        <div class="home-trust__action">
          <a href="/our-approach" class="link-action">See our approach</a>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══ §6 OKAY TO ASK (single OtA layer switch) ═══ -->
  <div class="layer-ota">
    <section class="home-ota" aria-labelledby="ota-heading">
      <div class="home-ota__inner">
        <!-- Beat 1: OtA introduction -->
        <div class="home-ota__intro">
          <img
            src="/assets/ota-wordmark-dark.svg"
            alt="Okay to Ask"
            class="home-ota__wordmark"
            width="160"
            height="28"
          />
          <h2 id="ota-heading" class="home-ota__title">Okay to Ask — honest answers for young people</h2>
          <p class="home-ota__text">
            Real questions from real young people, answered honestly. No judgement, no awkwardness. A free resource from Tailor Education.
          </p>
        </div>

        <!-- Beat 2: Featured question cards -->
        {featured.length > 0 && (
          <div class="home-ota__questions">
            <div class="home-ota__questions-grid">
              {featured.map((q) => (
                <QuestionCard question={q} />
              ))}
            </div>
            <div class="home-ota__questions-more">
              <a href="/questions/" class="btn btn--std btn--outline has-icon-hover w-full sm:w-auto">
                See all questions
              </a>
            </div>
          </div>
        )}

        <!-- Beat 3: Book promotion panel -->
        <div class="home-ota__book-wrap">
          <a href="/book" class="home-ota__book-panel">
            <img
              src="/images/ota-book-cover.webp"
              alt="Okay to Ask book cover"
              class="home-ota__book-cover"
              loading="lazy"
            />
            <div class="home-ota__book-text">
              <span class="home-ota__book-eyebrow">The Okay to Ask book</span>
              <h3 class="home-ota__book-title">The book that answers the questions young people really ask</h3>
              <p class="home-ota__book-desc">Real questions, honest answers, post-it notes and all.</p>
              <span class="link-action">Buy the book</span>
            </div>
          </a>
        </div>
      </div>
    </section>
  </div>

  <!-- ═══ §7 TOPICS OVERVIEW ═══ -->
  <section class="home-topics" aria-labelledby="topics-heading">
    <div class="home-topics__inner">
      <TopicsOverviewGrid />
    </div>
  </section>

  <!-- ═══ §8 CLOSING CTA ═══ -->
  <section class="home-cta surface--dark" aria-labelledby="cta-heading">
    <div class="home-cta__inner">
      <h2 id="cta-heading" class="home-cta__title">Ready to bring expert RSE to your school?</h2>
      <p class="home-cta__subtitle">
        Whether you need lessons, training, or delivery — we're here to help.
      </p>
      <div class="home-cta__actions">
        <a href="/contact" class="btn btn--std btn--primary has-icon-hover">
          Get in touch
        </a>
        <a href="/topics" class="btn btn--std btn--white-outline has-icon-hover">
          Explore lessons
        </a>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  /* ========================================
     Homepage [B1] — Layout Spec v2.0
     Teacher-first. 8 sections. 1 layer switch.
     ======================================== */

  /* --- §1 Teacher hero --- */
  .hero-teacher {
    background-color: var(--hero-tailor-bg);
    padding: var(--space-struct-y-hero) var(--space-global-gutter);
  }

  .hero-teacher__inner {
    max-width: var(--container-max-shell);
    margin: 0 auto;
    width: 100%;
  }

  .hero-teacher__text-only {
    max-width: 38rem;
  }

  .hero-teacher__eyebrow {
    color: var(--text-on-dark-strapline);
    margin: 0 0 var(--space-global-sm);
  }

  .hero-teacher__title {
    font-family: var(--font-tailor-heading-stack);
    font-size: var(--text-display-size-h1);
    font-weight: var(--heading-weight-h1);
    line-height: var(--lh-display);
    color: var(--text-heading-on-dark);
    margin: 0 0 var(--space-global-md);
  }

  .hero-teacher__subtitle {
    font-family: var(--font-tailor-body-stack);
    font-size: var(--text-util-hero-subhead-size);
    font-weight: var(--font-weight-regular);
    line-height: var(--lh-heading-sub);
    color: var(--text-on-dark-strapline);
    margin: 0 0 var(--space-global-lg);
  }

  .hero-teacher__actions {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-global-sm);
  }

  .hero-photo {
    width: 100%;
    height: auto;
    border-radius: var(--radius-lg);
    box-shadow: var(--shadow-lg);
  }

  /* --- §2 Platform --- */
  .home-platform {
    background: var(--bg-surface);
    padding: var(--space-struct-y-base) var(--space-global-gutter);
  }

  .home-platform__inner {
    max-width: var(--container-max-shell);
    margin: 0 auto;
    width: 100%;
  }

  .home-platform__text-only {
    max-width: 38rem;
  }

  .home-platform__preheader {
    color: var(--text-heading-muted);
    margin-bottom: var(--space-global-md);
  }

  .home-platform__title {
    font-family: var(--font-tailor-heading-stack);
    font-size: var(--text-display-size-h2);
    font-weight: var(--heading-weight-h2);
    line-height: var(--lh-heading);
    color: var(--text-heading);
    margin: 0 0 var(--space-global-md);
  }

  .home-platform__intro {
    font-size: var(--text-prose-size-body);
    color: var(--text-body-muted);
    line-height: var(--lh-body);
    max-width: 36rem;
    margin: 0 0 var(--space-global-md);
  }

  .home-platform__features {
    list-style: none;
    padding: 0;
    margin: 0 0 var(--space-global-lg);
    display: flex;
    flex-direction: column;
    gap: var(--space-global-xs);
  }

  .home-platform__features li {
    padding-left: 1.5rem;
    position: relative;
    font-size: var(--text-prose-size-body);
    color: var(--text-body);
    line-height: var(--lh-body);
  }

  .home-platform__features li::before {
    content: '\2713';
    position: absolute;
    left: 0;
    color: var(--brand-primary);
    font-weight: var(--font-weight-bold);
  }

  .home-platform__screenshot {
    width: 100%;
    height: auto;
    border-radius: var(--radius-md);
    box-shadow: var(--shadow-lg);
    border: var(--border-width-xs) solid var(--border-subtle);
  }

  /* --- §3 Delivery --- */
  .home-delivery {
    padding: var(--space-struct-y-base) var(--space-global-gutter);
  }

  .home-delivery__inner {
    max-width: var(--container-max-shell);
    margin: 0 auto;
    width: 100%;
  }

  .home-delivery__text-only {
    max-width: 38rem;
  }

  .home-delivery__photo {
    width: 100%;
    height: auto;
    border-radius: var(--radius-lg);
    box-shadow: var(--shadow-md);
  }

  .home-delivery__preheader {
    color: var(--text-heading-muted);
    margin-bottom: var(--space-global-xs);
  }

  .home-delivery__title {
    font-family: var(--font-tailor-heading-stack);
    font-size: var(--text-display-size-h2);
    font-weight: var(--heading-weight-h2);
    line-height: var(--lh-heading);
    color: var(--text-heading);
    margin: 0 0 var(--space-global-md);
  }

  .home-delivery__desc {
    font-size: var(--text-prose-size-body);
    color: var(--text-body-muted);
    line-height: var(--lh-body);
    max-width: 34rem;
    margin: 0 0 var(--space-global-lg);
  }

  .home-delivery__steps {
    list-style: none;
    padding: 0;
    margin: 0 0 var(--space-global-lg);
    display: flex;
    flex-direction: column;
    gap: var(--space-global-md);
  }

  .home-delivery__step {
    display: flex;
    align-items: flex-start;
    gap: var(--space-global-sm);
  }

  .home-delivery__step-num {
    width: 1.5rem;
    height: 1.5rem;
    border-radius: var(--radius-circle);
    background: var(--brand-primary);
    color: var(--text-on-dark);
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    font-size: 0.75rem;
    font-weight: var(--font-weight-bold);
  }

  .home-delivery__step-text {
    font-size: var(--text-card-size-body);
    color: var(--text-body-muted);
  }

  /* --- §4 Training & support --- */
  .home-training {
    background: var(--bg-surface);
    padding: var(--space-struct-y-base) var(--space-global-gutter);
  }

  .home-training__inner {
    max-width: var(--container-max-shell);
    margin: 0 auto;
    width: 100%;
  }

  .home-training__text-only {
    max-width: 38rem;
  }

  .home-training__preheader {
    color: var(--text-heading-muted);
    margin-bottom: var(--space-global-xs);
  }

  .home-training__title {
    font-family: var(--font-tailor-heading-stack);
    font-size: var(--text-display-size-h2);
    font-weight: var(--heading-weight-h2);
    line-height: var(--lh-heading);
    color: var(--text-heading);
    margin: 0 0 var(--space-global-md);
  }

  .home-training__intro {
    font-size: var(--text-prose-size-body);
    color: var(--text-body-muted);
    line-height: var(--lh-body);
    max-width: 34rem;
    margin: 0 0 var(--space-global-md);
  }

  .home-training__detail {
    font-size: var(--text-card-size-body);
    color: var(--text-body-muted);
    line-height: var(--lh-body);
    max-width: 34rem;
    margin: 0 0 var(--space-global-lg);
  }

  .home-training__actions {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-global-sm);
  }

  .home-training__photo {
    width: 100%;
    height: auto;
    border-radius: var(--radius-lg);
    box-shadow: var(--shadow-md);
  }

  /* --- §5 Trust signals --- */
  .home-trust {
    padding: var(--space-struct-y-base) var(--space-global-gutter);
  }

  .home-trust__inner {
    max-width: var(--container-max-shell);
    margin: 0 auto;
    width: 100%;
  }

  .home-trust__badges-wrap {
    text-align: center;
    margin-bottom: var(--space-global-xl);
  }

  .home-trust__preheader {
    color: var(--text-heading-muted);
    margin-bottom: var(--space-global-xs);
  }

  .home-trust__title {
    font-family: var(--font-tailor-heading-stack);
    font-size: var(--text-display-size-h3);
    font-weight: var(--heading-weight-h2);
    line-height: var(--lh-heading);
    color: var(--text-heading);
    margin: 0 0 var(--space-global-lg);
  }

  .home-trust__badges {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    align-items: center;
    gap: var(--space-global-xl);
  }

  .home-trust__quote-wrap {
    max-width: var(--container-max-prose);
    margin: var(--space-global-xl) auto 0;
    text-align: center;
  }

  .home-trust__quote {
    margin: 0;
    padding: 0;
    border: 0;
  }

  .home-trust__quote-text {
    font-family: var(--font-tailor-body-stack);
    font-size: var(--text-display-size-quote);
    font-weight: var(--font-weight-regular);
    font-style: italic;
    line-height: var(--lh-heading-sub);
    color: var(--text-heading);
    margin: 0 0 var(--space-global-md);
  }

  .home-trust__attribution {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: var(--space-global-sm);
  }

  .home-trust__cite {
    font-family: var(--font-tailor-body-stack);
    font-size: var(--text-card-size-body);
    font-weight: var(--font-weight-medium);
    color: var(--text-body-muted);
    font-style: normal;
  }

  .home-trust__action {
    margin-top: var(--space-global-lg);
  }

  /* --- §6 Okay to Ask --- */
  .home-ota {
    padding: var(--space-struct-y-base) var(--space-global-gutter);
    position: relative;
    overflow: hidden;
    background: var(--bg-surface-alt);
  }

  .home-ota__inner {
    max-width: var(--container-max-reading-wide);
    margin: 0 auto;
    width: 100%;
    position: relative;
    z-index: 2;
  }

  .home-ota__intro {
    text-align: center;
    margin-bottom: var(--space-global-2xl);
  }

  .home-ota__wordmark {
    display: block;
    width: 10rem;
    height: auto;
    margin: 0 auto var(--space-global-lg);
  }

  .home-ota__title {
    font-family: var(--font-ota-heading-stack);
    font-size: var(--text-display-size-h2);
    font-weight: var(--heading-ota-weight-h2);
    line-height: var(--lh-heading);
    color: var(--text-ota-heading);
    margin: 0 0 var(--space-global-md);
  }

  .home-ota__text {
    font-family: var(--font-ota-body-stack);
    font-size: var(--text-display-size-body);
    font-weight: var(--font-weight-regular);
    line-height: var(--lh-body);
    color: var(--text-ota-muted);
    margin: 0 auto;
  }

  /* Book panel */
  .home-ota__book-wrap {
    margin-bottom: 0;
  }

  .home-ota__book-panel {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-global-xl);
    padding: var(--space-global-xl);
    background: var(--bg-ota-paper-panel);
    border-radius: var(--radius-lg);
    box-shadow: var(--shadow-md);
    text-decoration: none;
    color: inherit;
    transition: box-shadow var(--transition-duration) var(--transition-easing),
                transform var(--transition-duration) var(--transition-easing);
  }

  .home-ota__book-panel:hover {
    box-shadow: var(--shadow-lg);
    transform: translateY(-2px);
  }

  .home-ota__book-cover {
    flex-shrink: 0;
    width: 10rem;
    border-radius: var(--radius-sm);
    box-shadow: var(--book-cover-shadow);
  }

  .home-ota__book-text {
    display: flex;
    flex-direction: column;
    gap: var(--space-global-sm);
    text-align: center;
  }

  .home-ota__book-eyebrow {
    font-size: var(--text-util-preheader-size);
    font-weight: var(--font-weight-semibold);
    letter-spacing: var(--text-util-preheader-ls);
    text-transform: uppercase;
    color: var(--text-ota-muted);
  }

  .home-ota__book-title {

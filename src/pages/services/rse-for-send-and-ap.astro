---
/**
 * Service page [C5] — /services/rse-for-send-and-ap
 * RSE for SEND & AP (Circuits). Tailor layer.
 * Distinct workbook-based product line with self-paced delivery.
 */
import BaseLayout from '../../layouts/BaseLayout.astro';
import CtaServiceEnquiry from '../../components/CtaServiceEnquiry.astro';
import TopicsOverviewGrid from '../../components/TopicsOverviewGrid.astro';
import ServicePageStyles from '../../components/ServicePageStyles.astro';
import { getBlogPosts } from '../../lib/content';

const allPosts = await getBlogPosts();
const relatedPosts = allPosts.filter((p) => p.serviceLink === 'delivery').slice(0, 3);
---

<BaseLayout
  title="RSE for SEND & AP (Circuits) — RSE for Schools | Tailor Education"
  description="Workbook-based RSE designed for SEND and alternative provision settings — self-paced, simplified keynotes, and space for students to process at their own speed."
  canonicalPath="/services/rse-for-send-and-ap/"
  jsonLd={{
    '@context': 'https://schema.org',
    '@type': 'Service',
    name: 'RSE for SEND & AP (Circuits)',
    description: 'Workbook-based RSE designed for SEND and alternative provision settings.',
    provider: { '@type': 'Organization', name: 'Tailor Education', url: 'https://tailoreducation.org.uk' },
  }}
>
  <article class="service-page" data-pagefind-body>

    <!-- §1 Hero -->
    <header class="service-page__header">
      <div class="mx-auto w-full max-w-[var(--container-max-shell)] px-[var(--space-global-gutter)] py-[var(--space-global-xl)]">
        <span class="service-page__eyebrow">Services · RSE Delivery</span>
        <h1 class="service-page__title">RSE for SEND & alternative provision</h1>
        <p class="service-page__subtitle">
          Circuits — workbook-based RSE designed for SEND and AP settings, where students learn at their own pace with simplified content and space to process.
        </p>
      </div>
    </header>

    <!-- §2 Service detail -->
    <section class="service-page__detail">
      <div class="mx-auto w-full max-w-[var(--container-max-prose)] px-[var(--space-global-gutter)] py-[var(--space-struct-y-base)]">

        <!-- [IMAGE PLACEHOLDER: Circuits workbook — showing the workbook format with doodle/game space, simplified layout] -->
        <div class="service-page__image-placeholder" style="margin-bottom: var(--space-global-lg)">
          Image — Circuits workbook (showing the physical workbook format with doodle/game space and simplified keynotes)
        </div>

        <div class="service-page__detail-stack">

          <div class="service-page__detail-block">
            <h2 class="service-page__section-title">What this service is</h2>
            <p>Circuits is a workbook-based RSE programme designed specifically for students in SEND and alternative provision settings. It recognises that mainstream RSE delivery doesn't always work for every learner — some students need more time, simpler language, and a format they can engage with at their own speed.</p>
            <p>Each student receives a physical workbook that guides them through the session content. The workbooks use simplified keynotes, clear visuals, and built-in doodle and game space that gives students a way to process without having to talk or write continuously.</p>
          </div>

          <div class="service-page__detail-block">
            <h2 class="service-page__section-title">Who it's for</h2>
            <p>Special schools, SEND units within mainstream schools, alternative provision settings, and PRUs. Schools where mainstream RSE resources don't meet the needs of their learners. Settings where students benefit from self-paced delivery, concrete language, and physical materials they can keep and return to.</p>
          </div>

          <div class="service-page__detail-block">
            <h2 class="service-page__section-title">What's included</h2>
            <ul>
              <li>Physical workbooks for every student — designed for accessibility and engagement</li>
              <li>Simplified keynote presentations for the educator to deliver alongside the workbooks</li>
              <li>Self-paced delivery — students work through their workbooks at their own speed</li>
              <li>Built-in doodle and game space for processing and decompression</li>
              <li>Pre-visit consultation to adapt content to your students' needs and abilities</li>
              <li>Delivery by a specialist educator experienced in SEND and AP contexts</li>
              <li>All content aligned to DfE statutory guidance, adapted for accessibility</li>
            </ul>
          </div>

          <div class="service-page__detail-block">
            <h2 class="service-page__section-title">What schools get</h2>
            <p>RSE delivery that actually works for your students. Workbooks students can keep and revisit. A session format that reduces anxiety and sensory overload while still covering essential content. Staff who see how RSE can be delivered effectively in their setting, and a framework they can build on.</p>
          </div>

        </div>
      </div>
    </section>

    <!-- §4 CTA [A13] — primary -->
    <CtaServiceEnquiry serviceName="RSE for SEND and AP" serviceParam="RSE for SEND and AP" />

    <!-- §5 Testimonial -->
    <section class="service-page__testimonial">
      <div class="mx-auto w-full max-w-[var(--container-max-prose)] px-[var(--space-global-gutter)] py-[var(--space-struct-y-base)]">
        <blockquote class="testimonial-pullquote">
          <p class="testimonial-pullquote__text">"The workbooks were brilliant. Students who normally disengage completely during PSHE were drawing, writing, and asking questions. One student said it was the first lesson where they didn't feel like they were being talked at."</p>
          <footer class="testimonial-pullquote__footer">
            <span class="testimonial-pullquote__source">— SENCo, special school</span>
            <a href="/testimonials" class="testimonial-pullquote__link">Read more testimonials</a>
          </footer>
        </blockquote>
      </div>
    </section>

    <!-- §6 Related blog posts -->
    {relatedPosts.length > 0 && (
      <section class="service-page__blog">
        <div class="mx-auto w-full max-w-[var(--container-max-shell)] px-[var(--space-global-gutter)] py-[var(--space-struct-y-base)]">
          <h2 class="service-page__section-title" style="margin-bottom: var(--space-global-md)">Related articles</h2>
          <div class="service-page__blog-grid">
            {relatedPosts.map((bp) => (
              <a href={`/blog/${bp.slug}`} class="card service-blog-card">
                {bp.featuredImage && (
                  <div class="service-blog-card__img">
                    <img src={bp.featuredImage} alt={bp.title} loading="lazy" />
                  </div>
                )}
                <div class="card__body">
                  {bp.targetAudience && <div class="card__eyebrow">{bp.targetAudience}</div>}
                  <div class="card__title">{bp.title}</div>
                  {bp.author && <div class="service-blog-card__author">By {bp.author}</div>}
                </div>
              </a>
            ))}
          </div>
        </div>
      </section>
    )}

    <!-- §7 Topics overview grid -->
    <TopicsOverviewGrid />

    <!-- §8 CTA [A13] — repeated -->
    <CtaServiceEnquiry serviceName="RSE for SEND and AP" serviceParam="RSE for SEND and AP" variant="alt" />

  </article>
  <ServicePageStyles />
</BaseLayout>

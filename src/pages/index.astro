---
/**
 * Homepage [B1] — /
 * v2: Teacher-first. 8 sections, 1 layer switch.
 * Surface rhythm: dark → white → alt → white → alt → white → alt → dark
 * Layer rhythm:   T → T → T → T → T → OtA → T → T
 */
import BaseLayout from '../layouts/BaseLayout.astro';
import QuestionCard from '../components/QuestionCard.astro';
import { getQuestions, getLandingPages, getTestimonials } from '../lib/content';
import { getTopicIllustrationPath } from '../lib/topic-illustrations';
import type { QuestionRef } from '../lib/types';

const allQuestions = await getQuestions();
const allTestimonials = await getTestimonials();
const homeTestimonial = allTestimonials.find((t) => t.name === 'Sara Stafford') ?? allTestimonials[0] ?? null;

// Featured questions: pick 3 answered questions with post-it scans
const answered = allQuestions.filter((q) => q.body.length > 0 && q.hasPostItScan);
// Fisher-Yates shuffle for unbiased randomisation
for (let i = answered.length - 1; i > 0; i--) {
  const j = Math.floor(Math.random() * (i + 1));
  [answered[i], answered[j]] = [answered[j], answered[i]];
}
const featured: QuestionRef[] = answered.slice(0, 3).map((q) => ({
  id: q.id,
  question: q.question,
  slug: q.slug,
  okayToAskCategory: q.okayToAskCategory,
  contentTags: q.contentTags,
}));

// §7 Topic carousel data
const landingPages = await getLandingPages();
const categoryTokenMap: Record<string, string> = {
  'Relationships': 'relationships',
  'Sex & Sexual Health': 'sexual-health',
  'Puberty & The Body': 'puberty',
  'Identity & Diversity': 'identity',
  'Online Safety & Media': 'online-safety',
  'Safety & Safeguarding': 'safety',
  'Health & Wellbeing': 'wellbeing',
};

// Hero photograph — conditionally rendered
const heroPhoto = '/images/services/tailor-education-secondary-rse-group-activity.webp' as string | null;

// §2 product screenshot — conditionally rendered
const appScreenshot = '/images/homepage/tailor-teach-app-screenshot.webp' as string | null;

// §3 delivery photograph — conditionally rendered
const deliveryPhoto = '/images/services/tailor-education-primary-rse-discussion-circle.webp' as string | null;

// §4 training photograph — conditionally rendered
const trainingPhoto = '/images/services/tailor-education-teachers-reviewing-rse-resources.webp' as string | null;

---

<BaseLayout
  title="Tailor Education — RSE workshops, training and delivery for UK schools"
  description="Expert RSE for UK primary and secondary schools. In-school teaching, CPD, and the Okay to Ask book."
  canonicalPath="/"
>
  <!-- ═══ §1 TEACHER HERO ═══ -->
  <section class="hero-teacher surface--dark" aria-labelledby="hero-heading">
    <div class="hero-teacher__inner">
      <div class="hero-teacher__text">
        <p class="preheader hero-teacher__eyebrow">Tailor Education</p>
        <h1 id="hero-heading" class="hero-teacher__title">Expert RSE for UK schools</h1>
        <p class="hero-teacher__subtitle">
          In-school RSE teaching, plus CPD for the teams that take it on themselves.
        </p>
        <div class="hero-teacher__actions">
          <a href="/services" class="btn btn--std btn--primary has-icon-hover w-full sm:w-auto">
            Explore our services
          </a>
          <a href="/topics" class="btn btn--std btn--tint has-icon-hover w-full sm:w-auto">
            Preview the lesson library
          </a>
        </div>
      </div>
      {heroPhoto && (
        <div class="hero-photo-wrap hidden lg:block">
          <img src={heroPhoto} alt="Secondary students in a Tailor RSE group session" class="hero-photo" loading="eager" />
        </div>
      )}
    </div>
  </section>

  <!-- ═══ §2 IN-SCHOOL DELIVERY (was §3) ═══ -->
  <section class="home-delivery" aria-labelledby="delivery-heading">
    <div class="home-delivery__inner">
      {deliveryPhoto && (
        <div class="hidden lg:block">
          <img
            src={deliveryPhoto}
            alt="A Tailor educator leading a primary RSE discussion circle"
            class="home-delivery__photo"
            loading="lazy"
          />
        </div>
      )}
      <div class="home-delivery__text">
        <span class="preheader home-delivery__preheader">In-school delivery</span>
        <h2 id="delivery-heading" class="home-delivery__title">RSE, taught directly in your school</h2>
        <p class="home-delivery__desc">
          Most of what Tailor does is direct teaching. A school that wants an external specialist on RSE books a Tailor educator, and one of us takes the lessons. We work across primary, secondary, SEND and alternative provision.
        </p>
        <p class="home-delivery__desc">
          Every lesson is written for your class. We'll ask your PSHE lead what we need to know going in — a recent safeguarding issue, a topic that needs more time, a pupil to plan around — and shape the session around what you tell us. After we've taught it, your staff get a written debrief and notes they can use the next week.
        </p>
        <ol class="home-delivery__steps">
          <li class="home-delivery__step">
            <span class="home-delivery__step-num" aria-hidden="true">1</span>
            <span class="home-delivery__step-text">You tell us what you need</span>
          </li>
          <li class="home-delivery__step">
            <span class="home-delivery__step-num" aria-hidden="true">2</span>
            <span class="home-delivery__step-text">We plan with your PSHE lead</span>
          </li>
          <li class="home-delivery__step">
            <span class="home-delivery__step-num" aria-hidden="true">3</span>
            <span class="home-delivery__step-text">We teach the lesson and leave you with notes</span>
          </li>
        </ol>
        <a href="/services" class="btn btn--std btn--primary has-icon-hover w-full sm:w-auto">
          Explore delivery options
        </a>
      </div>
    </div>
  </section>

  <!-- ═══ §3 TRAINING & SUPPORT (was §4) ═══ -->
  <section class="home-training surface--alt" aria-labelledby="training-heading">
    <div class="home-training__inner">
      <div class="home-training__text">
        <span class="preheader home-training__preheader">Training and CPD</span>
        <h2 id="training-heading" class="home-training__title">Help your team teach this with confidence</h2>
        <p class="home-training__intro">
          RSE is hard to teach well if you haven't been trained in it. Most teaching teams haven't. That gap shows up the moment a year 9 puts their hand up with something you didn't prep for, or when the parent email arrives the day after a contentious topic.
        </p>
        <p class="home-training__detail">
          Our CPD is built around what we use ourselves in classrooms — the subject knowledge, the strategies for the harder conversations, the read of the statutory guidance that lets a head of PSHE plan a year of RSE without panic-checking the document every term. Sessions run in your school or online, around the school calendar.
        </p>
        <div class="home-training__actions">
          <a href="/services/rse-training" class="btn btn--std btn--primary has-icon-hover w-full sm:w-auto">
            Explore training
          </a>
          <a href="/contact" class="btn btn--std btn--tint has-icon-hover w-full sm:w-auto">
            Talk to us about support
          </a>
        </div>
      </div>
      {trainingPhoto && (
        <div class="hidden lg:block">
          <img
            src={trainingPhoto}
            alt="Teachers reviewing RSE resources together during CPD"
            class="home-training__photo"
            loading="lazy"
          />
        </div>
      )}
    </div>
  </section>

  <!-- ═══ §4 TAILOR TEACH (was §2; coming-soon framing) ═══ -->
  <section class="home-platform" aria-labelledby="platform-heading">
    <div class="home-platform__inner">
      <div class="home-platform__text">
        <span class="preheader home-platform__preheader">Tailor Teach · Coming soon</span>
        <h2 id="platform-heading" class="home-platform__title">A lesson library for teaching teams</h2>
        <p class="home-platform__intro">
          Tailor Teach is what we're building for the teams who want to take RSE on themselves. The lessons inside are written by Tailor specialists and mapped to the DfE statutory guidance and the PSHE Association Programme of Study. The browse layer is live today. The cloning and adaptation tools are on the way.
        </p>
        <ul class="home-platform__features">
          <li>Lessons written by practising RSE specialists</li>
          <li>Mapped to DfE and PSHE Association frameworks</li>
          <li>Browse by topic or key stage</li>
          <li>Simple Mode and accessibility built in</li>
        </ul>
        <a href="/topics" class="btn btn--std btn--primary has-icon-hover w-full sm:w-auto">
          Browse the topic library
        </a>
      </div>
      {appScreenshot && (
        <div class="hidden lg:block">
          <img
            src={appScreenshot}
            alt="Screenshot of the Tailor Teach lesson interface"
            class="home-platform__screenshot"
            loading="lazy"
          />
        </div>
      )}
    </div>
  </section>

  <!-- ═══ §5 TRUST SIGNALS ═══ -->
  <section class="home-trust surface--alt" aria-labelledby="trust-heading">
    <div class="home-trust__inner">
      <div class="home-trust__badges-wrap">
        <span class="preheader home-trust__preheader">Frameworks and standards</span>
        <h2 id="trust-heading" class="home-trust__title">Aligned with the guidance schools are held to</h2>
        <div class="home-trust__badges">
          <div class="trust-badge">
            <span>DfE Statutory RSE Guidance</span>
          </div>
          <div class="trust-badge">
            <span>PSHE Association Programme of Study</span>
          </div>
          <div class="trust-badge">
            <span>UNESCO International Technical Guidance</span>
          </div>
          <div class="trust-badge">
            <span>WHO Standards for Sexuality Education</span>
          </div>
        </div>
      </div>

      {homeTestimonial && (
      <div class="home-trust__quote-wrap">
        <blockquote class="home-trust__quote">
          <p class="home-trust__quote-text">
            "{homeTestimonial.quote}"
          </p>
          <div class="home-trust__attribution">
            <cite class="home-trust__cite">
              {[homeTestimonial.name, homeTestimonial.role, homeTestimonial.organisation].filter(Boolean).join(', ')}
            </cite>
          </div>
        </blockquote>
        <div class="home-trust__action">
          <a href="/our-approach" class="btn btn--std btn--tint has-icon-hover w-full sm:w-auto">See our approach</a>
        </div>
      </div>
      )}
    </div>
  </section>

  <!-- ═══ §5.5 SELECTED PROJECTS ═══ -->
  <section class="home-projects" aria-labelledby="projects-heading">
    <div class="home-projects__inner">
      <span class="preheader home-projects__preheader">Selected projects</span>
      <h2 id="projects-heading" class="home-projects__title">We also work outside schools</h2>
      <p class="home-projects__body">
        We work with museums, universities, drama schools and the third sector on RSE projects for adults and young people in different settings. The sessions and workshops we've delivered for these partners feed directly back into what we teach in classrooms.
      </p>

      <ul class="home-projects__logos" role="list">
        <li class="home-projects__logo-item">
          {/* British Red Cross — emblem is protected under the Geneva
              Conventions Act 1957; must render in its authorised red.
              No monochrome filter is applied. */}
          <img src="/assets/logos/british-red-cross.svg" alt="The British Red Cross" class="home-projects__logo home-projects__logo--colour" loading="lazy" />
        </li>
        <li class="home-projects__logo-item">
          {/* Square logos under-read at equal height against wide logos;
              taller modifier balances the row's optical weight. */}
          <img src="/assets/logos/somerset-house.svg" alt="Somerset House" class="home-projects__logo home-projects__logo--square" loading="lazy" />
        </li>
        <li class="home-projects__logo-item">
          <img src="/assets/logos/kings-college-london.svg" alt="King's College London" class="home-projects__logo" loading="lazy" />
        </li>
        <li class="home-projects__logo-item">
          <img src="/assets/logos/british-museum.svg" alt="The British Museum" class="home-projects__logo" loading="lazy" />
        </li>
        <li class="home-projects__logo-item">
          <img src="/assets/logos/rada.svg" alt="Royal Academy of Dramatic Art" class="home-projects__logo" loading="lazy" />
        </li>
        <li class="home-projects__logo-item">
          <img src="/assets/logos/tate-modern.svg" alt="Tate Modern" class="home-projects__logo" loading="lazy" />
        </li>
      </ul>

      <div class="home-projects__action">
        <a href="/blog/category/our-work" class="btn btn--std btn--tint has-icon-hover w-full sm:w-auto">
          See our projects
        </a>
      </div>
    </div>
  </section>

  <!-- ═══ §6 OKAY TO ASK (single OtA layer switch) ═══ -->
  <div class="layer-ota">
    <section class="home-ota" aria-labelledby="ota-heading">
      <div class="home-ota__inner">
        <!-- Beat 1: OtA introduction -->
        <div class="home-ota__intro">
          <img
            src="/assets/ota-wordmark-coral.svg"
            alt="Okay to Ask"
            class="home-ota__wordmark"
            width="160"
            height="28"
          />
          <h2 id="ota-heading" class="home-ota__title">Honest answers to the questions young people ask</h2>
          <p class="home-ota__text">
            Okay to Ask started as a stack of post-its. Anonymous questions, written by pupils at the end of lessons, who wanted a proper answer but didn't want to put their name on it. We grouped the repeats, and an RSE specialist wrote the answers. The site is free to read, and there's a book now, too.
          </p>
        </div>

        <!-- Beat 2: Featured question cards -->
        {featured.length > 0 && (
          <div class="home-ota__questions">
            <div class="home-ota__questions-grid">
              {featured.map((q) => (
                <QuestionCard question={q} />
              ))}
            </div>
            <div class="home-ota__questions-more">
              <a href="/questions/" class="btn btn--std btn--tint has-icon-hover w-full sm:w-auto">
                See all questions
              </a>
            </div>
          </div>
        )}

        <!-- Beat 3: Book promotion panel -->
        <div class="home-ota__book-wrap">
          <a href="/book" class="home-ota__book-panel">
            <img
              src="/images/ota-book-cover.webp"
              alt="Okay to Ask book cover"
              class="home-ota__book-cover"
              loading="lazy"
            />
            <div class="home-ota__book-text">
              <span class="home-ota__book-eyebrow">The Okay to Ask book</span>
              <h3 class="home-ota__book-title">The book that answers the questions young people send in</h3>
              <p class="home-ota__book-desc">The original post-it notes with the answers written out in full.</p>
              <span class="link-action">Buy the book</span>
            </div>
          </a>
        </div>
      </div>
    </section>
  </div>

  <!-- ═══ §7 TOPICS CAROUSEL ═══ -->
  <section class="home-topics" aria-labelledby="topics-heading">
    <div class="home-topics__inner">
      <div class="home-topics__header">
        <h2 id="topics-heading" class="home-topics__title">Topics we cover</h2>
        <p class="home-topics__intro">
          Expert-written RSE content across {landingPages.length} curriculum-aligned topics.
        </p>
      </div>

      <div class="home-topics__track">
        {landingPages.map((lp) => {
          const token = categoryTokenMap[lp.category || ''] || 'relationships';
          const illustration = getTopicIllustrationPath(lp.slug);
          return (
            <a href={`/topics/${lp.slug}`} class="home-topics__card" style={`--cat-color: var(--cat-${token})`}>
              <div class="home-topics__card-illus">
                {illustration && <img src={illustration} alt="" loading="lazy" />}
              </div>
              <span class="home-topics__card-category">{lp.category}</span>
              <span class="home-topics__card-title">{lp.title}</span>
            </a>
          );
        })}
        <a href="/topics/" class="home-topics__card home-topics__card--all">
          <span class="home-topics__card-title">View all topics</span>
          <span class="link-action">Browse the full library</span>
        </a>
      </div>

      <div class="home-topics__nav" aria-hidden="true">
        <button class="home-topics__arrow home-topics__arrow--prev" type="button" aria-label="Scroll left" disabled>
          <svg width="20" height="20" viewBox="0 0 20 20" fill="none"><path d="M12.5 15L7.5 10L12.5 5" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
        </button>
        <button class="home-topics__arrow home-topics__arrow--next" type="button" aria-label="Scroll right">
          <svg width="20" height="20" viewBox="0 0 20 20" fill="none"><path d="M7.5 15L12.5 10L7.5 5" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
        </button>
      </div>
    </div>
  </section>

  <!-- ═══ §8 CLOSING CTA ═══ -->
  <section class="home-cta surface--dark" aria-labelledby="cta-heading">
    <div class="home-cta__inner">
      <h2 id="cta-heading" class="home-cta__title">Want to talk about RSE at your school?</h2>
      <p class="home-cta__subtitle">
        Tell us where you're starting from, and we'll work out what Tailor can do.
      </p>
      <div class="home-cta__actions">
        <a href="/contact" class="btn btn--std btn--primary has-icon-hover w-full sm:w-auto">
          Get in touch
        </a>
        <a href="/services" class="btn btn--std btn--tint has-icon-hover w-full sm:w-auto">
          Explore services
        </a>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  /* ========================================
     Homepage [B1] — Layout Spec v2.0
     Teacher-first. 8 sections. 1 layer switch.
     ======================================== */

  /* --- §1 Teacher hero ---
     Full-bleed split at lg+: text cell shell-aligned on left, image
     cell bleeds to viewport's right edge and fills the section height
     (image cropped via object-fit: cover). Below lg the image is
     hidden (existing .hidden.lg:block) and the text fills the width. */
  .hero-teacher {
    background-color: var(--hero-tailor-bg);
  }

  .hero-teacher__inner {
    width: 100%;
    display: grid;
    grid-template-columns: 1fr;
  }

  .hero-teacher__text {
    max-width: var(--container-max-hero-text);
    padding: var(--space-struct-y-hero) var(--space-global-gutter);
    padding-left: max(
      var(--space-global-gutter),
      calc((100vw - var(--container-max-shell)) / 2)
    );
  }

  .hero-teacher__eyebrow {
    color: var(--text-on-dark-strapline);
    margin: 0 0 var(--space-global-sm);
  }

  .hero-teacher__title {
    font-family: var(--font-tailor-heading-stack);
    font-size: var(--text-display-size-h1);
    font-weight: var(--heading-weight-h1);
    line-height: var(--lh-display);
    color: var(--text-heading-on-dark);
    margin: 0 0 var(--space-global-md);
  }

  .hero-teacher__subtitle {
    font-family: var(--font-tailor-body-stack);
    font-size: var(--text-util-hero-subhead-size);
    font-weight: var(--font-weight-regular);
    line-height: var(--lh-heading-sub);
    color: var(--text-on-dark-strapline);
    margin: 0 0 var(--space-global-lg);
  }

  .hero-teacher__actions {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-global-sm);
  }

  .hero-photo-wrap {
    /* Grid cell; image fills it. */
    min-height: 100%;
  }

  .hero-photo {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  /* --- §2 Platform --- */
  .home-platform {
    background: var(--bg-page);
    padding: var(--space-struct-y-base) var(--space-global-gutter);
  }

  .home-platform__inner {
    max-width: var(--container-max-shell);
    margin: 0 auto;
    width: 100%;
  }

  .home-platform__text {
    max-width: var(--container-max-text-col);
  }

  .home-platform__preheader {
    color: var(--text-heading-muted);
    margin-bottom: var(--space-global-md);
  }

  .home-platform__title {
    font-family: var(--font-tailor-heading-stack);
    font-size: var(--text-display-size-h2);
    font-weight: var(--heading-weight-h2);
    line-height: var(--lh-heading);
    color: var(--text-heading);
    margin: 0 0 var(--space-global-md);
  }

  .home-platform__intro {
    font-size: var(--text-prose-size-body);
    color: var(--text-body-muted);
    line-height: var(--lh-body);
    margin: 0 0 var(--space-global-md);
  }

  .home-platform__features {
    list-style: none;
    padding: 0;
    margin: 0 0 var(--space-global-lg);
    display: flex;
    flex-direction: column;
    gap: var(--space-global-xs);
  }

  .home-platform__features li {
    padding-left: var(--space-global-md);
    position: relative;
    font-size: var(--text-prose-size-body);
    color: var(--text-body);
    line-height: var(--lh-body);
  }

  .home-platform__features li::before {
    content: '\2713';
    position: absolute;
    left: 0;
    color: var(--brand-primary);
    font-weight: var(--font-weight-bold);
  }

  .home-platform__screenshot {
    width: 100%;
    height: auto;
    border-radius: var(--radius-md);
    box-shadow: var(--shadow-lg);
    border: var(--border-width-xs) solid var(--border-subtle);
  }

  /* --- §3 Delivery --- */
  .home-delivery {
    padding: var(--space-struct-y-base) var(--space-global-gutter);
  }

  .home-delivery__inner {
    max-width: var(--container-max-shell);
    margin: 0 auto;
    width: 100%;
  }

  .home-delivery__text {
    max-width: var(--container-max-text-col);
  }

  .home-delivery__photo {
    width: 100%;
    height: auto;
    border-radius: var(--radius-lg);
    box-shadow: var(--shadow-md);
  }

  .home-delivery__preheader {
    color: var(--text-heading-muted);
    margin-bottom: var(--space-global-xs);
  }

  .home-delivery__title {
    font-family: var(--font-tailor-heading-stack);
    font-size: var(--text-display-size-h2);
    font-weight: var(--heading-weight-h2);
    line-height: var(--lh-heading);
    color: var(--text-heading);
    margin: 0 0 var(--space-global-md);
  }

  .home-delivery__desc {
    font-size: var(--text-prose-size-body);
    color: var(--text-body-muted);
    line-height: var(--lh-body);
    margin: 0 0 var(--space-global-lg);
  }

  .home-delivery__steps {
    list-style: none;
    padding: 0;
    margin: 0 0 var(--space-global-lg);
    display: flex;
    flex-direction: column;
    gap: var(--space-global-md);
  }

  .home-delivery__step {
    display: flex;
    align-items: flex-start;
    gap: var(--space-global-sm);
  }

  .home-delivery__step-num {
    width: 1.5rem;
    height: 1.5rem;
    border-radius: var(--radius-circle);
    background: var(--brand-primary);
    color: var(--text-on-dark);
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    font-size: 0.75rem;
    font-weight: var(--font-weight-bold);
  }

  .home-delivery__step-text {
    font-size: var(--text-card-size-body);
    color: var(--text-body-muted);
  }

  /* --- §4 Training & support --- */
  .home-training {
    background: var(--bg-page);
    padding: var(--space-struct-y-base) var(--space-global-gutter);
  }

  .home-training__inner {
    max-width: var(--container-max-shell);
    margin: 0 auto;
    width: 100%;
  }

  .home-training__text {
    max-width: var(--container-max-text-col);
  }

  .home-training__preheader {
    color: var(--text-heading-muted);
    margin-bottom: var(--space-global-xs);
  }

  .home-training__title {
    font-family: var(--font-tailor-heading-stack);

---
/**
 * Glossary tooltip runtime behaviour [A7].
 * Include this component once per page that has glossary tooltips.
 * The build-time tooltip injection (in glossary-tooltips.ts) adds
 * data attributes; this script handles hover/tap display.
 */
---

<script>
  let tooltipCounter = 0;

  function initTooltips() {
    const terms = document.querySelectorAll<HTMLElement>('[data-glossary-tooltip]');
    let activeTooltip: HTMLElement | null = null;
    let activeTrigger: HTMLElement | null = null;

    function isSimpleMode(): boolean {
      return document.documentElement.classList.contains('simple-active');
    }

    function createTooltip(el: HTMLElement): HTMLElement {
      const slug = el.dataset.termSlug || '';
      const shortDef = el.dataset.shortDef || '';
      const simpleDef = el.dataset.simpleDef || '';
      const definition = isSimpleMode() ? simpleDef : shortDef;

      const tooltip = document.createElement('div');
      tooltip.className = 'glossary-tooltip';
      tooltip.setAttribute('role', 'tooltip');
      tooltip.id = `glossary-tooltip-${++tooltipCounter}`;
      tooltip.innerHTML = `
        <div class="glossary-tooltip__content">
          <p>${definition}</p>
          <a href="/glossary/${slug}" class="glossary-tooltip__link"
             data-analytics-event="glossary_tooltip_click"
             data-analytics-term-slug="${slug}">Read more &rarr;</a>
        </div>
      `;

      return tooltip;
    }

    function showTooltip(el: HTMLElement) {
      hideTooltip();
      const tooltip = createTooltip(el);
      el.appendChild(tooltip);
      activeTooltip = tooltip;
      activeTrigger = el;

      // Link the trigger to the tooltip for screen readers.
      el.setAttribute('aria-describedby', tooltip.id);

      // Position: ensure tooltip stays in viewport
      requestAnimationFrame(() => {
        const rect = tooltip.getBoundingClientRect();
        if (rect.right > window.innerWidth) {
          tooltip.style.left = 'auto';
          tooltip.style.right = '0';
        }
        if (rect.left < 0) {
          tooltip.style.left = '0';
          tooltip.style.right = 'auto';
        }
      });
    }

    function hideTooltip() {
      if (activeTooltip) {
        activeTooltip.remove();
        activeTooltip = null;
      }
      if (activeTrigger) {
        activeTrigger.removeAttribute('aria-describedby');
        activeTrigger = null;
      }
    }

    const isTouchDevice = 'ontouchstart' in window;

    terms.forEach((el) => {
      el.style.position = 'relative';

      // Touch: tap toggles.
      if (isTouchDevice) {
        el.addEventListener('click', (e) => {
          e.preventDefault();
          if (activeTrigger === el) {
            hideTooltip();
          } else {
            showTooltip(el);
          }
        });
      } else {
        // Mouse: hover.
        el.addEventListener('mouseenter', () => showTooltip(el));
        el.addEventListener('mouseleave', (e) => {
          const related = (e as MouseEvent).relatedTarget as HTMLElement;
          if (related && el.contains(related)) return;
          hideTooltip();
        });
      }

      // Keyboard: focus shows, blur hides. Works on both touch and
      // mouse devices and is additive to the above. Space/Enter
      // fire the default button click so we guard against double-toggle.
      el.addEventListener('focus', () => {
        if (activeTrigger !== el) showTooltip(el);
      });
      el.addEventListener('blur', (e) => {
        // Don't hide if focus moved INTO the tooltip (e.g. "Read more" link).
        const related = (e as FocusEvent).relatedTarget as HTMLElement | null;
        if (related && el.contains(related)) return;
        hideTooltip();
      });
    });

    // Escape dismisses + returns focus to the trigger.
    document.addEventListener('keydown', (e) => {
      if (e.key !== 'Escape' || !activeTooltip) return;
      const trigger = activeTrigger;
      hideTooltip();
      trigger?.focus();
    });

    // Close tooltip on click elsewhere (touch).
    if (isTouchDevice) {
      document.addEventListener('click', (e) => {
        if (activeTooltip && !(e.target as HTMLElement).closest('[data-glossary-tooltip]')) {
          hideTooltip();
        }
      });
    }

    // Update tooltip content when mode changes.
    const toggle = document.querySelector('.mode-toggle');
    if (toggle) {
      toggle.addEventListener('click', () => {
        hideTooltip();
      });
    }
  }

  initTooltips();
  document.addEventListener('astro:after-swap', initTooltips);
</script>

<style is:global>
  /* button trigger — reset UA styles so it reads as inline text */
  button.glossary-term {
    display: inline;
    padding: 0;
    margin: 0;
    border: 0;
    background: transparent;
    font: inherit;
    color: inherit;
    letter-spacing: inherit;
    text-align: inherit;
    text-decoration-line: underline;
    text-decoration-style: dotted;
    text-decoration-thickness: 2px;
    text-decoration-color: var(--glossary-underline-color, var(--brand-accent-text));
    text-underline-offset: var(--glossary-underline-offset, 0.2em);
    font-weight: var(--font-weight-semibold);
    cursor: help;
    position: relative;
  }
  button.glossary-term:focus-visible {
    outline: var(--focus-ring-width) solid var(--focus-ring);
    outline-offset: var(--focus-ring-offset);
    border-radius: var(--radius-xs);
  }

  .glossary-tooltip {
    position: absolute;
    bottom: 100%;
    left: 50%;
    transform: translateX(-50%);
    z-index: 30;
    padding-bottom: var(--tooltip-arrow-size);
    pointer-events: auto;
  }

  .glossary-tooltip__content {
    background: var(--tooltip-bg);
    border: var(--tooltip-border-width) solid var(--tooltip-border);
    border-radius: var(--tooltip-radius);
    box-shadow: var(--tooltip-shadow);
    padding: var(--tooltip-padding-y) var(--tooltip-padding-x);
    min-width: 14rem;
    max-width: var(--tooltip-max-width);
    font-size: var(--text-card-size-body, 14px);
    line-height: var(--lh-heading-sub);
    color: var(--tooltip-text);
    font-weight: var(--font-weight-regular);
  }

  .glossary-tooltip .glossary-tooltip__content p {
    font-size: var(--text-card-size-body, 14px);
    line-height: var(--lh-heading-sub);
    margin: 0 0 var(--space-global-xs);
  }

  .glossary-tooltip__link {
    color: var(--brand-accent-text);
    font-size: var(--text-card-size-h6);
    font-weight: var(--font-weight-semibold);
    text-decoration: none;
  }

  .glossary-tooltip__link:hover {
    text-decoration: underline;
  }
</style>

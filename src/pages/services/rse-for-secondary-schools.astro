---
/**
 * Service page [C5] — /services/rse-for-secondary-schools
 * RSE delivery for secondary schools. Tailor layer.
 */
import BaseLayout from '../../layouts/BaseLayout.astro';
import CtaServiceEnquiry from '../../components/CtaServiceEnquiry.astro';
import TopicsOverviewGrid from '../../components/TopicsOverviewGrid.astro';
import ServicePageStyles from '../../components/ServicePageStyles.astro';
import { getBlogPosts } from '../../lib/content';

const allPosts = await getBlogPosts();
const relatedPosts = allPosts.filter((p) => p.serviceLink === 'delivery').slice(0, 3);
---

<BaseLayout
  title="RSE for Secondary Schools — RSE for Schools | Tailor Education"
  description="Expert-led RSE for KS3 and KS4, covering the topics students are actually thinking about — consent, relationships, online safety, and more."
  canonicalPath="/services/rse-for-secondary-schools/"
  jsonLd={{
    '@context': 'https://schema.org',
    '@type': 'Service',
    name: 'RSE for Secondary Schools',
    description: 'Expert-led RSE for KS3 and KS4, covering the topics students are actually thinking about.',
    provider: { '@type': 'Organization', name: 'Tailor Education', url: 'https://tailoreducation.org.uk' },
  }}
>
  <article class="service-page" data-pagefind-body>

    <!-- §1 Hero -->
    <header class="service-page__header">
      <div class="mx-auto w-full max-w-[var(--container-max-shell)] px-[var(--space-global-gutter)] py-[var(--space-global-xl)]">
        <span class="service-page__eyebrow">Services · RSE Delivery</span>
        <h1 class="service-page__title">RSE for secondary schools</h1>
        <p class="service-page__subtitle">
          Expert-led RSE for KS3 and KS4, covering the topics students are actually thinking about — delivered with honesty, sensitivity, and real expertise.
        </p>
      </div>
    </header>

    <!-- §2 Service detail -->
    <section class="service-page__detail">
      <div class="mx-auto w-full max-w-[var(--container-max-prose)] px-[var(--space-global-gutter)] py-[var(--space-struct-y-base)]">

        <!-- [IMAGE PLACEHOLDER: Secondary school RSE session — educator leading discussion with teenagers] -->
        <div class="service-page__image-placeholder" style="margin-bottom: var(--space-global-lg)">
          Image — RSE session in a secondary school (educator leading discussion with KS3/KS4 students)
        </div>

        <div class="service-page__detail-stack">

          <div class="service-page__detail-block">
            <h2 class="service-page__section-title">What this service is</h2>
            <p>A specialist RSE educator delivers lessons directly to your secondary students. Sessions go beyond the textbook — addressing the real questions young people have about consent, relationships, pornography, online behaviour, and identity.</p>
            <p>Students respond differently to an external specialist than they do to their regular teachers. We use that dynamic to create space for the honest, sometimes uncomfortable conversations that RSE needs to include.</p>
          </div>

          <div class="service-page__detail-block">
            <h2 class="service-page__section-title">Who it's for</h2>
            <p>Secondary schools who want expert-led delivery on the topics staff find most challenging. Schools where students have questions that go beyond what the curriculum covers. Schools preparing for inspection where RSE provision needs strengthening. And schools who want to complement their existing programme with specialist sessions on specific topics.</p>
          </div>

          <div class="service-page__detail-block">
            <h2 class="service-page__section-title">What's included</h2>
            <ul>
              <li>Pre-visit consultation to agree topics, year groups, and approach</li>
              <li>Lessons designed for KS3 and KS4 developmental stages</li>
              <li>Coverage of high-demand topics: consent, healthy relationships, online safety, pornography and media literacy, sexual health</li>
              <li>Interactive delivery — discussion-based, not lecture-based</li>
              <li>Post-session summary for PSHE leads, including student engagement insights</li>
              <li>All content aligned to DfE statutory guidance and PSHE Association frameworks</li>
            </ul>
          </div>

          <div class="service-page__detail-block">
            <h2 class="service-page__section-title">What schools get</h2>
            <p>Students who have had the conversations that matter — not just the ones that are easy. Staff who can build on what was covered. A strengthened RSE provision that stands up to scrutiny and, more importantly, actually makes a difference to the young people in the room.</p>
          </div>

        </div>
      </div>
    </section>

    <!-- §4 CTA [A13] — primary -->
    <CtaServiceEnquiry serviceName="RSE for secondary schools" serviceParam="RSE for secondary schools" />

    <!-- §5 Testimonial -->
    <section class="service-page__testimonial">
      <div class="mx-auto w-full max-w-[var(--container-max-prose)] px-[var(--space-global-gutter)] py-[var(--space-struct-y-base)]">
        <blockquote class="testimonial-pullquote">
          <p class="testimonial-pullquote__text">"Our Year 10s are not easy to engage. Within five minutes, every student was listening. The session on consent went further than anything we could have delivered ourselves — and the students said it was the most useful PSHE lesson they'd had."</p>
          <footer class="testimonial-pullquote__footer">
            <span class="testimonial-pullquote__source">— Head of PSHE, secondary school</span>
            <a href="/testimonials" class="testimonial-pullquote__link">Read more testimonials</a>
          </footer>
        </blockquote>
      </div>
    </section>

    <!-- §6 Related blog posts -->
    {relatedPosts.length > 0 && (
      <section class="service-page__blog">
        <div class="mx-auto w-full max-w-[var(--container-max-shell)] px-[var(--space-global-gutter)] py-[var(--space-struct-y-base)]">
          <h2 class="service-page__section-title" style="margin-bottom: var(--space-global-md)">Related articles</h2>
          <div class="service-page__blog-grid">
            {relatedPosts.map((bp) => (
              <a href={`/blog/${bp.slug}`} class="card service-blog-card">
                {bp.featuredImage && (
                  <div class="service-blog-card__img">
                    <img src={bp.featuredImage} alt={bp.title} loading="lazy" />
                  </div>
                )}
                <div class="card__body">
                  {bp.targetAudience && <div class="card__eyebrow">{bp.targetAudience}</div>}
                  <div class="card__title">{bp.title}</div>
                  {bp.author && <div class="service-blog-card__author">By {bp.author}</div>}
                </div>
              </a>
            ))}
          </div>
        </div>
      </section>
    )}

    <!-- §7 Topics overview grid -->
    <TopicsOverviewGrid />

    <!-- §8 CTA [A13] — repeated -->
    <CtaServiceEnquiry serviceName="RSE for secondary schools" serviceParam="RSE for secondary schools" variant="alt" />

  </article>
  <ServicePageStyles />
</BaseLayout>

---
/**
 * Age flag interstitial [D1] — C1 question page.
 *
 * Renders when Age Tier = "Age-flagged Year 9+". Honest signpost, not a gate.
 * The surrounding section wrapper (56rem column) lives in the page template
 * so it can be shared with CrisisSupport [A9] when both are present.
 *
 * Uses .alert.alert--ageflag. Not dismissable. "Continue to the answer"
 * scrolls to the post-it figure and moves focus to its caption.
 */
interface Props {
  topicLabel: string;
  topicSlug: string;
}

const { topicLabel, topicSlug } = Astro.props;
---

<div
  class="alert alert--ageflag"
  id="age-flag"
  role="complementary"
  aria-labelledby="age-flag-title"
>
  <script is:inline>
    if (typeof window.trackEvent === 'function') {
      window.trackEvent('age_flag_shown', {
        question_slug: window.location.pathname.split('/').filter(Boolean).pop() || '',
      });
    }
  </script>
  <div class="alert__icon">
    <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
      <circle cx="12" cy="12" r="10"></circle>
      <line x1="12" y1="8" x2="12" y2="12"></line>
      <line x1="12" y1="16" x2="12.01" y2="16"></line>
    </svg>
  </div>
  <div class="alert__content">
    <div class="alert__title" id="age-flag-title">
      {topicLabel}: this content is aimed at Year 9+
    </div>
    <div class="alert__body">
      <p>
        This answer covers <strong>{topicLabel}</strong> in a way suitable for students in Year 9 and above.
        {' '}
        <a href={`/topics/${topicSlug}`}>Read a foundational answer first &rarr;</a>
      </p>
      <div class="mt-[var(--space-global-sm)]">
        <button
          type="button"
          class="btn btn--sm btn--outline"
          data-ageflag-continue
          data-analytics-event="age_flag_continue"
        >
          Continue to the answer
        </button>
      </div>
    </div>
  </div>
</div>

<script is:inline>
  (function initAgeFlagContinue() {
    var btn = document.querySelector('[data-ageflag-continue]');
    if (!btn) return;
    btn.addEventListener('click', function () {
      var target = document.getElementById('question-post-it');
      var caption = document.getElementById('question-post-it-caption');
      if (target) {
        target.scrollIntoView({ behavior: 'smooth', block: 'start' });
      }
      if (caption) {
        caption.setAttribute('tabindex', '-1');
        // Delay focus until after the smooth scroll has begun so the
        // assistive-tech reading cursor lands cleanly on the caption.
        setTimeout(function () { caption.focus(); }, 350);
      }
    });
  })();
</script>

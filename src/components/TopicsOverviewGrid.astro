---
/**
 * Topics overview grid — reusable 23-topic browse component.
 * Used on service pages [C5], homepage [B1], and training [B4].
 * Shows all landing pages grouped by 7 app categories.
 */

const categories = [
  {
    name: 'Relationships',
    token: 'relationships',
    pages: [
      { title: 'Consent', slug: 'consent' },
      { title: 'Healthy relationships', slug: 'healthy-relationships' },
      { title: 'Friendships', slug: 'friendships' },
      { title: 'Families', slug: 'families' },
      { title: 'Sex and intimacy', slug: 'sex-and-intimacy' },
    ],
  },
  {
    name: 'Sex & Sexual Health',
    token: 'sexual-health',
    pages: [
      { title: 'Contraception', slug: 'contraception' },
      { title: 'STIs and sexual health', slug: 'stis-and-sexual-health' },
      { title: 'Pregnancy and reproductive health', slug: 'pregnancy-and-reproductive-health' },
      { title: 'Sex and the law', slug: 'sex-and-the-law' },
    ],
  },
  {
    name: 'Puberty & The Body',
    token: 'puberty',
    pages: [
      { title: 'Puberty', slug: 'puberty' },
      { title: 'Body image', slug: 'body-image' },
      { title: 'Bodies and anatomy', slug: 'bodies-and-anatomy' },
    ],
  },
  {
    name: 'Identity & Diversity',
    token: 'identity',
    pages: [
      { title: 'LGBTQ+ inclusion', slug: 'lgbtq-inclusion' },
      { title: 'Masculinity and misogyny', slug: 'masculinity-and-misogyny' },
      { title: 'Gender stereotypes and discrimination', slug: 'gender-stereotypes-and-discrimination' },
    ],
  },
  {
    name: 'Online Safety & Media',
    token: 'online-safety',
    pages: [
      { title: 'Online safety', slug: 'online-safety' },
      { title: 'Sexting and sharing nudes', slug: 'sexting-and-sharing-nudes' },
      { title: 'Pornography and media literacy', slug: 'pornography-and-media-literacy' },
    ],
  },
  {
    name: 'Safety & Safeguarding',
    token: 'safety',
    pages: [
      { title: 'Abuse, exploitation and violence', slug: 'abuse-exploitation-and-violence' },
      { title: 'FGM and harmful practices', slug: 'fgm-and-harmful-practices' },
      { title: 'Personal safety', slug: 'personal-safety' },
    ],
  },
  {
    name: 'Health & Wellbeing',
    token: 'wellbeing',
    pages: [
      { title: 'Mental health and wellbeing', slug: 'mental-health-and-wellbeing' },
      { title: 'Self-esteem', slug: 'self-esteem' },
    ],
  },
];
---

<section class="topics-overview">
  <div class="mx-auto max-w-[var(--container-max-shell)] px-[var(--space-global-gutter)] py-[var(--space-struct-y-base)]">
    <h2 class="topics-overview__title">Topics we cover</h2>
    <p class="topics-overview__intro">
      Expert-written RSE content across 23 curriculum-aligned topics.
    </p>
    <div class="topics-overview__grid">
      {categories.map((cat) => (
        <div class="topics-overview__group">
          <h3 class="topics-overview__heading" style={`--cat-color: var(--cat-${cat.token})`}>
            {cat.name}
          </h3>
          <ul class="topics-overview__list" role="list">
            {cat.pages.map((page) => (
              <li>
                <a href={`/topics/${page.slug}`} class="topics-overview__link">
                  {page.title}
                </a>
              </li>
            ))}
          </ul>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .topics-overview__title {
    font-family: var(--font-tailor-heading-stack);
    font-size: var(--text-display-size-h3);
    font-weight: var(--heading-weight-h2);
    color: var(--text-heading);
    margin: 0 0 var(--space-global-xs);
  }

  .topics-overview__intro {
    font-family: var(--font-tailor-body-stack);
    font-size: var(--text-prose-size-body);
    color: var(--text-body-muted);
    margin: 0 0 var(--space-global-lg);
    line-height: var(--lh-body);
  }

  .topics-overview__grid {
    display: grid;
    gap: var(--space-global-md);
  }

  .topics-overview__group {
    padding: var(--space-global-md);
    background: var(--bg-surface);
    border-radius: var(--radius-md);
    border: var(--border-width-xs) solid var(--border-subtle);
  }

  .topics-overview__heading {
    font-family: var(--font-tailor-heading-stack);
    font-size: var(--text-card-size-h3);
    font-weight: var(--heading-weight-h3);
    color: var(--cat-color, var(--text-heading));
    margin: 0 0 var(--space-global-xs);
    padding-bottom: 0.375rem;
    border-bottom: 2px solid var(--cat-color, var(--border-subtle));
  }

  .topics-overview__list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 0.125rem;
  }

  .topics-overview__link {
    display: block;
    padding: 0.35rem 0.5rem;
    font-family: var(--font-tailor-body-stack);
    font-size: var(--text-card-size-body);
    font-weight: var(--font-weight-medium);
    color: var(--brand-accent-text);
    text-decoration: none;
    border-radius: var(--radius-xs);
    transition: background var(--transition-duration) var(--transition-easing);
  }

  .topics-overview__link:hover {
    background: var(--bg-surface-alt);
  }

  @media (min-width: 768px) {
    .topics-overview__grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (min-width: 1024px) {
    .topics-overview__grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }
</style>

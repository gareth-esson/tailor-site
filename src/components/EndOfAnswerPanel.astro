---
/**
 * End-of-answer panel [A17] — C1 question page.
 *
 * Two CTAs: a hero book-buy panel (primary) and a smaller
 * "Bring RSE to your school" secondary. Should feel like a continuation
 * of help, not a conversion block.
 *
 * Lives on a .surface--ota-alt band; the page template owns the outer
 * section/background. This component owns the heading + the panels.
 *
 * All visual values resolve to tokens in tailor-site-v2.css.
 */
---

<!-- Primary CTA — Get the book -->
<a
  href="/book"
  class="end-panel-book"
  data-analytics-event="end_panel_click"
  data-analytics-panel="book"
>
  <img
    src="/images/ota-book-cover.webp"
    alt="Okay to Ask book cover"
    class="end-panel-book__cover"
    loading="lazy"
  />
  <div class="end-panel-book__text">
    <span class="end-panel-book__eyebrow">The Okay to Ask book</span>
    <h3 class="end-panel-book__title">Funny, honest, heartbreaking, useful.</h3>
    <p class="end-panel-book__desc">
      For a young person, parent or carer in your life.
    </p>
    <span class="btn btn--std btn--primary end-panel-book__cta">Buy the book</span>
  </div>
</a>

<!-- Secondary CTA — Bring RSE to your school -->
<a
  href="/services"
  class="end-panel-services"
  data-analytics-event="end_panel_click"
  data-analytics-panel="services"
>
  <div class="end-panel-services__text">
    <span class="end-panel-services__eyebrow">For school leaders</span>
    <div class="end-panel-services__heading">Bring RSE into your school</div>
    <p class="end-panel-services__body">
      Expert-led delivery, training and curriculum planning from the team behind Okay to Ask.
    </p>
  </div>
  <span class="end-panel-services__action">See our services &rarr;</span>
</a>

<style>
  /* ── Section heading ── */
  .end-panel__title {
    font-family: var(--font-ota-heading-stack, inherit);
    font-size: var(--text-prose-size-h2);
    font-weight: var(--heading-ota-weight-h2, 600);
    color: var(--text-ota-heading);
    line-height: var(--lh-heading);
  }

  .end-panel__subtitle {
    font-family: var(--font-ota-body-stack, inherit);
    font-size: var(--text-util-lede-size, var(--text-prose-size-body));
    color: var(--text-ota-muted);
    line-height: var(--lh-ui);
  }

  /* ── Primary: book panel (mirrors .home-ota__book-panel) ── */
  .end-panel-book {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-global-xl);
    padding: var(--space-global-xl);
    background: var(--bg-ota-paper-panel);
    border-radius: var(--radius-lg);
    box-shadow: var(--shadow-md);
    text-decoration: none;
    color: inherit;
    transition:
      box-shadow var(--transition-duration) var(--transition-easing),
      transform var(--transition-duration) var(--transition-easing);
  }
  .end-panel-book:hover {
    box-shadow: var(--shadow-lg);
    transform: translateY(-2px);
  }
  .end-panel-book:focus-visible {
    outline: var(--focus-ring-width) solid var(--focus-ring);
    outline-offset: var(--focus-ring-offset);
  }

  .end-panel-book__cover {
    flex-shrink: 0;
    width: 10rem;
    border-radius: var(--radius-sm);
    box-shadow: var(--book-cover-shadow);
  }

  .end-panel-book__text {
    display: flex;
    flex-direction: column;
    gap: var(--space-global-sm);
    text-align: center;
  }

  .end-panel-book__eyebrow {
    font-size: var(--text-util-preheader-size);
    font-weight: var(--font-weight-semibold);
    letter-spacing: var(--text-util-preheader-ls);
    text-transform: uppercase;
    color: var(--text-ota-muted);
  }

  .end-panel-book__title {
    font-family: var(--font-ota-heading-stack);
    font-size: var(--text-card-size-h2);
    font-weight: var(--heading-ota-weight-h2);
    line-height: var(--lh-heading-sub);
    color: var(--text-ota-heading);
    margin: 0;
  }

  .end-panel-book__desc {
    font-family: var(--font-ota-body-stack);
    font-size: var(--text-prose-size-body);
    line-height: var(--lh-body);
    color: var(--text-ota-muted);
    margin: 0;
  }

  /* ── Secondary: services panel (dark authority, compact) ── */
  .end-panel-services {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: var(--space-global-md);
    margin-top: var(--space-global-lg);
    padding: var(--space-global-lg);
    background: var(--panel-services-bg);
    color: var(--text-on-dark);
    border-radius: var(--panel-radius, var(--radius-lg));
    text-decoration: none;
    transition:
      box-shadow var(--transition-duration) var(--transition-easing),
      transform var(--transition-duration) var(--transition-easing);
  }
  .end-panel-services:hover {
    transform: translateY(-2px);
    box-shadow: var(--shadow-md);
  }
  .end-panel-services:focus-visible {
    outline: var(--focus-ring-width) solid var(--focus-ring-on-dark);
    outline-offset: var(--focus-ring-offset);
  }

  .end-panel-services__text {
    display: flex;
    flex-direction: column;
    gap: var(--space-global-xs);
  }

  .end-panel-services__eyebrow {
    font-size: var(--text-util-preheader-size);
    font-weight: var(--font-weight-semibold);
    letter-spacing: var(--text-util-preheader-ls);
    text-transform: uppercase;
    color: var(--text-muted-on-dark);
  }

  .end-panel-services__heading {
    font-family: var(--font-ota-heading-stack, inherit);
    font-size: var(--text-card-size-h3);
    font-weight: var(--heading-ota-weight-h3, 600);
    line-height: var(--lh-tight);
    color: var(--text-heading-on-dark);
  }

  .end-panel-services__body {
    font-family: var(--font-ota-body-stack, inherit);
    font-size: var(--text-card-size-body);
    line-height: var(--lh-body);
    color: var(--text-muted-on-dark);
    margin: 0;
  }

  .end-panel-services__action {
    font-family: var(--font-ota-body-stack, inherit);
    font-size: var(--text-card-size-body);
    font-weight: var(--font-weight-bold);
    color: var(--link-action-color-on-dark);
  }
  .end-panel-services:hover .end-panel-services__action {
    color: var(--link-action-color-on-dark-hover);
  }

  @media (min-width: 768px) {
    .end-panel-book {
      flex-direction: row;
    }
    .end-panel-book__text {
      text-align: left;
    }
    .end-panel-book__cta {
      align-self: flex-start;
    }
    .end-panel-services {
      flex-direction: row;
      align-items: center;
      justify-content: space-between;
      gap: var(--space-global-xl);
    }
    .end-panel-services__action {
      flex-shrink: 0;
    }
  }

  @media (min-width: 1024px) {
    .end-panel-book__cover {
      width: 12rem;
    }
  }
</style>

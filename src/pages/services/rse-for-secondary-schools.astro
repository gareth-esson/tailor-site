---
/**
 * Service page [C5] — /services/rse-for-secondary-schools
 * RSE delivery for secondary schools. Tailor layer, v3.
 */
import BaseLayout from '../../layouts/BaseLayout.astro';
import CtaServiceEnquiry from '../../components/CtaServiceEnquiry.astro';
import ServiceTopicsStrip from '../../components/ServiceTopicsStrip.astro';
import ServicePageStyles from '../../components/ServicePageStyles.astro';
import { getBlogPosts, getTestimonials } from '../../lib/content';

// --- Data ----------------------------------------------------------
const slug = 'rse-for-secondary-schools';
const title = 'RSE for secondary schools';
const serviceParam = 'RSE for secondary schools';
const serviceName = 'RSE for secondary schools';

const heroSubtitle =
  'Discussion-led RSE for KS3 and KS4 — honest, expert-led sessions that cover the topics students are actually thinking about, delivered with the confidence and credibility a specialist brings.';

const heroImage: string | null = '/images/services/tailor-education-secondary-students-collaborative-learning.webp';
const heroImageAlt = 'Secondary students working collaboratively in a Tailor RSE session';

const descriptionLead =
  'A specialist RSE educator delivers discussion-based lessons to your KS3 and KS4 students — covering consent, healthy relationships, pornography, online safety, misogyny, sexual health, and the topics students are asking about but staff often hesitate to tackle.';

// H2 shown above the description body on the C5 page.
// Placeholder — Gareth: review/replace per service if this isn't the right framing.
const descriptionHeading = 'What is RSE for secondary schools?';

const descriptionBody = [
  'Secondary students can tell when a session is being delivered by someone who isn\'t comfortable with the material — and they disengage fast. Our educators lead with expertise, honesty, and the ability to hold a room through genuinely difficult conversations. Every session is planned with your PSHE lead around what is happening in your cohort.',
];

const whatSchoolsGet =
  'Students who can name what healthy and unhealthy relationships look like, understand consent in concrete terms, recognise coercive and controlling behaviours, and know what to do if something isn\'t right. Staff who have a reference point for difficult conversations. A cohort that has heard someone take these topics seriously.';

const featureCards = [
  { title: 'Pre-visit curriculum consultation', description: 'Planning call with your PSHE lead to agree topics, year groups, cohort context, and anything sensitive happening in the school.' },
  { title: 'Discussion-led session design', description: 'Sessions built around student voice and honest dialogue — not lectures or tick-box coverage.' },
  { title: 'Current, evidence-informed content', description: 'Up-to-date with what KS3 and KS4 students are encountering — pornography, deepfakes, sexting, coercive control.' },
  { title: 'DfE and KCSIE alignment', description: 'All content aligned to DfE statutory RSE and health education guidance and Keeping Children Safe in Education.' },
  { title: 'Disclosure-aware delivery', description: 'Sessions designed so students know how to disclose safely, and so staff are briefed on what to watch for afterwards.' },
  { title: 'Post-session staff debrief', description: 'Written summary with talking points and follow-up recommendations for form tutors and pastoral staff.' },
];

// Prefer secondary-school setting; fall back to any RSE delivery quote
const _testimonials = await getTestimonials();
const _delivery = _testimonials.filter((t) => t.serviceTags.includes('RSE delivery'));
const _match = _delivery.find((t) => t.setting === 'Secondary school') || _delivery[0] || null;
const testimonialQuote: string | null = _match?.quote || null;
const testimonialSource: string | null = _match
  ? [_match.role || _match.name, _match.organisation].filter(Boolean).join(', ')
  : null;

const featuredTopicSlugs = [
  'consent',
  'healthy-relationships',
  'sexting-and-sharing-nudes',
  'pornography-and-media-literacy',
  'masculinity-and-misogyny',
  'mental-health-and-wellbeing',
];

// --- Content --------------------------------------------------------
const allPosts = await getBlogPosts();
const relatedPosts = allPosts.filter((p) => p.serviceLink === 'delivery').slice(0, 3);

const metaTitle = `${title} — RSE for Schools | Tailor Education`;
const metaDescription = 'Discussion-led RSE for KS3 and KS4, delivered by specialist educators with the confidence and credibility to lead honest conversations.';
---

<BaseLayout
  title={metaTitle}
  description={metaDescription}
  canonicalPath={`/services/${slug}/`}
  ogImage={heroImage ?? undefined}
  jsonLd={{
    '@context': 'https://schema.org',
    '@type': 'Service',
    name: title,
    description: metaDescription,
    provider: { '@type': 'Organization', name: 'Tailor Education', url: 'https://tailoreducation.org.uk' },
  }}
>
  <article class="service-page" data-pagefind-body>

    <header class="service-hero">
      <div class="service-hero__wrap">
        <div class="service-hero__inner">
          <div class="service-hero__text">
            <span class="service-hero__eyebrow">Services</span>
            <h1 class="service-hero__title">{title}</h1>
            <p class="service-hero__subtitle">{heroSubtitle}</p>
            <a
              href={`/contact?service=${encodeURIComponent(serviceParam)}`}
              class="btn btn--std btn--primary has-icon-hover"
              data-analytics-event="cta_click"
              data-analytics-cta-type="hero_enquire"
              data-analytics-service-type={serviceParam}
            >Enquire now</a>
          </div>
          <div class="service-hero__image">
            {heroImage ? (
              <img src={heroImage} alt={heroImageAlt} loading="eager" />
            ) : (
              <div class="service-hero__image-placeholder">Hero photography required — source before launch</div>
            )}
          </div>
        </div>
      </div>
    </header>

    <section class="service-description">
      <div class="service-description__inner py-[var(--space-struct-y-base)]">
        <div class="service-description__col">
          <h2 class="service-description__heading">{descriptionHeading}</h2>
          <p class="service-description__lead">{descriptionLead}</p>
          {descriptionBody.map((para) => (<p>{para}</p>))}
          {whatSchoolsGet && (
            <>
              <h2 class="service-description__sub-title">What schools get</h2>
              <p>{whatSchoolsGet}</p>
            </>
          )}
        </div>
      </div>
    </section>

    <section class="service-features">
      <div class="mx-auto w-full max-w-[var(--container-max-shell)] px-[var(--space-global-gutter)] py-[var(--space-struct-y-base)]">
        <h2 class="service-section-title">What's included</h2>
        <div class="service-features__grid">
          {featureCards.map((card) => (
            <div class="feature-card">
              <h3 class="feature-card__title">{card.title}</h3>
              <p class="feature-card__text">{card.description}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <section class="service-proof-band">
      <div class="mx-auto w-full max-w-[var(--container-max-prose)] px-[var(--space-global-gutter)] py-[var(--space-struct-y-base)]">
        <div class="service-proof-band__inner">
          {testimonialQuote && (
            <>
              <blockquote>
                <p class="service-proof-band__quote">"{testimonialQuote}"</p>
              </blockquote>
              <span class="service-proof-band__source">— {testimonialSource}</span>
            </>
          )}
          <div class="service-proof-band__cta-wrap">
            <a
              href={`/contact?service=${encodeURIComponent(serviceParam)}`}
              class="btn btn--std btn--white-primary has-icon-hover"
              data-analytics-event="cta_click"
              data-analytics-cta-type="proof_band_enquire"
              data-analytics-service-type={serviceParam}
            >Enquire about {serviceName}</a>
            <a href="/testimonials" class="service-proof-band__testimonials-link">Read more testimonials →</a>
          </div>
        </div>
      </div>
    </section>

    <ServiceTopicsStrip featuredSlugs={featuredTopicSlugs} />

    {relatedPosts.length > 0 && (
      <section class="service-blog">
        <div class="mx-auto w-full max-w-[var(--container-max-shell)] px-[var(--space-global-gutter)] py-[var(--space-struct-y-base)]">
          <h2 class="service-section-title">Related articles</h2>
          <div class="service-blog__grid">
            {relatedPosts.map((bp) => (
              <a href={`/blog/${bp.slug}`} class="card service-blog-card">
                {bp.featuredImage && (
                  <div class="service-blog-card__img">
                    <img src={bp.featuredImage} alt="" loading="lazy" />
                  </div>
                )}
                <div class="card__body">
                  {bp.targetAudience && <div class="card__eyebrow">{bp.targetAudience}</div>}
                  <h3 class="card__title">{bp.title}</h3>
                  {bp.author && <div class="service-blog-card__author">By {bp.author}</div>}
                </div>
              </a>
            ))}
          </div>
        </div>
      </section>
    )}

    <CtaServiceEnquiry serviceName={serviceName} serviceParam={serviceParam} variant="alt" />

  </article>
  <ServicePageStyles />
</BaseLayout>

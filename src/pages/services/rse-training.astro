---
/**
 * Service page [C5] — /services/rse-training
 * RSE training for school staff. Tailor layer.
 * Mode: individual — highest-traffic service page, richest content.
 */
import BaseLayout from '../../layouts/BaseLayout.astro';
import CtaServiceEnquiry from '../../components/CtaServiceEnquiry.astro';
import TopicsOverviewGrid from '../../components/TopicsOverviewGrid.astro';
import ServicePageStyles from '../../components/ServicePageStyles.astro';
import { getBlogPosts } from '../../lib/content';

const allPosts = await getBlogPosts();
const relatedPosts = allPosts.filter((p) => p.serviceLink === 'training').slice(0, 3);

const serviceParam = 'RSE training';
const serviceName = 'RSE training';

const trustStats = [
  { figure: 'CPD certified', label: 'Professional development' },
  { figure: 'DfE 2026', label: 'Statutory guidance aligned' },
  { figure: 'PSHE mapped', label: 'Association frameworks' },
];

const featureCards = [
  { title: 'Pre-training consultation', description: 'We understand your school\'s context, concerns, and priorities before designing the session.' },
  { title: 'Whole-staff INSET or targeted CPD', description: 'Full-day INSET, half-day sessions, or twilight CPD — whatever fits your calendar.' },
  { title: 'Subject knowledge development', description: 'What the statutory guidance actually says, and what it means in practice for your classroom.' },
  { title: 'Practical teaching strategies', description: 'How to handle difficult questions, manage disclosures, and create safe classroom environments.' },
  { title: 'Topic-specific deep dives', description: 'Consent, online safety, pornography and media literacy, LGBTQ+ inclusion, puberty, and more.' },
  { title: 'Parent communication guidance', description: 'How to manage parent consultation, communication, and withdrawal requests confidently.' },
];

const processSteps = [
  { number: 1, title: 'We understand your needs', description: 'Pre-training consultation to identify priorities, gaps, and the specific concerns your staff have.' },
  { number: 2, title: 'We deliver the training', description: 'Practical, engaging CPD that gives teachers real strategies — not just information.' },
  { number: 3, title: 'Your staff feel ready', description: 'Teachers leave with confidence, resources, and a changed perspective on RSE delivery.' },
];
---

<BaseLayout
  title="RSE Training for Teachers — RSE for Schools | Tailor Education"
  description="Practical RSE training that builds teacher confidence — from whole-staff INSET days to topic-specific CPD sessions, delivered by an experienced RSE specialist."
  canonicalPath="/services/rse-training/"
  jsonLd={{
    '@context': 'https://schema.org',
    '@type': 'Service',
    name: 'RSE Training',
    description: 'Practical RSE training that builds teacher confidence.',
    provider: { '@type': 'Organization', name: 'Tailor Education', url: 'https://tailoreducation.org.uk' },
  }}
>
  <article class="service-page" data-pagefind-body>

    <!-- §1 Hero -->
    <header class="service-hero">
      <div class="mx-auto w-full max-w-[var(--container-max-shell)] px-[var(--space-global-gutter)] py-[var(--space-struct-y-base)]">
        <div class="service-hero__inner service-hero--no-image">
          <div class="service-hero__text">
            <span class="service-hero__eyebrow">Services</span>
            <h1 class="service-hero__title">RSE training</h1>
            <p class="service-hero__subtitle">
              Practical CPD that builds teacher confidence — equipping your staff to deliver RSE that is honest, age-appropriate, and aligned to statutory guidance.
            </p>
            <a
              href={`/contact?service=${encodeURIComponent(serviceParam)}`}
              class="btn btn--std btn--primary has-icon-hover"
              data-analytics-event="cta_click"
              data-analytics-cta-type="hero_enquire"
              data-analytics-service-type={serviceParam}
            >Enquire now</a>
          </div>
        </div>
      </div>
    </header>

    <!-- §2 Trust strip -->
    <section class="service-trust-strip">
      <div class="mx-auto w-full max-w-[var(--container-max-shell)] px-[var(--space-global-gutter)] py-[var(--space-global-lg)]">
        <div class="service-trust-strip__inner">
          {trustStats.map((stat) => (
            <div class="trust-stat">
              <div class="trust-stat__figure">{stat.figure}</div>
              <div class="trust-stat__label">{stat.label}</div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- §4 Service detail -->
    <section class="service-detail">
      <div class="mx-auto w-full max-w-[var(--container-max-prose)] px-[var(--space-global-gutter)] py-[var(--space-struct-y-base)]">

        <h2 class="service-detail__section-title">What this service is</h2>
        <p>RSE training for school staff — from whole-staff INSET days to targeted CPD sessions on specific topics. Delivered by an experienced RSE specialist who understands what teachers actually need: practical strategies, not just theory.</p>
        <p>Training covers subject knowledge, pedagogy, and confidence. Most teachers weren't trained to deliver RSE. Many are uncomfortable with the content, unsure about the boundaries, or worried about parent pushback. This training addresses all of that directly.</p>
        <p>Sessions can focus on specific topics (consent, online safety, LGBTQ+ inclusion) or provide a broader foundation for schools building or strengthening their RSE programme.</p>

        <div class="service-audience-callout">
          <span class="service-audience-callout__eyebrow">Who it's for</span>
          <p class="service-audience-callout__body">Schools investing in staff CPD for RSE — whether that's a whole-staff awareness session, targeted training for PSHE leads and form tutors, or specialist CPD for staff delivering sensitive topics. Also for schools preparing for inspection where RSE training is a gap, or schools responding to specific incidents or concerns that highlight a need for better RSE provision.</p>
        </div>

        <h2 class="service-detail__section-title">What schools get</h2>
        <p>Teachers who feel genuinely more confident — not just informed, but ready to teach. Staff who understand why RSE matters and have the practical skills to deliver it well. A school that can demonstrate a credible, well-supported RSE provision to inspectors, governors, and parents.</p>
        <p>The best training changes how teachers think about RSE, not just what they know about it. That's what we aim for.</p>

      </div>
    </section>

    <!-- §5 Feature cards -->
    <section class="service-features">
      <div class="mx-auto w-full max-w-[var(--container-max-shell)] px-[var(--space-global-gutter)] py-[var(--space-struct-y-base)]">
        <h2 class="service-section-title">What's included</h2>
        <div class="service-features__grid">
          {featureCards.map((card) => (
            <div class="feature-card">
              <h3 class="feature-card__title">{card.title}</h3>
              <p class="feature-card__text">{card.description}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- §6 Process steps -->
    <section class="service-process">
      <div class="mx-auto w-full max-w-[var(--container-max-shell)] px-[var(--space-global-gutter)] py-[var(--space-struct-y-base)]">
        <h2 class="service-section-title">How it works</h2>
        <div class="service-process__grid">
          {processSteps.map((step) => (
            <div class="process-step">
              <div class="process-step__number">{step.number}</div>
              <h3 class="process-step__title">{step.title}</h3>
              <p class="process-step__text">{step.description}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- §7 Dark proof band -->
    <section class="service-proof-band">
      <div class="mx-auto w-full max-w-[var(--container-max-prose)] px-[var(--space-global-gutter)] py-[var(--space-struct-y-base)]">
        <div class="service-proof-band__inner">
          <blockquote>
            <p class="service-proof-band__quote">"This was the most useful training I've had in years. I went from dreading RSE lessons to actually looking forward to them. The practical strategies made all the difference — I finally feel like I know what I'm doing."</p>
          </blockquote>
          <span class="service-proof-band__source">— Year 9 form tutor, secondary school</span>
          <div class="service-proof-band__cta-wrap">
            <a
              href={`/contact?service=${encodeURIComponent(serviceParam)}`}
              class="btn btn--std btn--white-primary has-icon-hover"
              data-analytics-event="cta_click"
              data-analytics-cta-type="proof_band_enquire"
              data-analytics-service-type={serviceParam}
            >Enquire about {serviceName}</a>
            <a href="/testimonials" class="service-proof-band__testimonials-link">Read more testimonials →</a>
          </div>
        </div>
      </div>
    </section>

    <!-- §8 Related blog posts -->
    {relatedPosts.length > 0 && (
      <section class="service-blog">
        <div class="mx-auto w-full max-w-[var(--container-max-shell)] px-[var(--space-global-gutter)] py-[var(--space-struct-y-base)]">
          <h2 class="service-section-title">Related articles</h2>
          <div class="service-blog__grid">
            {relatedPosts.map((bp) => (
              <a href={`/blog/${bp.slug}`} class="card service-blog-card">
                {bp.featuredImage && (
                  <div class="service-blog-card__img">
                    <img src={bp.featuredImage} alt="" loading="lazy" />
                  </div>
                )}
                <div class="card__body">
                  {bp.targetAudience && <div class="card__eyebrow">{bp.targetAudience}</div>}
                  <div class="card__title">{bp.title}</div>
                  {bp.author && <div class="service-blog-card__author">By {bp.author}</div>}
                </div>
              </a>
            ))}
          </div>
        </div>
      </section>
    )}

    <!-- §9 Topics overview grid -->
    <TopicsOverviewGrid />

    <!-- §10 CTA repeated -->
    <CtaServiceEnquiry serviceName={serviceName} serviceParam={serviceParam} variant="alt" />

  </article>
  <ServicePageStyles />
</BaseLayout>
